  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "MapBasis" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups use `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the Logical Model sub-path for BackboneElement\r\nslices passed from parent groups. The IG Publisher may produce SM_TARGET_PATH\r\nerrors. The element names are correct per the IQTIG 18.1 Logical Model.\r\n============================================================================\r\nTeildatensatz Basis (B): Patient + Encounter + Organization -> B:*\r\nEnthaelt die administrativen und demografischen Pflichtfelder fuer die\r\nIQTIG-QS-Meldung (Institutionskennzeichen, Pseudonym-ID, Geburtsdatum,\r\nGeschlecht, Aufnahme/Entlassung).\r\nDie Pseudonymisierung der Versicherten-ID wird von der Vertrauensstelle\r\nuebernommen; hier wird lediglich die bereits pseudonymisierte ID uebertragen.\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntryOrganization" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Organization)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "OrgContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "org" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "FilterIKNR" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'https://fhir.de/sid/arge-ik/iknr'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetIKNRKH" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "institutionskennzeichen" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "FilterStandort" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'http://fhir.de/sid/standortnummer'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetStandort" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "entlassenderStandort" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "FilterBSNR" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'http://fhir.de/sid/kbv/bsnr'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetBSNR" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "betriebsstaettennummer" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetDatensatzVersion" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "datensatzVersion" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "18.1_2024_V05"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryPatient" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Patient)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapBasisPatient" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "patient" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapBasisPatient" ] ;
           fhir:variable ( [ fhir:v "patient" ] [ fhir:v "tgt" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryEncounter" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Encounter)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapBasisEncounter" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "encounter" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapBasisEncounter" ] ;
           fhir:variable ( [ fhir:v "encounter" ] [ fhir:v "tgt" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapBasisPatient" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nPatient -> B:VERSICHERTENIDNEU, B:GEBDATUM, B:GESCHLECHT, B:PLZ\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Patient" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapPseudonymId" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "identifier" ] ;
         fhir:variable [ fhir:v "id" ] ;
         fhir:condition [ fhir:v "system = 'http://fhir.de/sid/gkv/kvid-10'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetPseudonymId" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "id" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "v" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "pseudonymId" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "v"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapPseudonymIdFallback" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "identifier" ] ;
         fhir:variable [ fhir:v "id" ] ;
         fhir:condition [ fhir:v "system.contains('pseudonym') or system.contains('pid')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetPseudonymIdFallback" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "id" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "v" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "pseudonymId" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "v"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetGeburtsdatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "birthDate" ] ;
         fhir:variable [ fhir:v "bd" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geburtsdatum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "bd"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetGeschlechtM" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "gender" ] ;
         fhir:variable [ fhir:v "g" ] ;
         fhir:condition [ fhir:v "$this = 'male'" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geschlecht" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "1"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetGeschlechtF" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "gender" ] ;
         fhir:variable [ fhir:v "g" ] ;
         fhir:condition [ fhir:v "$this = 'female'" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geschlecht" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "2"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetGeschlechtX" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "gender" ] ;
         fhir:variable [ fhir:v "g" ] ;
         fhir:condition [ fhir:v "$this = 'other'" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geschlecht" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "8"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetGeschlechtU" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "gender" ] ;
         fhir:variable [ fhir:v "g" ] ;
         fhir:condition [ fhir:v "$this = 'unknown'" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geschlecht" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "9"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapPLZ" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "address" ] ;
         fhir:variable [ fhir:v "addr" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetPLZ" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "addr" ] ;
           fhir:element [ fhir:v "postalCode" ] ;
           fhir:variable [ fhir:v "plz" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "postleitzahl" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "plz"
             ]
           ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapBasisEncounter" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nEncounter -> B:AUFNDATUM, B:ENTLDATUM, B:AUFNGRUND, B:AUFNANLASS, B:ENTLGRUND\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Encounter" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapFallId" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
