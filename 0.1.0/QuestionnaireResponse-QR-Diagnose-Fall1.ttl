         ] ;
         fhir:code [ fhir:v "7" ] ;
         fhir:display [ fhir:v "histologische Untersuchung eines Primärtumors" ]
       ]
     ] )
  ] [
     fhir:linkId [ fhir:v "stadium-summary" ] ;
     fhir:answer ( [
       fhir:value [
         a fhir:String ;
         fhir:v "UICC IA (cT1c cN0 cM0)"
       ]
     ] )
  ] [
