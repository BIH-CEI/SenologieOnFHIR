                "valueId" : "v"
              }]
            }]
          }]
        },
        {
          "name" : "MapSpecimenCollection",
          "source" : [{
            "context" : "specimen",
            "element" : "collection",
            "variable" : "coll"
          }],
          "rule" : [{
            "name" : "SetHistologiedatumFromSpecimen",
            "source" : [{
              "context" : "coll",
              "element" : "collected",
              "variable" : "collDt",
              "condition" : "$this.is(dateTime)"
            }],
            "target" : [{
              "context" : "tgt",
              "contextType" : "variable",
              "element" : "tumorHistologiedatum",
              "transform" : "copy",
              "parameter" : [{
                "valueId" : "collDt"
              }]
            }]
          }]
        }]
      }]
    },
    {
      "name" : "MapMorphologie",
      "source" : [{
        "context" : "src",
        "element" : "value",
        "variable" : "val"
      }],
      "rule" : [{
        "name" : "MapMorphCoding",
        "source" : [{
          "context" : "val",
          "element" : "coding",
          "variable" : "c",
          "condition" : "system = 'urn:oid:2.16.840.1.113883.6.43.1'"
        }],
        "target" : [{
          "context" : "tgt",
          "contextType" : "variable",
          "element" : "morphologieICDO",
