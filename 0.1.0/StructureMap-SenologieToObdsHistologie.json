      "name" : "EntrySentinelLKUntersucht",
      "source" : [{
        "context" : "bundle",
        "element" : "entry",
        "variable" : "slkEntry",
        "condition" : "resource.is(Observation) and resource.code.coding.exists(code = '92832-5')"
      }],
      "rule" : [{
        "name" : "MapSentinelLKUntersuchtSep",
        "source" : [{
          "context" : "slkEntry",
