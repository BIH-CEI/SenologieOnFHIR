{
  "resourceType": "ViewDefinition",
  "id": "PathologieKohorte",
  "url": "https://www.senologie.org/fhir/ViewDefinition/PathologieKohorte",
  "name": "PathologieKohorte",
  "title": "Pathologie-Kohorte",
  "status": "draft",
  "description": "SQL-on-FHIR ViewDefinition: Pathologie-Befunde (DiagnosticReport). Spalten: reportId, patientId, datum, issued, morphology (ICD-O-3), conclusion (Freitext), specimenRef, institut, status. Hinweis: Aidbox FHIRPath unterstützt today(), replaceMatches(), startsWith(), contains() (String), matches() und iif() noch nicht - Grading (G1-G4), ER/PR/HER2-Status und Ki-67 werden nachgelagert im Notebook aus der conclusion-Spalte (regex) oder aus verknüpften Observations extrahiert. subject-Referenz wird über getReferenceKey(Patient) aufgelöst (Aidbox speichert Referenzen als {id, resourceType}, nicht als 'Type/id'-String).",
  "resource": "DiagnosticReport",
  "where": [
    {
      "path": "meta.profile.where($this='https://www.senologie.org/fhir/StructureDefinition/senologie-pathologie-befund' or $this='https://www.medizininformatik-initiative.de/fhir/ext/modul-patho/StructureDefinition/mii-pr-patho-report').exists()"
    }
  ],
  "select": [
    {
      "column": [
        {
          "path": "getResourceKey()",
          "name": "reportId",
          "type": "id"
        },
        {
          "path": "subject.getReferenceKey(Patient)",
          "name": "patientId",
          "type": "string"
        },
        {
          "path": "effective.ofType(dateTime)",
          "name": "datum",
          "type": "dateTime"
        },
        {
          "path": "issued",
          "name": "issued",
          "type": "instant"
        },
        {
          "path": "conclusionCode.coding.where(system='http://terminology.hl7.org/CodeSystem/icd-o-3').first().code",
          "name": "morphology",
          "type": "code"
        },
        {
          "path": "conclusion",
          "name": "conclusion",
          "type": "string"
        },
        {
          "path": "specimen.first().getReferenceKey(Specimen)",
          "name": "specimenRef",
          "type": "string"
        },
        {
          "path": "performer.first().display",
          "name": "institut",
          "type": "string"
        },
        {
          "path": "status",
          "name": "status",
          "type": "code"
        }
      ]
    }
  ]
}
