{
  "resourceType": "ViewDefinition",
  "id": "OperationenKohorte",
  "url": "https://www.senologie.org/fhir/ViewDefinition/OperationenKohorte",
  "name": "OperationenKohorte",
  "title": "Operationen-Kohorte",
  "status": "draft",
  "description": "SQL-on-FHIR ViewDefinition: Alle Operationen (Procedure) mit OPS-Code, Datum, Seite, Outcome und Performer. Spalten: procedureId, patientId, ops, opsDisplay, kategorie, datum, beginn, seite, seiteCode, outcomeText, outcomeCode, performer, hauptoperateur, intention, reasonConditionId, status. Hinweis: Aidbox FHIRPath unterstützt today(), replaceMatches(), startsWith(), contains() (String), matches() und iif() noch nicht - die nachgelagerte Kategorisierung (BET='5-870'/Mastektomie='5-871|5-872'/SNB='5-401'/ALND='5-402'; Resektionsstatus R0/R1/R2 aus outcomeText) erfolgt im Notebook. subject/reason-Referenzen werden über getReferenceKey(...) aufgelöst (Aidbox speichert Referenzen als {id, resourceType}, nicht als 'Type/id'-String).",
  "resource": "Procedure",
  "where": [
    {
      "path": "meta.profile.where($this='https://www.senologie.org/fhir/StructureDefinition/senologie-operation' or $this='https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-pr-onko-mamma-operation' or $this='https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-pr-onko-operation').exists()"
    }
  ],
  "select": [
    {
      "column": [
        {
          "path": "getResourceKey()",
          "name": "procedureId",
          "type": "id"
        },
        {
          "path": "subject.getReferenceKey(Patient)",
          "name": "patientId",
          "type": "string"
        },
        {
          "path": "code.coding.where(system='http://fhir.de/CodeSystem/bfarm/ops').first().code",
          "name": "ops",
          "type": "code"
        },
        {
          "path": "code.coding.where(system='http://fhir.de/CodeSystem/bfarm/ops').first().display",
          "name": "opsDisplay",
          "type": "string"
        },
        {
          "path": "category.coding.first().display",
          "name": "kategorie",
          "type": "string"
        },
        {
          "path": "performed.ofType(dateTime)",
          "name": "datum",
          "type": "dateTime"
        },
        {
          "path": "performed.ofType(Period).start",
          "name": "beginn",
          "type": "dateTime"
        },
        {
          "path": "bodySite.first().coding.first().display",
          "name": "seite",
          "type": "string"
        },
        {
          "path": "bodySite.first().coding.first().code",
          "name": "seiteCode",
          "type": "code"
        },
        {
          "path": "outcome.text",
          "name": "outcomeText",
          "type": "string"
        },
        {
          "path": "outcome.coding.first().code",
          "name": "outcomeCode",
          "type": "code"
        },
        {
          "path": "performer.first().actor.display",
          "name": "performer",
          "type": "string"
        },
        {
          "path": "performer.where(function.coding.code='304292004').first().actor.display",
          "name": "hauptoperateur",
          "type": "string"
        },
        {
          "path": "extension.where(url='https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-ex-onko-operation-intention').value.coding.first().code",
          "name": "intention",
          "type": "code"
        },
        {
          "path": "reasonReference.first().getReferenceKey(Condition)",
          "name": "reasonConditionId",
          "type": "string"
        },
        {
          "path": "status",
          "name": "status",
          "type": "code"
        }
      ]
    }
  ]
}
