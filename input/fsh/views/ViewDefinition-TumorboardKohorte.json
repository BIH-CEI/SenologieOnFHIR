{
  "resourceType": "ViewDefinition",
  "id": "TumorboardKohorte",
  "url": "https://www.senologie.org/fhir/ViewDefinition/TumorboardKohorte",
  "name": "TumorboardKohorte",
  "title": "Tumorboard-Kohorte",
  "status": "draft",
  "description": "SQL-on-FHIR ViewDefinition: Tumorboard-Empfehlungen (CarePlan). Kopfzeile je CarePlan plus eine Zeile je activity. Spalten (Kopf): careplanId, patientId (volle Referenz 'Patient/xyz'), datum, datumEnde, typ, beschreibung, status, intent, conditionId (volle Referenz 'Condition/xyz'), empfehlungenText, empfehlungenDisplay, empfehlungsStatus, note. Spalten (activity-Zeile): activityKind, activityCode, activityText, activityDisplay, activityStatus. Hinweis: Aidbox FHIRPath unterstützt today(), replaceMatches(), startsWith(), contains() (String), matches(), iif() und den Union-Operator '|' noch nicht - Title-Filter ('Tumorboard'/'Tumorkonferenz') und Präfix-Entfernung ('Patient/', 'Condition/') erfolgen nachgelagert.",
  "resource": "CarePlan",
  "where": [
    {
      "path": "meta.profile.where($this='https://www.senologie.org/fhir/StructureDefinition/senologie-tumorboard-empfehlung').exists()"
    }
  ],
  "select": [
    {
      "column": [
        {
          "path": "getResourceKey()",
          "name": "careplanId",
          "type": "id"
        },
        {
          "path": "subject.getReferenceKey(Patient)",
          "name": "patientId",
          "type": "string"
        },
        {
          "path": "period.start",
          "name": "datum",
          "type": "dateTime"
        },
        {
          "path": "period.end",
          "name": "datumEnde",
          "type": "dateTime"
        },
        {
          "path": "title",
          "name": "typ",
          "type": "string"
        },
        {
          "path": "description",
          "name": "beschreibung",
          "type": "string"
        },
        {
          "path": "status",
          "name": "status",
          "type": "code"
        },
        {
          "path": "intent",
          "name": "intent",
          "type": "code"
        },
        {
          "path": "addresses.first().getReferenceKey(Condition)",
          "name": "conditionId",
          "type": "string"
        },
        {
          "path": "activity.detail.code.text.join('; ')",
          "name": "empfehlungenText",
          "type": "string",
          "description": "Alle freitextlichen empfohlenen Maßnahmen als zusammengefügter String"
        },
        {
          "path": "activity.detail.code.coding.display.join('; ')",
          "name": "empfehlungenDisplay",
          "type": "string",
          "description": "Alle empfohlenen Maßnahmen (Coding.display) als zusammengefügter String"
        },
        {
          "path": "activity.detail.status.join(', ')",
          "name": "empfehlungsStatus",
          "type": "string"
        },
        {
          "path": "note.first().text",
          "name": "note",
          "type": "string"
        }
      ]
    },
    {
      "forEach": "activity",
      "column": [
        {
          "path": "detail.kind",
          "name": "activityKind",
          "type": "code"
        },
        {
          "path": "detail.code.coding.first().code",
          "name": "activityCode",
          "type": "code"
        },
        {
          "path": "detail.code.text",
          "name": "activityText",
          "type": "string"
        },
        {
          "path": "detail.code.coding.first().display",
          "name": "activityDisplay",
          "type": "string"
        },
        {
          "path": "detail.status",
          "name": "activityStatus",
          "type": "code"
        }
      ]
    }
  ]
}
