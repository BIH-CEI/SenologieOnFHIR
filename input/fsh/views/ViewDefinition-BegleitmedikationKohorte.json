{
  "resourceType": "ViewDefinition",
  "id": "BegleitmedikationKohorte",
  "url": "https://www.senologie.org/fhir/ViewDefinition/BegleitmedikationKohorte",
  "name": "BegleitmedikationKohorte",
  "title": "Begleitmedikation-Kohorte",
  "status": "draft",
  "description": "SQL-on-FHIR ViewDefinition: Begleitmedikation (MedicationStatement) mit Substanz, Dosis und Zeitraum.",
  "resource": "MedicationStatement",
  "where": [
    {
      "path": "meta.profile.where($this='https://www.senologie.org/fhir/StructureDefinition/senologie-begleitmedikation').exists()"
    }
  ],
  "select": [
    {
      "column": [
        {
          "path": "getResourceKey()",
          "name": "medicationId",
          "type": "id"
        },
        {
          "path": "subject.getReferenceKey(Patient)",
          "name": "patientId",
          "type": "string"
        },
        {
          "path": "medication.ofType(CodeableConcept).coding.where(system='http://snomed.info/sct').first().display",
          "name": "substanz",
          "type": "string"
        },
        {
          "path": "medication.ofType(CodeableConcept).coding.where(system='http://snomed.info/sct').first().code",
          "name": "substanzCode",
          "type": "code"
        },
        {
          "path": "effective.ofType(Period).start",
          "name": "beginn",
          "type": "dateTime"
        },
        {
          "path": "effective.ofType(Period).end",
          "name": "ende",
          "type": "dateTime"
        },
        {
          "path": "dosage.first().text",
          "name": "dosierung",
          "type": "string"
        },
        {
          "path": "status",
          "name": "status",
          "type": "code"
        }
      ]
    }
  ]
}
