{
  "resourceType": "ViewDefinition",
  "id": "PatientKohorte",
  "url": "http://fhir.bih-charite.de/kds-senologie/ViewDefinition/PatientKohorte",
  "name": "PatientKohorte",
  "title": "Patientenkohorte",
  "status": "draft",
  "description": "SQL-on-FHIR ViewDefinition: Flache Tabelle aller Patientinnen mit Basis-Demographika. Spalten: id, familyName, givenName, gender, birthDate, city, postalCode, deceased. Hinweis: age wird nachgelagert aus birthDate berechnet (Aidbox FHIRPath unterstützt today() noch nicht). Name ist in familyName und givenName aufgeteilt; Zusammenfügen erfolgt nachgelagert (String-Konkatenation mit + ist in Aidbox bei leeren Operanden problematisch).",
  "resource": "Patient",
  "select": [
    {
      "column": [
        {
          "path": "getResourceKey()",
          "name": "id",
          "type": "id"
        },
        {
          "path": "name.where(use='official' or use.empty()).first().family",
          "name": "familyName",
          "type": "string"
        },
        {
          "path": "name.where(use='official' or use.empty()).first().given.first()",
          "name": "givenName",
          "type": "string"
        },
        {
          "path": "gender",
          "name": "gender",
          "type": "code"
        },
        {
          "path": "birthDate",
          "name": "birthDate",
          "type": "date"
        },
        {
          "path": "address.where(use='home' or use.empty()).first().city",
          "name": "city",
          "type": "string"
        },
        {
          "path": "address.where(use='home' or use.empty()).first().postalCode",
          "name": "postalCode",
          "type": "string"
        },
        {
          "path": "deceased.ofType(dateTime).exists() or deceased.ofType(boolean) = true",
          "name": "deceased",
          "type": "boolean"
        }
      ]
    }
  ]
}
