{
  "resourceType": "ViewDefinition",
  "id": "SystemtherapieKohorte",
  "url": "http://fhir.bih-charite.de/kds-senologie/ViewDefinition/SystemtherapieKohorte",
  "name": "SystemtherapieKohorte",
  "title": "Systemtherapie-Kohorte",
  "status": "draft",
  "description": "SQL-on-FHIR ViewDefinition: Systemische Therapien (Procedure). Spalten: procedureId, patientId (volle Referenz 'Patient/xyz'), categoryCode, categoryDisplay, typCode, typDisplay, intention, intentionDisplay, beginn, ende, performedDateTime, protokoll, protokollCode, outcomeText, outcomeCode, reasonConditionId, note, status. Hinweis: Aidbox FHIRPath unterstützt today(), replaceMatches(), startsWith(), contains() (String), matches() und iif() noch nicht - die Kategorisierung der Art (CH=Chemo=SNOMED 385786002, HO=Hormon=169413002, IM=Immun=76334006, ZT=Zielgerichtet=764166006) erfolgt nachgelagert im Notebook anhand categoryCode/typCode.",
  "resource": "Procedure",
  "where": [
    {
      "path": "meta.profile.where($this='http://fhir.bih-charite.de/kds-senologie/StructureDefinition/senologie-systemtherapie-procedure' or $this='https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-pr-onko-systemische-therapie').exists()"
    }
  ],
  "select": [
    {
      "column": [
        {
          "path": "getResourceKey()",
          "name": "procedureId",
          "type": "id"
        },
        {
          "path": "subject.getReferenceKey(Patient)",
          "name": "patientId",
          "type": "string"
        },
        {
          "path": "category.coding.first().code",
          "name": "categoryCode",
          "type": "code"
        },
        {
          "path": "category.coding.first().display",
          "name": "categoryDisplay",
          "type": "string"
        },
        {
          "path": "code.coding.first().code",
          "name": "typCode",
          "type": "code"
        },
        {
          "path": "code.coding.first().display",
          "name": "typDisplay",
          "type": "string"
        },
        {
          "path": "extension.where(url='https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-ex-onko-systemische-therapie-intention').value.coding.first().code",
          "name": "intention",
          "type": "code"
        },
        {
          "path": "extension.where(url='https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-ex-onko-systemische-therapie-intention').value.coding.first().display",
          "name": "intentionDisplay",
          "type": "string"
        },
        {
          "path": "performed.ofType(Period).start",
          "name": "beginn",
          "type": "dateTime"
        },
        {
          "path": "performed.ofType(Period).end",
          "name": "ende",
          "type": "dateTime"
        },
        {
          "path": "performed.ofType(dateTime)",
          "name": "performedDateTime",
          "type": "dateTime"
        },
        {
          "path": "usedCode.coding.first().display",
          "name": "protokoll",
          "type": "string"
        },
        {
          "path": "usedCode.coding.first().code",
          "name": "protokollCode",
          "type": "code"
        },
        {
          "path": "outcome.text",
          "name": "outcomeText",
          "type": "string"
        },
        {
          "path": "outcome.coding.first().code",
          "name": "outcomeCode",
          "type": "code"
        },
        {
          "path": "reasonReference.first().getReferenceKey(Condition)",
          "name": "reasonConditionId",
          "type": "string"
        },
        {
          "path": "note.first().text",
          "name": "note",
          "type": "string"
        },
        {
          "path": "status",
          "name": "status",
          "type": "code"
        },
        {
          "path": "partOf.first().getReferenceKey(Procedure)",
          "name": "partOfRef",
          "type": "string"
        }
      ]
    }
  ]
}
