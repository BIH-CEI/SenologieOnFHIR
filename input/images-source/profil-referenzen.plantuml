@startuml profil-referenzen
!define DIAG_COLOR #FFCDD2
!define BILDG_COLOR #C8E6C9
!define PATHO_COLOR #D1C4E9
!define THER_COLOR #BBDEFB
!define ANAM_COLOR #FFF9C4
!define PLAN_COLOR #FFE0B2
!define OTHER_COLOR #F5F5F5

skinparam class {
  FontSize 11
}
top to bottom direction

title Referenzmodell – Senologie-Profile

class "**Patient**" as pat #E0E0E0

' === Diagnose ===
package "Diagnose" {
  class "Diagnose\nMaligne" as diag DIAG_COLOR
  class "Diagnose\nBenigne" as diag_b DIAG_COLOR
}

' === Bildgebung ===
package "Bildgebung" {
  class "Bildgebung\nBefund" as bild BILDG_COLOR
  class "Bildgebung\nObservation" as bildo BILDG_COLOR
  class "Bildgebung\nSonstige" as bilds BILDG_COLOR
  class "Tumor-\nlokalisation" as loc BILDG_COLOR
}

' === Pathologie ===
package "Pathologie" {
  class "Pathologie\nBefund" as patho PATHO_COLOR
  class "Pathologie\nPräparat" as spec PATHO_COLOR
}

' === Therapie ===
package "Operative Therapie" {
  class "Operation" as op THER_COLOR
  class "OP Planung" as plan PLAN_COLOR
  class "Komplikation" as komp OTHER_COLOR
  class "Implantat" as impl OTHER_COLOR
}

package "Systemische Therapie" {
  class "Systemtherapie\nProcedure" as sysp THER_COLOR
  class "Systemtherapie\nMedikation" as sysm THER_COLOR
  class "Geplante\nSystemtherapie" as sysg PLAN_COLOR
}

package "Strahlentherapie" {
  class "Strahlen-\ntherapie" as rt THER_COLOR
}

' === Anamnese ===
package "Anamnese" {
  class "Klinische\nUntersuchung" as klin ANAM_COLOR
  class "Gynäkologische\nAnamnese" as gyn ANAM_COLOR
  class "Familien-\nanamnese" as fam ANAM_COLOR
}

' === Risiko ===
package "Genexpression" {
  class "Genexpressions-\ntest" as gen OTHER_COLOR
  class "Genexpressions-\nScore" as score OTHER_COLOR
}

' === Planung ===
package "Planung" {
  class "Tumorboard\nEmpfehlung" as tb PLAN_COLOR
  class "Begleit-\nmedikation" as bmed OTHER_COLOR
  class "Studien-\nteilnahme" as study OTHER_COLOR
}

' === Referenzen: subject → Patient ===
pat <-down- diag : subject
pat <-down- diag_b : subject
pat <-down- bild : subject
pat <-down- patho : subject
pat <-down- op : subject
pat <-down- sysp : subject
pat <-down- rt : subject

' === Bildgebung intern ===
bild -down-> bildo : result
bild -right-> loc

' === Pathologie intern ===
patho -down-> spec : specimen

' === Therapie → Diagnose ===
op -left-> diag : reasonReference
sysp -left-> diag : reasonReference
rt -left-> diag : reasonReference
sysg -left-> diag : reasonReference

' === OP-Zusammenhänge ===
plan -down-> op : basedOn
komp -up-> op : focus
op -down-> impl : focalDevice
op -right-> op : partOf\n(Subprozedur)

' === Systemtherapie intern ===
sysm -up-> sysp : partOf

' === Genexpressionstest ===
gen -down-> score : basis

' === Tumorboard ===
tb -down-> diag : addresses
tb -down-> op : activity
tb -down-> sysp : activity
tb -down-> rt : activity

legend right
  |= Farbe |= Domäne |
  | <back:FFCDD2> </back> | Diagnose |
  | <back:C8E6C9> </back> | Bildgebung |
  | <back:D1C4E9> </back> | Pathologie |
  | <back:BBDEFB> </back> | Therapie |
  | <back:FFF9C4> </back> | Anamnese |
  | <back:FFE0B2> </back> | Planung |
  | <back:F5F5F5> </back> | Sonstige |
endlegend

@enduml
