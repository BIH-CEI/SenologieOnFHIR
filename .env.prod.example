# Domain for HTTPS (Caddy auto-provisions Let's Encrypt certificate)
DOMAIN=fhir.example.com

# Aidbox
AIDBOX_LICENSE=your-license-jwt-here
AIDBOX_BASE_URL=https://fhir.example.com
AIDBOX_ADMIN_ID=admin
AIDBOX_ADMIN_PASSWORD=CHANGE-ME-strong-password
AIDBOX_CLIENT_ID=root
AIDBOX_CLIENT_SECRET=CHANGE-ME-strong-secret

# PostgreSQL
PGPASSWORD=CHANGE-ME-strong-db-password
