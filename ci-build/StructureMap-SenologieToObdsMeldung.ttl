<https://www.senologie.org/fhir/StructureMap/SenologieToObdsMeldung> a fhir:StructureMap ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "SenologieToObdsMeldung"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToObdsMeldung</b></p><a name=\"SenologieToObdsMeldung\"> </a><a name=\"hcSenologieToObdsMeldung\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToObdsMeldung<span style=\"color: navy\">\" = \"</span>SenologieToObdsMeldung<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie FHIR Bundle to oBDS Meldung (Master Orchestrator)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/condition.html\" title=\"Condition\">http://hl7.org/fhir/StructureDefinition/Condition</a><span style=\"color: navy\">\" </span><b>alias </b>Condition <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/procedure.html\" title=\"Procedure\">http://hl7.org/fhir/StructureDefinition/Procedure</a><span style=\"color: navy\">\" </span><b>alias </b>Procedure <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/careplan.html\" title=\"CarePlan\">http://hl7.org/fhir/StructureDefinition/CarePlan</a><span style=\"color: navy\">\" </span><b>alias </b>CarePlan <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/patient.html\" title=\"Patient\">http://hl7.org/fhir/StructureDefinition/Patient</a><span style=\"color: navy\">\" </span><b>alias </b>Patient <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/observation.html\" title=\"Observation\">http://hl7.org/fhir/StructureDefinition/Observation</a><span style=\"color: navy\">\" </span><b>alias </b>Observation <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-obds-meldung.html\" title=\"oBDS Meldung\">https://www.senologie.org/fhir/StructureDefinition/obds-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>OBDSMeldung <b>as </b><b>target</b>#xD;\n#xD;\n<b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsTumorzuordnung.html\" title=\"SenologieToObdsTumorzuordnung\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsDiagnose.html\" title=\"SenologieToObdsDiagnose\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsDiagnose</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsOP.html\" title=\"SenologieToObdsOP\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsOP</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsSYST.html\" title=\"SenologieToObdsSYST\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsSYST</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsST.html\" title=\"SenologieToObdsST\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsST</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsTumorkonferenz.html\" title=\"SenologieToObdsTumorkonferenz\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorkonferenz</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsVerlauf.html\" title=\"SenologieToObdsVerlauf\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsVerlauf</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsTod.html\" title=\"SenologieToObdsTod\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsTod</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsTNM.html\" title=\"SenologieToObdsTNM\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsHistologie.html\" title=\"SenologieToObdsHistologie\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsModulMamma.html\" title=\"SenologieToObdsModulMamma\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsFernmetastasen.html\" title=\"SenologieToObdsFernmetastasen\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsFernmetastasen</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsResidualstatus.html\" title=\"SenologieToObdsResidualstatus\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsResidualstatus</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsNebenwirkung.html\" title=\"SenologieToObdsNebenwirkung\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsNebenwirkung</a><span style=\"color: navy\">\"#xD;\n</span><b>imports</b><span style=\"color: navy\"> \"</span><a href=\"StructureMap-SenologieToObdsLeistungszustand.html\" title=\"SenologieToObdsLeistungszustand\">https://www.senologie.org/fhir/StructureMap/SenologieToObdsLeistungszustand</a><span style=\"color: navy\">\"#xD;\n</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Master Orchestrator: Bundle -&gt; oBDS Meldung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Empfaengt ein FHIR Bundle mit allen Ressourcen eines Patienten und</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">dispatcht an die jeweiligen Teil-Maps basierend auf Ressourcentyp und Profil.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Jede Ressource erzeugt eine separate oBDS-Meldung:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- Condition (Erstdiagnose)         -&gt; Diagnosemeldung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- Condition (Rezidiv)              -&gt; Verlaufsmeldung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- Procedure (Operation)            -&gt; OP-Meldung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- Procedure (Systemtherapie)       -&gt; SYST-Meldung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- Procedure (Strahlentherapie)     -&gt; ST-Meldung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- CarePlan (Tumorboard)            -&gt; Tumorkonferenzmeldung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- Patient (verstorben)             -&gt; Todesmeldung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>SenologieToObdsMeldung<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Bundle, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>OBDSMeldung<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Meldungs-Metadaten ---</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt<b> then </b>SetMeldungMetadata<span style=\"color: navy\">(</span><span style=\"color: maroon\">src</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">tgt</span><span style=\"color: navy\">)</span> <i>\"CallSetMeldungMetadata\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Diagnose: Condition mit Senologie-Diagnose-Profil, NICHT Rezidiv ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">clinicalStatus != recurrence und Profil senologie-diagnose</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Condition) and resource.meta.profile.exists($this.contains('senologie-diagnose')) and resource.clinicalStatus.coding.exists(code = 'recurrence').not()<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">condition</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">Tumorzuordnung</span>#xD;\n      condition<span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorzuordnung<b> as </b><span style=\"color: maroon\">tz</span><b> then </b>MapTumorzuordnung<span style=\"color: navy\">(</span><span style=\"color: maroon\">condition</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">tz</span><span style=\"color: navy\">)</span> <i>\"DiagnoseTZ\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">Diagnose: delegiert an SenologieToObdsDiagnose.MapDiagnose</span>#xD;\n      condition<span style=\"color: navy\"><b> -&gt; </b></span>tgt.diagnose<b> as </b><span style=\"color: maroon\">dx</span><b> then </b>MapDiagnose<span style=\"color: navy\">(</span><span style=\"color: maroon\">condition</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">dx</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">src</span><span style=\"color: navy\">)</span> <i>\"DiagnoseDX\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"DiagnoseConditionContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryDiagnose\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Verlauf: Condition mit clinicalStatus = recurrence (Rezidiv) ---</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Condition) and resource.clinicalStatus.coding.exists(code = 'recurrence')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">condition</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">Tumorzuordnung</span>#xD;\n      condition<span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorzuordnung<b> as </b><span style=\"color: maroon\">tz</span><b> then </b>MapTumorzuordnung<span style=\"color: navy\">(</span><span style=\"color: maroon\">condition</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">tz</span><span style=\"color: navy\">)</span> <i>\"VerlaufTZ\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">Verlauf: delegiert an SenologieToObdsVerlauf.MapVerlauf</span>#xD;\n      condition<span style=\"color: navy\"><b> -&gt; </b></span>tgt.verlauf<b> as </b><span style=\"color: maroon\">verl</span><b> then </b>MapVerlauf<span style=\"color: navy\">(</span><span style=\"color: maroon\">condition</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">verl</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">src</span><span style=\"color: navy\">)</span> <i>\"VerlaufMap\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"VerlaufConditionContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryVerlauf\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- OP: Procedure mit Senologie-Operation-Profil ---</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-operation') or $this.contains('senologie-brustop'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">procedure</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">OP: delegiert an SenologieToObdsOP.MapOP</span>#xD;\n      procedure<span style=\"color: navy\"><b> -&gt; </b></span>tgt.op<b> as </b><span style=\"color: maroon\">op</span><b> then </b>MapOP<span style=\"color: navy\">(</span><span style=\"color: maroon\">procedure</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">op</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">src</span><span style=\"color: navy\">)</span> <i>\"OPMap\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"OPProcedureContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryOP\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Systemische Therapie: Procedure mit Systemtherapie-Profil ---</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-systemtherapie-procedure'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">procedure</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">SYST: delegiert an SenologieToObdsSYST.MapSYST</span>#xD;\n      procedure<span style=\"color: navy\"><b> -&gt; </b></span>tgt.syst<b> as </b><span style=\"color: maroon\">syst</span><b> then </b>MapSYST<span style=\"color: navy\">(</span><span style=\"color: maroon\">procedure</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">syst</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">src</span><span style=\"color: navy\">)</span> <i>\"SYSTMap\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"SYSTProcedureContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntrySYST\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Strahlentherapie: Procedure mit Strahlentherapie-Profil ---</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-strahlentherapie'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">procedure</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">ST: delegiert an SenologieToObdsST.MapST</span>#xD;\n      procedure<span style=\"color: navy\"><b> -&gt; </b></span>tgt.st<b> as </b><span style=\"color: maroon\">st</span><b> then </b>MapST<span style=\"color: navy\">(</span><span style=\"color: maroon\">procedure</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">st</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">src</span><span style=\"color: navy\">)</span> <i>\"STMap\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"STProcedureContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryST\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Tumorkonferenz: CarePlan mit Tumorboard-Empfehlung-Profil ---</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(CarePlan) and resource.meta.profile.exists($this.contains('senologie-tumorboard-empfehlung'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">careplan</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">Tumorkonferenz: delegiert an SenologieToObdsTumorkonferenz.MapTumorkonferenz</span>#xD;\n      careplan<span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorkonferenz<b> as </b><span style=\"color: maroon\">tk</span><b> then </b>MapTumorkonferenz<span style=\"color: navy\">(</span><span style=\"color: maroon\">careplan</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">tk</span><span style=\"color: navy\">)</span> <i>\"TumorkonferenzMap\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"TumorkonferenzCarePlanContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryTumorkonferenz\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Tod: Patient mit deceasedDateTime ---</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Patient) and resource.deceased.exists()<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">patient</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">Tod: delegiert an SenologieToObdsTod.MapTod</span>#xD;\n      patient<span style=\"color: navy\"><b> -&gt; </b></span>tgt.tod<b> as </b><span style=\"color: maroon\">tod</span><b> then </b>MapTod<span style=\"color: navy\">(</span><span style=\"color: maroon\">patient</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">tod</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">src</span><span style=\"color: navy\">)</span> <i>\"TodMap\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"TodPatientContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryTod\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">SetMeldungMetadata: Meldungs-Metadaten erzeugen</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">meldungID, melderID, meldebegruendung, eigeneLeistung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>SetMeldungMetadata<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Bundle, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>OBDSMeldung<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Meldung_ID: aus Bundle.identifier oder generierte UUID</span>#xD;\n  src.identifier<b> as </b><span style=\"color: maroon\">id</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    id.value<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.meldungID = <span style=\"color: maroon\">v</span> <i>\"SetMeldungIDFromIdentifier\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapMeldungID\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Fallback: generierte UUID als Meldung_ID</span>#xD;\n  src<b> where </b>identifier.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.meldungID = <b>uuid</b><span style=\"color: navy\">(</span><span style=\"color: navy\">)</span> <i>\"SetMeldungIDGenerated\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Melder_ID: aus Bundle.meta.source oder fest konfigurierter Wert</span>#xD;\n  src.meta<b> as </b><span style=\"color: maroon\">meta</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    meta.source<b> as </b><span style=\"color: maroon\">s</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.melderID = <span style=\"color: maroon\">s</span> <i>\"SetMelderIDFromSource\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapMelderID\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Meldebegruendung: I (eigene Leistung) als Standard</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Wird ggf. durch die Teil-Maps ueberschrieben basierend auf Meldungstyp</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.meldebegruendung = <span style=\"color: blue\">'I'</span> <i>\"SetMeldebegruendung\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Eigene Leistung: J als Standard (Behandlungseinrichtung meldet eigene Daten)</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.eigeneLeistung = <span style=\"color: blue\">'J'</span> <i>\"SetEigeneLeistung\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:url [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsMeldung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsMeldung>
  ] ; # 
  fhir:version [ fhir:v "0.1.0"] ; # 
  fhir:name [ fhir:v "SenologieToObdsMeldung"] ; # 
  fhir:status [ fhir:v "draft"] ; # 
  fhir:date [ fhir:v "2026-05-03T21:28:00+00:00"^^xsd:dateTime] ; # 
  fhir:publisher [ fhir:v "Berlin Institute of Health at Charité (BIH)"] ; # 
  fhir:contact ( [
     fhir:name [ fhir:v "Berlin Institute of Health at Charité (BIH)" ] ;
     fhir:telecom ( [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://www.bihealth.org" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "title: Senologie FHIR Bundle to oBDS Meldung (Master Orchestrator)\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Condition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Condition>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Condition" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Procedure"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Procedure>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Procedure" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/CarePlan"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/CarePlan>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "CarePlan" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Patient"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Patient>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Patient" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Observation"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Observation>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Observation" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/obds-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/obds-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OBDSMeldung" ]
  ] ) ; # 
  fhir:import ( [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsDiagnose"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsDiagnose>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsOP"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsOP>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsSYST"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsSYST>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsST"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsST>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorkonferenz"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorkonferenz>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsVerlauf"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsVerlauf>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTod"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTod>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsFernmetastasen"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsFernmetastasen>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsResidualstatus"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsResidualstatus>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsNebenwirkung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsNebenwirkung>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsLeistungszustand"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsLeistungszustand>
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "SenologieToObdsMeldung" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nMaster Orchestrator: Bundle -> oBDS Meldung\r\nEmpfaengt ein FHIR Bundle mit allen Ressourcen eines Patienten und\r\ndispatcht an die jeweiligen Teil-Maps basierend auf Ressourcentyp und Profil.\r\nJede Ressource erzeugt eine separate oBDS-Meldung:\r\n- Condition (Erstdiagnose)         -> Diagnosemeldung\r\n- Condition (Rezidiv)              -> Verlaufsmeldung\r\n- Procedure (Operation)            -> OP-Meldung\r\n- Procedure (Systemtherapie)       -> SYST-Meldung\r\n- Procedure (Strahlentherapie)     -> ST-Meldung\r\n- CarePlan (Tumorboard)            -> Tumorkonferenzmeldung\r\n- Patient (verstorben)             -> Todesmeldung\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "OBDSMeldung" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "CallSetMeldungMetadata" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "SetMeldungMetadata" ] ;
         fhir:variable ( [ fhir:v "src" ] [ fhir:v "tgt" ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryDiagnose" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition) and resource.meta.profile.exists($this.contains('senologie-diagnose')) and resource.clinicalStatus.coding.exists(code = 'recurrence').not()" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "DiagnoseConditionContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "DiagnoseTZ" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "condition" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "tumorzuordnung" ] ;
             fhir:variable [ fhir:v "tz" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapTumorzuordnung" ] ;
             fhir:variable ( [ fhir:v "condition" ] [ fhir:v "tz" ] )
           ] )
         ] [
           fhir:name [ fhir:v "DiagnoseDX" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "condition" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "diagnose" ] ;
             fhir:variable [ fhir:v "dx" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapDiagnose" ] ;
             fhir:variable ( [ fhir:v "condition" ] [ fhir:v "dx" ] [ fhir:v "src" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryVerlauf" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition) and resource.clinicalStatus.coding.exists(code = 'recurrence')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "VerlaufConditionContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "VerlaufTZ" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "condition" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "tumorzuordnung" ] ;
             fhir:variable [ fhir:v "tz" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapTumorzuordnung" ] ;
             fhir:variable ( [ fhir:v "condition" ] [ fhir:v "tz" ] )
           ] )
         ] [
           fhir:name [ fhir:v "VerlaufMap" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "condition" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "verlauf" ] ;
             fhir:variable [ fhir:v "verl" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapVerlauf" ] ;
             fhir:variable ( [ fhir:v "condition" ] [ fhir:v "verl" ] [ fhir:v "src" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryOP" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-operation') or $this.contains('senologie-brustop'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "OPProcedureContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "OPMap" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "procedure" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "op" ] ;
             fhir:variable [ fhir:v "op" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapOP" ] ;
             fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "op" ] [ fhir:v "src" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntrySYST" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-systemtherapie-procedure'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SYSTProcedureContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SYSTMap" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "procedure" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "syst" ] ;
             fhir:variable [ fhir:v "syst" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapSYST" ] ;
             fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "syst" ] [ fhir:v "src" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryST" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-strahlentherapie'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "STProcedureContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "STMap" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "procedure" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "st" ] ;
             fhir:variable [ fhir:v "st" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapST" ] ;
             fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "st" ] [ fhir:v "src" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryTumorkonferenz" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(CarePlan) and resource.meta.profile.exists($this.contains('senologie-tumorboard-empfehlung'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "TumorkonferenzCarePlanContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "careplan" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "TumorkonferenzMap" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "careplan" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "tumorkonferenz" ] ;
             fhir:variable [ fhir:v "tk" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapTumorkonferenz" ] ;
             fhir:variable ( [ fhir:v "careplan" ] [ fhir:v "tk" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryTod" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Patient) and resource.deceased.exists()" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "TodPatientContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "patient" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "TodMap" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "patient" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
