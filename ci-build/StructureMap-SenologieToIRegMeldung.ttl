  fhir:description [ fhir:v "title: Senologie FHIR Bundle to IRegG Brustimplantat-Meldung (Orchestrator)\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Patient"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Patient>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Patient" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Encounter"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Encounter>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Encounter" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Procedure"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Procedure>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Procedure" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Device"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Device>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Device" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Condition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Condition>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Condition" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Observation"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Observation>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Observation" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Organization"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Organization>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Organization" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/ireg-brustimplantat-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/ireg-brustimplantat-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "IRegMeldung" ]
  ] ) ; # 
  fhir:import ( [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToIRegPatient"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToIRegPatient>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToIRegOperation"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToIRegOperation>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToIRegEntlassung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToIRegEntlassung>
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "SenologieToIRegMeldung" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups (MapMeldungskopf, MapFall) use\r\n`target tgt : BackboneElement` because FML has no syntax to declare the\r\nspecific Logical Model sub-path when a parent group passes a BackboneElement\r\nslice. The IG Publisher resolves target paths against BackboneElement,\r\nproducing ~20 SM_TARGET_PATH / SM_SOURCE_PATH errors. The element names are\r\ncorrect and match the IRegG Brustimplantat Logical Model. These errors are\r\ncosmetic.\r\n============================================================================\r\nMaster Orchestrator: Bundle -> IRegG Brustimplantat-Meldung\r\nEmpfaengt ein FHIR Bundle mit Senologie-Ressourcen (Patient, Procedure,\r\nDevice, Encounter, Condition, Observations) und erzeugt eine vollstaendige\r\nIRegG-Meldung fuer Brustimplantate.\r\nIm Gegensatz zur oBDS-Transformation (mehrere Meldungen pro Bundle)\r\nerzeugt die IRegG-Meldung eine einzelne GEMeldung pro Behandlungsfall.\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "IRegMeldung" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "CallMapMeldungskopf" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "meldung" ] ;
         fhir:variable [ fhir:v "mel" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapMeldungskopf" ] ;
         fhir:variable ( [ fhir:v "src" ] [ fhir:v "mel" ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryEncounter" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Encounter)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapFall" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "encounter" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "fall" ] ;
           fhir:variable [ fhir:v "fall" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapFall" ] ;
           fhir:variable ( [ fhir:v "encounter" ] [ fhir:v "fall" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapMeldungskopf" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nMeldungskopf: Bundle -> meldung (MEL_*)\r\nEinrichtungskennung, Softwareinfo aus Organization und Bundle-Metadaten\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntryOrganization" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Organization)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "OrgContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "org" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "FilterIrdId" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'http://fhir.de/sid/ird/ge-kennung'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetIdEinrichtung" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "idEinrichtung" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "FilterBsnr" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'https://fhir.de/sid/arge-ik/iknr'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetBsnr" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "bsnr" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetSpezVersion" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "irdSpezVersion" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "4.1.1"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetSwName" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "swName" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "Senologie-KDS FHIR IG"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetSwHersteller" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "swHersteller" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "BIH at Charite"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetSwVersion" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "swVersion" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "0.1.0"
           ]
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapFall" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nFall: Encounter -> fall (FAL_*)\r\nAufnahmedatum, Art des Aufenthalts, Transfernummer\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Encounter" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapAufnahmedatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "period" ] ;
         fhir:variable [ fhir:v "period" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetAufnahmedatum" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "period" ] ;
           fhir:element [ fhir:v "start" ] ;
           fhir:variable [ fhir:v "s" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "aufnahmedatum" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "s"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapArtAufenthalt" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "class" ] ;
         fhir:variable [ fhir:v "cls" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetAufenthaltStationaer" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "cls" ] ;
           fhir:element [ fhir:v "code" ] ;
           fhir:variable [ fhir:v "cd" ] ;
           fhir:condition [ fhir:v "$this = 'IMP'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "artAufenthaltSchluessel" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:String ;
               fhir:v "1"
             ]
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "SetAufenthaltTeilstationaer" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "cls" ] ;
           fhir:element [ fhir:v "code" ] ;
           fhir:variable [ fhir:v "cd" ] ;
           fhir:condition [ fhir:v "$this = 'SS'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "artAufenthaltSchluessel" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:String ;
               fhir:v "2"
             ]
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "SetAufenthaltAmbulant" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "cls" ] ;
           fhir:element [ fhir:v "code" ] ;
           fhir:variable [ fhir:v "cd" ] ;
           fhir:condition [ fhir:v "$this = 'AMB'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "artAufenthaltSchluessel" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:String ;
               fhir:v "3"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTransfernummer" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "identifier" ] ;
         fhir:variable [ fhir:v "id" ] ;
         fhir:condition [ fhir:v "system = 'http://fhir.de/sid/ird/transfernummer'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetTransfernummer" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "id" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "v" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "transfernummer" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "v"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetSatzErstellung" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "datumZeitSatzErstellung" ] ;
         fhir:transform [ fhir:v "evaluate" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "src"
           ]
         ] [
           fhir:value [
             a fhir:String ;
             fhir:v "now()"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapVersionsnummer" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "meta" ] ;
         fhir:variable [ fhir:v "meta" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetVersionsnummer" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "meta" ] ;
           fhir:element [ fhir:v "versionId" ] ;
           fhir:variable [ fhir:v "v" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "versionsnummer" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "v"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryAusloeser" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "AusloeserProcContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "MapAusloeserCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "procedure" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "code" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "MapAusloeserCoding" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "code" ] ;
               fhir:element [ fhir:v "coding" ] ;
               fhir:variable [ fhir:v "c" ] ;
               fhir:condition [ fhir:v "system = 'http://fhir.de/CodeSystem/bfarm/ops'" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "ausloeser" ] ;
               fhir:variable [ fhir:v "ausl" ]
             ] ) ;
             fhir:rule ( [
               fhir:name [ fhir:v "SetAusloeserOPS" ] ;
               fhir:source ( [
                 fhir:context [ fhir:v "c" ] ;
                 fhir:element [ fhir:v "code" ] ;
                 fhir:variable [ fhir:v "cd" ]
               ] ) ;
               fhir:target ( [
                 fhir:context [ fhir:v "ausl" ] ;
                 fhir:contextType [ fhir:v "variable" ] ;
                 fhir:element [ fhir:v "prozedurenSchluessel" ] ;
                 fhir:transform [ fhir:v "copy" ] ;
                 fhir:parameter ( [
                   fhir:value [
                     a fhir:Id ;
                     fhir:v "cd"
                   ]
                 ] )
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryPatient" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Patient)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapPatientenaufnahme" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "patient" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "patientenaufnahme" ] ;
           fhir:variable [ fhir:v "pat" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapPatientenaufnahme" ] ;
           fhir:variable ( [ fhir:v "patient" ] [ fhir:v "pat" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryOperation" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-operation') or $this.contains('senologie-brustop'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapOperation" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "operation" ] ;
           fhir:variable [ fhir:v "op" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapOperation" ] ;
           fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "op" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapEntlassung" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "entlassung" ] ;
         fhir:variable [ fhir:v "entl" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapEntlassung" ] ;
         fhir:variable ( [ fhir:v "src" ] [ fhir:v "entl" ] [ fhir:v "bundle" ] )
       ] )
     ] )
  ] ) . # 

