     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToIRegMeldung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToIRegMeldung>
  ] ; # 
