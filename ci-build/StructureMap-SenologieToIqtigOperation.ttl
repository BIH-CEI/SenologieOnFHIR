                 fhir:element [ fhir:v "code" ] ;
                 fhir:variable [ fhir:v "cd" ]
               ] ) ;
               fhir:target ( [
                 fhir:context [ fhir:v "kompItem" ] ;
                 fhir:contextType [ fhir:v "variable" ] ;
                 fhir:element [ fhir:v "icdCode" ] ;
                 fhir:transform [ fhir:v "copy" ] ;
                 fhir:parameter ( [
                   fhir:value [
                     a fhir:Id ;
                     fhir:v "cd"
                   ]
                 ] )
               ] )
             ] )
           ] )
         ] )
       ] )
     ] )
  ] ) . # 

