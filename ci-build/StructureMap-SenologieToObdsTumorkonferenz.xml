        <rule>
          <name value="ExtractOnkoTypCoding"/>
          <source>
            <context value="det"/>
            <element value="code"/>
            <variable value="code"/>
          </source>
          <rule>
            <name value="SetTypFromOnkoCS"/>
            <source>
              <context value="code"/>
              <element value="coding"/>
              <variable value="c"/>
              <condition value="system = 'https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/CodeSystem/mii-cs-onko-therapie-typ'"/>
            </source>
            <target>
              <context value="tgt"/>
              <contextType value="variable"/>
              <element value="typTherapieempfehlung"/>
