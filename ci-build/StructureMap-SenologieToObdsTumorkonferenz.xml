        </source>
        <rule>
          <name value="ExtractMedCode"/>
          <source>
            <context value="det"/>
            <element value="code"/>
            <variable value="code"/>
            <condition value="coding.exists()"/>
          </source>
          <rule>
            <name value="SetTypMedicationRequest"/>
            <source>
              <context value="code"/>
              <element value="coding"/>
              <variable value="c"/>
            </source>
            <target>
              <context value="tgt"/>
              <contextType value="variable"/>
              <element value="typTherapieempfehlung"/>
              <transform value="evaluate"/>
              <parameter>
                <valueString value="c.code"/>
              </parameter>
            </target>
          </rule>
        </rule>
      </rule>
    </rule>
    <rule>
      <name value="MapOnkoTypActivities"/>
      <source>
        <context value="src"/>
        <element value="activity"/>
        <variable value="act"/>
        <condition value="detail.exists()"/>
      </source>
      <rule>
        <name value="ExtractOnkoDetail"/>
        <source>
          <context value="act"/>
          <element value="detail"/>
          <variable value="det"/>
