            <element value="lokaleBeurteilung"/>
            <transform value="translate"/>
            <parameter>
              <valueId value="c"/>
            </parameter>
            <parameter>
              <valueString value="https://www.senologie.org/fhir/ConceptMap/cm-sct-to-obds-residualstatus"/>
            </parameter>
            <parameter>
              <valueString value="code"/>
            </parameter>
          </target>
        </rule>
      </rule>
    </rule>
