      <mode value="source"/>
    </input>
    <input>
      <name value="tgt"/>
      <type value="BackboneElement"/>
      <mode value="target"/>
    </input>
    <rule>
      <name value="MapLokaleBeurteilung"/>
      <source>
        <context value="src"/>
        <element value="component"/>
        <variable value="comp"/>
        <condition value="code.coding.exists(code = '84892-9')"/>
      </source>
      <rule>
