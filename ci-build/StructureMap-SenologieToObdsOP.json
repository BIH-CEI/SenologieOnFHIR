              "contextType" : "variable",
              "element" : "code",
              "transform" : "copy",
              "parameter" : [{
                "valueId" : "cd"
              }]
            }]
          },
          {
            "name" : "SetKompIcdVersion",
            "source" : [{
              "context" : "c",
              "element" : "version",
              "variable" : "v"
            }],
            "target" : [{
              "context" : "icd",
              "contextType" : "variable",
