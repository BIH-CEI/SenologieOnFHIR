  ] ) ; # 
  fhir:description [ fhir:v "title: Senologie ECOG Observation to oBDS Allgemeiner Leistungszustand\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Observation"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Observation>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Observation" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/obds-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/obds-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OBDSMeldung" ]
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "MapLeistungszustandFromBundle" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups use `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the Logical Model sub-path for BackboneElement\r\nslices passed from parent groups. The IG Publisher produces SM_TARGET_PATH\r\nerrors. The element names are correct per the oBDS Logical Model.\r\n============================================================================\r\nGemeinsame Leistungszustand-Map: Extrahiert den ECOG Performance Status\r\naus einer Observation und mappt auf das oBDS-Element allgemeinerLeistungszustand.\r\nWird von Diagnose und Verlauf importiert.\r\nMII Onko Profil: mii-pr-onko-allgemeiner-leistungszustand-ecog\r\nLOINC 89247-1 = \"ECOG Performance Status\"\r\nECOG-Score: 0-4 (direkte Uebernahme), U = unbekannt\r\nDie MII Onko Observation codiert den ECOG-Score als valueCodeableConcept\r\nmit dem Karnofsky/ECOG-CodeSystem.\r\n============================================================================\r\n============================================================================\r\nMapLeistungszustandFromBundle: Bundle -> allgemeinerLeistungszustand\r\nSucht die ECOG-Observation im Bundle und extrahiert den Score\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntryECOG" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "ecogEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '89247-1')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapLeistungszustand" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "ecogEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "ecogObs" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapLeistungszustand" ] ;
           fhir:variable ( [ fhir:v "ecogObs" ] [ fhir:v "tgt" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapLeistungszustand" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nMapLeistungszustand: Observation -> allgemeinerLeistungszustand (code)\r\nExtrahiert den ECOG-Score (0-4) aus der Observation\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Observation" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapECOGValue" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "value" ] ;
         fhir:variable [ fhir:v "v" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "ExtractECOGCode" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "v" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetECOG" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "allgemeinerLeistungszustand" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "cd"
               ]
             ] )
           ] )
         ] )
       ] )
     ] )
  ] ) . # 

