         fhir:condition [ fhir:v "url = 'https://www.senologie.org/fhir/StructureDefinition/ex-senologie-first-line-therapy'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetFirstLineJa" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "ext" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ] ;
           fhir:condition [ fhir:v "$this = true" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "firstLine" ] ;
