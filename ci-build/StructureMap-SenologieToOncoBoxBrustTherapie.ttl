           fhir:parameter ( [
             fhir:value [
               a fhir:String ;
               fhir:v "1"
             ]
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "SetFirstLineNein" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "ext" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ] ;
           fhir:condition [ fhir:v "$this = false" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "firstLine" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:String ;
               fhir:v "0"
             ]
           ] )
         ] )
