             fhir:condition [ fhir:v "code = 'palliativ'" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "stellungZurOP" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "P"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapSystPeriod" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "performed" ] ;
         fhir:variable [ fhir:v "perf" ] ;
         fhir:condition [ fhir:v "$this.is(Period)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetSystBeginn" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "perf" ] ;
           fhir:element [ fhir:v "start" ] ;
           fhir:variable [ fhir:v "s" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "beginn" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "s"
             ]
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "SetSystEnde" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "perf" ] ;
           fhir:element [ fhir:v "end" ] ;
           fhir:variable [ fhir:v "e" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "ende" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "e"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTrastu" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "code" ] ;
         fhir:variable [ fhir:v "code" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapTrastuCoding" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "code" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'http://snomed.info/sct'" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetTrastuJa" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this = '387208009'" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "enthaeltTrastuzumab" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "1"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapFirstLine" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "extension" ] ;
