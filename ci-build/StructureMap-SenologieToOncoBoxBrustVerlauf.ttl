<https://www.senologie.org/fhir/StructureMap/SenologieToOncoBoxBrustVerlauf> a fhir:StructureMap ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "SenologieToOncoBoxBrustVerlauf"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToOncoBoxBrustVerlauf</b></p><a name=\"SenologieToOncoBoxBrustVerlauf\"> </a><a name=\"hcSenologieToOncoBoxBrustVerlauf\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToOncoBoxBrustVerlauf<span style=\"color: navy\">\" = \"</span>SenologieToOncoBoxBrustVerlauf<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie Bundle to OncoBox Brust Verlauf (inkl. OncoBox 2.0 FM-Felder J03-J05)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/condition.html\" title=\"Condition\">http://hl7.org/fhir/StructureDefinition/Condition</a><span style=\"color: navy\">\" </span><b>alias </b>Condition <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/observation.html\" title=\"Observation\">http://hl7.org/fhir/StructureDefinition/Observation</a><span style=\"color: navy\">\" </span><b>alias </b>Observation <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/procedure.html\" title=\"Procedure\">http://hl7.org/fhir/StructureDefinition/Procedure</a><span style=\"color: navy\">\" </span><b>alias </b>Procedure <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-oncobox-brust-meldung.html\" title=\"OncoBox Brust N1.1.1 Meldung (Logical Model)\">https://www.senologie.org/fhir/StructureDefinition/oncobox-brust-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>OncoBoxBrust <b>as </b><b>target</b>#xD;\n#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Known limitation: Sub-groups use `target tgt : BackboneElement` because FML</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">has no syntax to declare the Logical Model sub-path for BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">slices passed from parent groups. The IG Publisher may produce SM_TARGET_PATH</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">errors. The element names are correct per the OncoBox Brust Logical Model.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapVerlaufFromBundle: Bundle -&gt; OncoBox Primaerfall.verlauf (repeating)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Extrahiert Verlaufsereignisse aus dem Bundle und mappt auf den OncoBox-</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Verlauf-Block. Drei Quellen fuer Verlaufseintraege:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">1. Senologie_FollowUp Observations (SCT 396432002) -&gt; M01-M10 + Gesamtbeurteilung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Bildet die vollstaendige Verlaufsmeldung ab inkl. Nachsorge-Art, Vitalstatus,</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Tumorstatus lokal/LK/FM und Zweittumor. Gesamtbeurteilung (D27) wird auf</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">verlauf.ereignis gemappt: P-&gt;6 (Progress), Y-&gt;1 (Lokalrezidiv Default).</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">2. Condition mit clinicalStatus=recurrence -&gt; Rezidiv / Fernmetastase</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">3. Observation LOINC 21907-1 (Distant metastases.clinical) -&gt; Fernmetastase</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Fuer Fernmetastasen-Ereignisse (ereignis=3) werden zusaetzlich die</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">OncoBox 2.0 Felder J03-J05 befuellt:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">J03: FM_OP_Datum       -&gt; aus Procedure (Operation) mit FM-reasonReference</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">J04: FM_Therapien      -&gt; Existenz-Check fuer OP/Syst/ST/Endo im Bundle</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">J05: FM_Residualstatus -&gt; aus Procedure.outcome (Operation)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapVerlaufFromBundle<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Bundle, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Senologie_FollowUp Observations -&gt; Verlauf M01-M10 + Gesamtbeurteilung ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">SCT 396432002 = \"Status of regression of tumor\"</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">fuEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '396432002')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    fuEntry.resource<b> as </b><span style=\"color: maroon\">fuObs</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.verlauf<b> as </b><span style=\"color: maroon\">verl</span><b> then </b>MapVerlaufFollowUp<span style=\"color: navy\">(</span><span style=\"color: maroon\">fuObs</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">verl</span><span style=\"color: navy\">)</span> <i>\"CallMapVerlaufFU\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryVerlaufFU\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Fernmetastasen-Observations -&gt; Verlauf mit ereignis=3 ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">LOINC 21907-1 = \"Distant metastases.clinical Cancer\"</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">fmEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '21907-1')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    fmEntry.resource<b> as </b><span style=\"color: maroon\">fmObs</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.verlauf<b> as </b><span style=\"color: maroon\">verl</span><b> then </b>MapVerlaufFernmetastase<span style=\"color: navy\">(</span><span style=\"color: maroon\">fmObs</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">verl</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">src</span><span style=\"color: navy\">)</span> <i>\"CallMapVerlaufFM\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryVerlaufFM\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Conditions mit recurrence -&gt; Verlauf (Lokalrezidiv, Regionaerrezidiv, etc.) ---</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">recEntry</span><b> where </b>resource.is(Condition) and resource.clinicalStatus.coding.exists(code = 'recurrence')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    recEntry.resource<b> as </b><span style=\"color: maroon\">recCond</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.verlauf<b> as </b><span style=\"color: maroon\">verl</span><b> then </b>MapVerlaufRezidiv<span style=\"color: navy\">(</span><span style=\"color: maroon\">recCond</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">verl</span><span style=\"color: navy\">)</span> <i>\"CallMapVerlaufRez\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryVerlaufRez\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapVerlaufFollowUp: Observation (Senologie_FollowUp) -&gt; Verlauf M01-M10</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Bildet eine Senologie_FollowUp Observation (SCT 396432002) auf den</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">vollstaendigen OncoBox-Verlauf-Block ab:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M01: Meldedatum       &lt;- effectiveDateTime</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M02: Melder           &lt;- performer.display</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M03: Nachsorge-Art    &lt;- component[nachsorge-art]</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M04: Vitalstatus      &lt;- component[vitalstatus]</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M05: Tumorstatus lok. &lt;- component[Tumor_Verlauf] (SCT 445200009)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M06: Tumorstatus LK   &lt;- component[Lymphknoten_Verlauf] (SCT 399656008)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M07: Tumorstatus FM   &lt;- component[Fernmetastasen_Verlauf] (SCT 399608002)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M08: Zweittumor       &lt;- component[zweittumor]</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M09: Zweittumor ICD   &lt;- component[zweittumor-icd]</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">M10: Zweittumor Datum &lt;- component[zweittumor-datum]</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Ereignis              &lt;- Gesamtbeurteilung (valueCodeableConcept):</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">P-&gt;6 (Progress), Y-&gt;1 (Lokalrezidiv Default)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapVerlaufFollowUp<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Observation, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">M01: Meldedatum</span>#xD;\n  src.effective<b> as </b><span style=\"color: maroon\">eff</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.meldedatum = <span style=\"color: maroon\">eff</span> <i>\"SetM01Datum\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M02: Melder (Performer-Name als String)</span>#xD;\n  src.performer<b> as </b><span style=\"color: maroon\">perf</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    perf.display<b> as </b><span style=\"color: maroon\">d</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.melder = <span style=\"color: maroon\">d</span> <i>\"SetM02Melder\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM02Perf\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M03: Art der Nachsorge (aus Component mit Code nachsorge-art)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = 'nachsorge-art')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = 'aktiv'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.nachsorgeArt = <span style=\"color: blue\">'aktiv'</span> <i>\"SetM03Aktiv\"</i><span style=\"color: navy\">;</span>#xD;\n        c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = 'passiv'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.nachsorgeArt = <span style=\"color: blue\">'passiv'</span> <i>\"SetM03Passiv\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapM03Coding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapM03Val\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM03\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M04: Vitalstatus (SCT 438949009=lebend, 419099009=verstorben, 261665006=unbekannt)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = 'vitalstatus')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '438949009'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.vitalstatus = <span style=\"color: blue\">'lebend'</span> <i>\"SetM04Lebend\"</i><span style=\"color: navy\">;</span>#xD;\n        c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '419099009'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.vitalstatus = <span style=\"color: blue\">'verstorben'</span> <i>\"SetM04Verstorben\"</i><span style=\"color: navy\">;</span>#xD;\n        c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '261665006'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.vitalstatus = <span style=\"color: blue\">'unbekannt'</span> <i>\"SetM04Unbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapM04Coding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapM04Val\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM04\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M05: Lokaler Tumorstatus (SCT 445200009 = Status of residual neoplasm)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '445200009')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system.contains('verlauf-primaertumor')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorstatusLokal = <span style=\"color: maroon\">cd</span> <i>\"SetM05\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapM05Coding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapM05Val\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM05\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M06: Lymphknoten-Tumorstatus (SCT 399656008)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '399656008')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system.contains('verlauf-lymphknoten')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorstatusLK = <span style=\"color: maroon\">cd</span> <i>\"SetM06\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapM06Coding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapM06Val\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM06\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M07: Fernmetastasen-Tumorstatus (SCT 399608002)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '399608002')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system.contains('verlauf-fernmetastasen')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorstatusFM = <span style=\"color: maroon\">cd</span> <i>\"SetM07\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapM07Coding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapM07Val\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM07\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M08: Zweittumor (SCT 373066001=ja, 373067005=nein, 261665006=unbekannt)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = 'zweittumor')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '373066001'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.zweittumor = <span style=\"color: blue\">'ja'</span> <i>\"SetM08Ja\"</i><span style=\"color: navy\">;</span>#xD;\n        c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '373067005'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.zweittumor = <span style=\"color: blue\">'nein'</span> <i>\"SetM08Nein\"</i><span style=\"color: navy\">;</span>#xD;\n        c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '261665006'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.zweittumor = <span style=\"color: blue\">'unbekannt'</span> <i>\"SetM08Unbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapM08Coding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapM08Val\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM08\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M09: Zweittumor ICD-10-GM</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = 'zweittumor-icd')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'http://fhir.de/CodeSystem/bfarm/icd-10-gm'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.zweitttumorIcd = <span style=\"color: maroon\">cd</span> <i>\"SetM09\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapM09Coding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapM09Val\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM09\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">M10: Zweittumor Diagnosedatum</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = 'zweittumor-datum')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.zweitttumorDatum = <span style=\"color: maroon\">val</span> <i>\"SetM10\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapM10\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Gesamtbeurteilung -&gt; Verlauf_Ereignis</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ConceptMap: V/T/K/B/R -&gt; kein Ereignis (stabil); P -&gt; 6; Y -&gt; 1</span>#xD;\n  src.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system.contains('verlauf-gesamtbeurteilung')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">P = Progression -&gt; 6 (Progress)</span>#xD;\n      c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = 'P'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.ereignis = <span style=\"color: blue\">'6'</span> <i>\"SetEreignisProgress\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">Y = Rezidiv -&gt; 1 (Lokalrezidiv als Default)</span>#xD;\n      c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = 'Y'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.ereignis = <span style=\"color: blue\">'1'</span> <i>\"SetEreignisRezidiv\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapGesamtCoding\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapGesamt\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapVerlaufFernmetastase: Observation (FM) -&gt; Verlauf + OncoBox 2.0 J03-J05</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Bildet eine Fernmetastasen-Observation auf den OncoBox-Verlauf-Block ab.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Zusaetzlich werden FM-spezifische Therapie-Procedures aus dem Bundle</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">extrahiert fuer die OncoBox 2.0 Felder.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">FM-spezifische Procedures werden identifiziert ueber:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- meta.profile enthält das jeweilige Senologie-Profil</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- extension:Intention mit code 'P' (palliativ) als FM-Kontextindikator</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapVerlaufFernmetastase<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Observation, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement, <b>source</b> <span style=\"color: maroon\">bundle</span><span style=\"color: navy\"> : </span>Bundle<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Verlauf_Datum: aus Observation.effectiveDateTime</span>#xD;\n  src.effective<b> as </b><span style=\"color: maroon\">eff</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.datum = <span style=\"color: maroon\">eff</span> <i>\"SetVerlaufDatumFM\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Verlauf_Ereignis: 3 = Fernmetastase</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.ereignis = <span style=\"color: blue\">'3'</span> <i>\"SetEreignisFM\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">=== OncoBox 2.0: J03 — FM_OP_Datum ===</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Operationsdatum bei Fernmetastasen: aus Procedure (Operation) mit</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">palliativer Intention im selben Bundle</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">opEntry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-operation') or $this.contains('senologie-brustop'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    opEntry.resource<b> as </b><span style=\"color: maroon\">proc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      proc.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url.contains('Intention')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'P'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>            proc.performed<b> as </b><span style=\"color: maroon\">perf</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.fmOpDatum = <span style=\"color: maroon\">perf</span> <i>\"SetFMOpDatum\"</i><span style=\"color: navy\">;</span>#xD;\n          <span style=\"color: navy\">}</span> <i>\"CheckIntentionPalliativ\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"MapIntentionValue\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapIntentionExt\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapFMOpProc\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryFMOp\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">=== OncoBox 2.0: J04 — FM_Therapien ===</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.fmTherapien<b> as </b><span style=\"color: maroon\">fmTh</span><b> then </b>MapFMTherapien<span style=\"color: navy\">(</span><span style=\"color: maroon\">bundle</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">fmTh</span><span style=\"color: navy\">)</span> <i>\"CallMapFMTherapien\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">=== OncoBox 2.0: J05 — FM_Residualstatus ===</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Aus Procedure.outcome der FM-Operation (palliativer Kontext)</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">opEntry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-operation') or $this.contains('senologie-brustop'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    opEntry.resource<b> as </b><span style=\"color: maroon\">proc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      proc.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url.contains('Intention')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'P'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>            proc.outcome<b> as </b><span style=\"color: maroon\">oc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>              oc.coding<b> as </b><span style=\"color: maroon\">rc</span><b> where </b>system.contains('residualstatus')<span style=\"color: navy\"><b> -&gt; </b></span>tgt.fmResidualstatus = <span style=\"color: maroon\">rc</span> <i>\"SetFMResidualCode\"</i><span style=\"color: navy\">;</span>#xD;\n            <span style=\"color: navy\">}</span> <i>\"MapFMResidualCoding\"</i><span style=\"color: navy\">;</span>#xD;\n          <span style=\"color: navy\">}</span> <i>\"CheckIntentionPalliativR\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"MapIntentionValueR\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapIntentionExtR\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapFMResidualProc\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryFMResidual\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapFMTherapien: Bundle -&gt; FM_Therapien (J04)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Prueft fuer jede Therapieart ob eine Procedure mit palliativer Intention</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">im Bundle vorhanden ist und setzt entsprechend 0/1.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapFMTherapien<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Bundle, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Operation bei FM</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-operation') or $this.contains('senologie-brustop'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">proc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      proc.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url.contains('Intention')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'P'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.operation = <span style=\"color: blue\">'1'</span> <i>\"SetFMThOP\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"CheckIntentionPalliativOP\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapIntentionExtOP\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapFMThOPProc\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryFMThOP\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Systemtherapie bei FM</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-systemtherapie'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">proc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      proc.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url.contains('Intention')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'P'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.systemtherapie = <span style=\"color: blue\">'1'</span> <i>\"SetFMThSyst\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"CheckIntentionPalliativSyst\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapIntentionExtSyst\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapFMThSystProc\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryFMThSyst\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Strahlentherapie bei FM</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-strahlentherapie'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">proc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      proc.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url.contains('Intention')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'P'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.strahlentherapie = <span style=\"color: blue\">'1'</span> <i>\"SetFMThST\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"CheckIntentionPalliativST\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapIntentionExtST\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapFMThSTProc\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryFMThST\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Endokrine Therapie bei FM (Senologie Systemtherapie mit endocrine type)</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Endokrine Therapie wird als Systemtherapie mit spezifischem Code erfasst</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-systemtherapie'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">proc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      proc.code<b> as </b><span style=\"color: maroon\">code</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        code.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '169413002'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>          proc.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url.contains('Intention')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>            ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>              val.coding<b> as </b><span style=\"color: maroon\">ic</span><b> where </b>code = 'P'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.endokrineTherapie = <span style=\"color: blue\">'1'</span> <i>\"SetFMThEndo\"</i><span style=\"color: navy\">;</span>#xD;\n            <span style=\"color: navy\">}</span> <i>\"CheckIntentionPalliativEndo\"</i><span style=\"color: navy\">;</span>#xD;\n          <span style=\"color: navy\">}</span> <i>\"MapIntentionExtEndo\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"CheckEndocrineCode\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapEndocrineCodeCtx\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapFMThEndoProc\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryFMThEndo\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapVerlaufRezidiv: Condition (Rezidiv) -&gt; Verlauf (Nicht-FM-Ereignis)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Mappt Rezidiv-Conditions auf den OncoBox-Verlauf-Block fuer Lokalrezidive,</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Regionaerrezidive und andere Verlaufsereignisse.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">FM-spezifische Felder J03-J05 werden hier NICHT befuellt.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapVerlaufRezidiv<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Condition, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Verlauf_Datum: aus Condition.recordedDate oder extension Feststellungsdatum</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-ex-onko-feststellungsdatum'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.datum = <span style=\"color: maroon\">val</span> <i>\"SetVerlaufDatumExt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapVerlaufDatumExt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Fallback: recordedDate</span>#xD;\n  src.recordedDate<b> as </b><span style=\"color: maroon\">rd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.datum = <span style=\"color: maroon\">rd</span> <i>\"SetVerlaufDatumFallback\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Verlauf_Ereignis: aus Condition.code oder stage</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Mapping: Lokalrezidiv=1, Regionaerrezidiv=2, kontralateral=4, Zweitmalignom=5, Progress=6</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">(Fernmetastase=3 wird ueber MapVerlaufFernmetastase abgedeckt)</span>#xD;\n  src.code<b> as </b><span style=\"color: maroon\">code</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    code.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'http://snomed.info/sct'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">255226008 = Local recurrence of tumor</span>#xD;\n      c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '255226008'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.ereignis = <span style=\"color: blue\">'1'</span> <i>\"SetEreignisLokal\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">315266007 = Regional recurrence</span>#xD;\n      c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '315266007'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.ereignis = <span style=\"color: blue\">'2'</span> <i>\"SetEreignisRegional\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">94222008 = Contralateral breast cancer (Secondary malignant neoplasm of contralateral breast)</span>#xD;\n      c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '94222008'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.ereignis = <span style=\"color: blue\">'4'</span> <i>\"SetEreignisKontralateral\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapEreignisSCT\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapEreignis\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:url [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToOncoBoxBrustVerlauf"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToOncoBoxBrustVerlauf>
  ] ; # 
  fhir:version [ fhir:v "0.1.0"] ; # 
  fhir:name [ fhir:v "SenologieToOncoBoxBrustVerlauf"] ; # 
  fhir:status [ fhir:v "draft"] ; # 
  fhir:date [ fhir:v "2026-05-04T07:50:36+00:00"^^xsd:dateTime] ; # 
  fhir:publisher [ fhir:v "Berlin Institute of Health at Charité (BIH)"] ; # 
  fhir:contact ( [
     fhir:name [ fhir:v "Berlin Institute of Health at Charité (BIH)" ] ;
     fhir:telecom ( [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://www.bihealth.org" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "title: Senologie Bundle to OncoBox Brust Verlauf (inkl. OncoBox 2.0 FM-Felder J03-J05)\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Condition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Condition>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Condition" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Observation"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Observation>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Observation" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Procedure"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Procedure>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Procedure" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/oncobox-brust-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/oncobox-brust-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OncoBoxBrust" ]
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "MapVerlaufFromBundle" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups use `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the Logical Model sub-path for BackboneElement\r\nslices passed from parent groups. The IG Publisher may produce SM_TARGET_PATH\r\nerrors. The element names are correct per the OncoBox Brust Logical Model.\r\n============================================================================\r\nMapVerlaufFromBundle: Bundle -> OncoBox Primaerfall.verlauf (repeating)\r\nExtrahiert Verlaufsereignisse aus dem Bundle und mappt auf den OncoBox-\r\nVerlauf-Block. Drei Quellen fuer Verlaufseintraege:\r\n1. Senologie_FollowUp Observations (SCT 396432002) -> M01-M10 + Gesamtbeurteilung\r\nBildet die vollstaendige Verlaufsmeldung ab inkl. Nachsorge-Art, Vitalstatus,\r\nTumorstatus lokal/LK/FM und Zweittumor. Gesamtbeurteilung (D27) wird auf\r\nverlauf.ereignis gemappt: P->6 (Progress), Y->1 (Lokalrezidiv Default).\r\n2. Condition mit clinicalStatus=recurrence -> Rezidiv / Fernmetastase\r\n3. Observation LOINC 21907-1 (Distant metastases.clinical) -> Fernmetastase\r\nFuer Fernmetastasen-Ereignisse (ereignis=3) werden zusaetzlich die\r\nOncoBox 2.0 Felder J03-J05 befuellt:\r\nJ03: FM_OP_Datum       -> aus Procedure (Operation) mit FM-reasonReference\r\nJ04: FM_Therapien      -> Existenz-Check fuer OP/Syst/ST/Endo im Bundle\r\nJ05: FM_Residualstatus -> aus Procedure.outcome (Operation)\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntryVerlaufFU" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "fuEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '396432002')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapVerlaufFU" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "fuEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "fuObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "verlauf" ] ;
           fhir:variable [ fhir:v "verl" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapVerlaufFollowUp" ] ;
           fhir:variable ( [ fhir:v "fuObs" ] [ fhir:v "verl" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryVerlaufFM" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "fmEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '21907-1')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapVerlaufFM" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "fmEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "fmObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "verlauf" ] ;
           fhir:variable [ fhir:v "verl" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapVerlaufFernmetastase" ] ;
           fhir:variable ( [ fhir:v "fmObs" ] [ fhir:v "verl" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryVerlaufRez" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "recEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition) and resource.clinicalStatus.coding.exists(code = 'recurrence')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapVerlaufRez" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "recEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "recCond" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "verlauf" ] ;
           fhir:variable [ fhir:v "verl" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapVerlaufRezidiv" ] ;
           fhir:variable ( [ fhir:v "recCond" ] [ fhir:v "verl" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapVerlaufFollowUp" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nMapVerlaufFollowUp: Observation (Senologie_FollowUp) -> Verlauf M01-M10\r\nBildet eine Senologie_FollowUp Observation (SCT 396432002) auf den\r\nvollstaendigen OncoBox-Verlauf-Block ab:\r\nM01: Meldedatum       <- effectiveDateTime\r\nM02: Melder           <- performer.display\r\nM03: Nachsorge-Art    <- component[nachsorge-art]\r\nM04: Vitalstatus      <- component[vitalstatus]\r\nM05: Tumorstatus lok. <- component[Tumor_Verlauf] (SCT 445200009)\r\nM06: Tumorstatus LK   <- component[Lymphknoten_Verlauf] (SCT 399656008)\r\nM07: Tumorstatus FM   <- component[Fernmetastasen_Verlauf] (SCT 399608002)\r\nM08: Zweittumor       <- component[zweittumor]\r\nM09: Zweittumor ICD   <- component[zweittumor-icd]\r\nM10: Zweittumor Datum <- component[zweittumor-datum]\r\nEreignis              <- Gesamtbeurteilung (valueCodeableConcept):\r\nP->6 (Progress), Y->1 (Lokalrezidiv Default)\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Observation" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "SetM01Datum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "effective" ] ;
         fhir:variable [ fhir:v "eff" ] ;
         fhir:condition [ fhir:v "$this.is(dateTime)" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "meldedatum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "eff"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapM02Perf" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "performer" ] ;
         fhir:variable [ fhir:v "perf" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetM02Melder" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "perf" ] ;
           fhir:element [ fhir:v "display" ] ;
           fhir:variable [ fhir:v "d" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "melder" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "d"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapM03" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "component" ] ;
         fhir:variable [ fhir:v "comp" ] ;
         fhir:condition [ fhir:v "code.coding.exists(code = 'nachsorge-art')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapM03Val" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "comp" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "MapM03Coding" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetM03Aktiv" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ] ;
               fhir:condition [ fhir:v "$this = 'aktiv'" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "nachsorgeArt" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:String ;
                   fhir:v "aktiv"
                 ]
               ] )
             ] )
           ] [
             fhir:name [ fhir:v "SetM03Passiv" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ] ;
               fhir:condition [ fhir:v "$this = 'passiv'" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
