  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "MapEntlassung" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups use `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the specific Logical Model sub-path when a parent\r\ngroup passes a BackboneElement slice (e.g., `tgt.entlassung as entl then ...`).\r\nThe IG Publisher resolves target paths against BackboneElement, producing\r\nSM_TARGET_PATH / SM_SOURCE_PATH errors. The element names are correct and\r\nmatch the IRegG Brustimplantat Logical Model. These errors are cosmetic.\r\n============================================================================\r\nEntlassung: Encounter + Condition -> ENT_* + DBI_*\r\nEntlassungsdaten und Brustimplantat-spezifische Entlassungsdiagnosen.\r\nENT_Datum kommt aus Encounter.period.end.\r\nENT_GrundSchluessel kommt aus Encounter.hospitalization.dischargeDisposition.\r\nDBI_* Diagnosen kommen aus Condition-Ressourcen im Bundle (ICD-10-GM).\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Encounter" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapEntlassungsDatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "period" ] ;
         fhir:variable [ fhir:v "period" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetEntlassungsDatum" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "period" ] ;
           fhir:element [ fhir:v "end" ] ;
           fhir:variable [ fhir:v "e" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "datum" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "e"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapHospitalization" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "hospitalization" ] ;
         fhir:variable [ fhir:v "hosp" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapDischargeDisposition" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "hosp" ] ;
           fhir:element [ fhir:v "dischargeDisposition" ] ;
           fhir:variable [ fhir:v "dd" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "MapEntlassungsgrundCoding" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "dd" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ] ;
             fhir:condition [ fhir:v "system = 'http://fhir.de/CodeSystem/dkgev/Entlassungsgrund'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetEntlassungsgrund" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "grundSchluessel" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "MapEntlassungsgrundFallbackCoding" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "dd" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ] ;
             fhir:condition [ fhir:v "system != 'http://fhir.de/CodeSystem/dkgev/Entlassungsgrund'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetEntlassungsgrundFallback" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "grundSchluessel" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryDbiCondition" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "DbiConditionContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "MapDbiCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "condition" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "code" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "MapDbiIcd" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "code" ] ;
               fhir:element [ fhir:v "coding" ] ;
               fhir:variable [ fhir:v "c" ] ;
               fhir:condition [ fhir:v "system = 'http://fhir.de/CodeSystem/bfarm/icd-10-gm'" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "diagnoseBrustimplantat" ] ;
               fhir:variable [ fhir:v "dbi" ]
             ] ) ;
             fhir:rule ( [
               fhir:name [ fhir:v "SetDbiIcdCode" ] ;
               fhir:source ( [
                 fhir:context [ fhir:v "c" ] ;
                 fhir:element [ fhir:v "code" ] ;
                 fhir:variable [ fhir:v "cd" ]
               ] ) ;
               fhir:target ( [
                 fhir:context [ fhir:v "dbi" ] ;
                 fhir:contextType [ fhir:v "variable" ] ;
                 fhir:element [ fhir:v "icdSchluessel" ] ;
                 fhir:transform [ fhir:v "copy" ] ;
                 fhir:parameter ( [
                   fhir:value [
                     a fhir:Id ;
                     fhir:v "cd"
                   ]
                 ] )
               ] )
             ] [
               fhir:name [ fhir:v "MapDbiSeite" ] ;
               fhir:source ( [
                 fhir:context [ fhir:v "condition" ] ;
                 fhir:element [ fhir:v "bodySite" ] ;
                 fhir:variable [ fhir:v "bs" ]
               ] ) ;
               fhir:rule ( [
                 fhir:name [ fhir:v "MapDbiSeiteSCT" ] ;
                 fhir:source ( [
                   fhir:context [ fhir:v "bs" ] ;
                   fhir:element [ fhir:v "coding" ] ;
                   fhir:variable [ fhir:v "bsc" ] ;
                   fhir:condition [ fhir:v "system = 'http://snomed.info/sct'" ]
                 ] ) ;
                 fhir:rule ( [
                   fhir:name [ fhir:v "AppendSeiteRechts" ] ;
                   fhir:source ( [
                     fhir:context [ fhir:v "bsc" ] ;
                     fhir:element [ fhir:v "code" ] ;
                     fhir:variable [ fhir:v "bscd" ] ;
                     fhir:condition [ fhir:v "$this = '24028007'" ]
                   ] ) ;
                   fhir:target ( [
                     fhir:context [ fhir:v "dbi" ] ;
                     fhir:contextType [ fhir:v "variable" ] ;
                     fhir:element [ fhir:v "icdSchluessel" ] ;
                     fhir:transform [ fhir:v "append" ] ;
                     fhir:parameter ( [
                       fhir:value [
                         a fhir:Id ;
                         fhir:v "cd"
                       ]
                     ] [
                       fhir:value [
                         a fhir:String ;
                         fhir:v ":R"
                       ]
                     ] )
                   ] )
                 ] [
                   fhir:name [ fhir:v "AppendSeiteLinks" ] ;
                   fhir:source ( [
                     fhir:context [ fhir:v "bsc" ] ;
                     fhir:element [ fhir:v "code" ] ;
                     fhir:variable [ fhir:v "bscd" ] ;
                     fhir:condition [ fhir:v "$this = '7771000'" ]
