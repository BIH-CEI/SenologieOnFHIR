<https://www.senologie.org/fhir/StructureMap/SenologieToIRegEntlassung> a fhir:StructureMap ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "SenologieToIRegEntlassung"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToIRegEntlassung</b></p><a name=\"SenologieToIRegEntlassung\"> </a><a name=\"hcSenologieToIRegEntlassung\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToIRegEntlassung<span style=\"color: navy\">\" = \"</span>SenologieToIRegEntlassung<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie Encounter + Condition to IRegG Entlassung + DiagnoseBrustimplantat</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/encounter.html\" title=\"Encounter\">http://hl7.org/fhir/StructureDefinition/Encounter</a><span style=\"color: navy\">\" </span><b>alias </b>Encounter <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/condition.html\" title=\"Condition\">http://hl7.org/fhir/StructureDefinition/Condition</a><span style=\"color: navy\">\" </span><b>alias </b>Condition <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-ireg-brustimplantat-meldung.html\" title=\"IRegG Brustimplantat Meldung (Logical Model)\">https://www.senologie.org/fhir/StructureDefinition/ireg-brustimplantat-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>IRegMeldung <b>as </b><b>target</b>#xD;\n#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Known limitation: Sub-groups use `target tgt : BackboneElement` because FML</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">has no syntax to declare the specific Logical Model sub-path when a parent</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">group passes a BackboneElement slice (e.g., `tgt.entlassung as entl then ...`).</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">The IG Publisher resolves target paths against BackboneElement, producing</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">SM_TARGET_PATH / SM_SOURCE_PATH errors. The element names are correct and</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">match the IRegG Brustimplantat Logical Model. These errors are cosmetic.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Entlassung: Encounter + Condition -&gt; ENT_* + DBI_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Entlassungsdaten und Brustimplantat-spezifische Entlassungsdiagnosen.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">ENT_Datum kommt aus Encounter.period.end.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">ENT_GrundSchluessel kommt aus Encounter.hospitalization.dischargeDisposition.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">DBI_* Diagnosen kommen aus Condition-Ressourcen im Bundle (ICD-10-GM).</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapEntlassung<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Encounter, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement, <b>source</b> <span style=\"color: maroon\">bundle</span><span style=\"color: navy\"> : </span>Bundle<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">--- ENT_* Entlassungsdaten ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ENT_Datum: aus Encounter.period.end (Entlassungsdatum)</span>#xD;\n  src.period<b> as </b><span style=\"color: maroon\">period</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    period.end<b> as </b><span style=\"color: maroon\">e</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.datum = <span style=\"color: maroon\">e</span> <i>\"SetEntlassungsDatum\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapEntlassungsDatum\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ENT_GrundSchluessel: aus Encounter.hospitalization.dischargeDisposition</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">2-stelliger Entlassungs-/Verlegungsgrund nach §301 SGB V</span>#xD;\n  src.hospitalization<b> as </b><span style=\"color: maroon\">hosp</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    hosp.dischargeDisposition<b> as </b><span style=\"color: maroon\">dd</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      dd.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'http://fhir.de/CodeSystem/dkgev/Entlassungsgrund'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.grundSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetEntlassungsgrund\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapEntlassungsgrundCoding\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">Fallback: beliebiges Coding</span>#xD;\n      dd.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system != 'http://fhir.de/CodeSystem/dkgev/Entlassungsgrund'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.grundSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetEntlassungsgrundFallback\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapEntlassungsgrundFallbackCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapDischargeDisposition\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapHospitalization\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- DBI_* Brustimplantat-spezifische Entlassungsdiagnosen ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Alle Condition-Ressourcen im Bundle mit ICD-10-GM-Kodierung</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Condition)<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">condition</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      condition.code<b> as </b><span style=\"color: maroon\">code</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        code.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'http://fhir.de/CodeSystem/bfarm/icd-10-gm'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.diagnoseBrustimplantat<b> as </b><span style=\"color: maroon\">dbi</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          <span style=\"color: navy\">// </span><span style=\"color: green\">DBI_IcdSchluessel: ICD-10-GM Kode mit optionaler Seitenlokalisation</span>#xD;\n          c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>dbi.icdSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetDbiIcdCode\"</i><span style=\"color: navy\">;</span>#xD;\n          <span style=\"color: navy\">// </span><span style=\"color: green\">Seitenlokalisation an ICD-Code anhaengen falls vorhanden</span>#xD;\n          <span style=\"color: navy\">// </span><span style=\"color: green\">Format: Z99.9:R (rechts), Z99.9:L (links), Z99.9:B (beidseits)</span>#xD;\n          condition.bodySite<b> as </b><span style=\"color: maroon\">bs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>            bs.coding<b> as </b><span style=\"color: maroon\">bsc</span><b> where </b>system = 'http://snomed.info/sct'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>              bsc.code<b> as </b><span style=\"color: maroon\">bscd</span><b> where </b>$this = '24028007'<span style=\"color: navy\"><b> -&gt; </b></span>dbi.icdSchluessel = <b>append</b><span style=\"color: navy\">(</span><span style=\"color: maroon\">cd</span><span style=\"color: navy\">, </span><span style=\"color: blue\">':R'</span><span style=\"color: navy\">)</span> <i>\"AppendSeiteRechts\"</i><span style=\"color: navy\">;</span>#xD;\n              bsc.code<b> as </b><span style=\"color: maroon\">bscd</span><b> where </b>$this = '7771000'<span style=\"color: navy\"><b> -&gt; </b></span>dbi.icdSchluessel = <b>append</b><span style=\"color: navy\">(</span><span style=\"color: maroon\">cd</span><span style=\"color: navy\">, </span><span style=\"color: blue\">':L'</span><span style=\"color: navy\">)</span> <i>\"AppendSeiteLinks\"</i><span style=\"color: navy\">;</span>#xD;\n              bsc.code<b> as </b><span style=\"color: maroon\">bscd</span><b> where </b>$this = '51440002'<span style=\"color: navy\"><b> -&gt; </b></span>dbi.icdSchluessel = <b>append</b><span style=\"color: navy\">(</span><span style=\"color: maroon\">cd</span><span style=\"color: navy\">, </span><span style=\"color: blue\">':B'</span><span style=\"color: navy\">)</span> <i>\"AppendSeiteBeidseits\"</i><span style=\"color: navy\">;</span>#xD;\n            <span style=\"color: navy\">}</span> <i>\"MapDbiSeiteSCT\"</i><span style=\"color: navy\">;</span>#xD;\n          <span style=\"color: navy\">}</span> <i>\"MapDbiSeite\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"MapDbiIcd\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapDbiCode\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"DbiConditionContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryDbiCondition\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
  ] ; # 
