<https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma> a fhir:StructureMap ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "SenologieToObdsModulMamma"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToObdsModulMamma</b></p><a name=\"SenologieToObdsModulMamma\"> </a><a name=\"hcSenologieToObdsModulMamma\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma<span style=\"color: navy\">\" = \"</span>SenologieToObdsModulMamma<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie Mamma-Observations to oBDS Modul_Mamma BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/observation.html\" title=\"Observation\">http://hl7.org/fhir/StructureDefinition/Observation</a><span style=\"color: navy\">\" </span><b>alias </b>Observation <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/servicerequest.html\" title=\"ServiceRequest\">http://hl7.org/fhir/StructureDefinition/ServiceRequest</a><span style=\"color: navy\">\" </span><b>alias </b>ServiceRequest <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/specimen.html\" title=\"Specimen\">http://hl7.org/fhir/StructureDefinition/Specimen</a><span style=\"color: navy\">\" </span><b>alias </b>Specimen <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-obds-meldung.html\" title=\"oBDS Meldung\">https://www.senologie.org/fhir/StructureDefinition/obds-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>OBDSMeldung <b>as </b><b>target</b>#xD;\n#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Known limitation: Sub-groups use `target tgt : BackboneElement` because FML</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">has no syntax to declare the Logical Model sub-path for BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">slices passed from parent groups. The IG Publisher produces SM_TARGET_PATH</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">/ SM_SOURCE_PATH errors (~22). The element names are correct per the oBDS</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Logical Model.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Gemeinsame Modul-Mamma-Map: Extrahiert mammaspezifische Observations aus</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">dem Bundle und mappt auf das oBDS Modul_Mamma BackboneElement.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Wird von Diagnose, OP und Verlauf importiert.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MII Onko Mamma-Profile:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-mamma-rezeptorstatus-estrogen (LOINC 85337-4)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-mamma-rezeptorstatus-progesteron (LOINC 85339-0)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-mamma-her2neu-status (LOINC 85319-2)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-mamma-menopause-status (LOINC 63612-8)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">SNOMED-CT Werte:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">10828004 = Positive (qualifier value) -&gt; P</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">260385009 = Negative (qualifier value) -&gt; N</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">261665006 = Unknown (qualifier value) -&gt; U</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Menopausenstatus:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">309606002 = Before menopause (finding) -&gt; 1 (praemenopausal)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">309607006 = During menopause (finding) -&gt; 2 (perimenopausal, nicht oBDS-konform, gemappt auf U)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">309608001 = After menopause (finding) -&gt; 3 (postmenopausal)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapModulMamma: Bundle -&gt; oBDS Modul_Mamma</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Extrahiert Hormonrezeptoren, HER2 und Menopausenstatus aus Observations</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapModulMamma<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Bundle, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Oestrogenrezeptor (LOINC 85337-4 = Estrogen receptor Ag [Presence])</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">erEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '85337-4')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    erEntry.resource<b> as </b><span style=\"color: maroon\">erObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      erObs.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '10828004'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.hormonrezeptorStatusOestrogen = <span style=\"color: blue\">'P'</span> <i>\"SetERPositiv\"</i><span style=\"color: navy\">;</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '260385009'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.hormonrezeptorStatusOestrogen = <span style=\"color: blue\">'N'</span> <i>\"SetERNegativ\"</i><span style=\"color: navy\">;</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '261665006'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.hormonrezeptorStatusOestrogen = <span style=\"color: blue\">'U'</span> <i>\"SetERUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapERValue\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapERObs\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryER\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Progesteronrezeptor (LOINC 85339-0 = Progesterone receptor Ag [Presence])</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">prEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '85339-0')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    prEntry.resource<b> as </b><span style=\"color: maroon\">prObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      prObs.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '10828004'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.hormonrezeptorStatusProgesteron = <span style=\"color: blue\">'P'</span> <i>\"SetPRPositiv\"</i><span style=\"color: navy\">;</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '260385009'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.hormonrezeptorStatusProgesteron = <span style=\"color: blue\">'N'</span> <i>\"SetPRNegativ\"</i><span style=\"color: navy\">;</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '261665006'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.hormonrezeptorStatusProgesteron = <span style=\"color: blue\">'U'</span> <i>\"SetPRUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapPRValue\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapPRObs\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryPR\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">HER2-Status (LOINC 85319-2 = HER2 [Presence] in Breast cancer specimen)</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">herEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '85319-2')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    herEntry.resource<b> as </b><span style=\"color: maroon\">herObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      herObs.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '10828004'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.her2neuStatus = <span style=\"color: blue\">'P'</span> <i>\"SetHER2Positiv\"</i><span style=\"color: navy\">;</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '260385009'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.her2neuStatus = <span style=\"color: blue\">'N'</span> <i>\"SetHER2Negativ\"</i><span style=\"color: navy\">;</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '261665006'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.her2neuStatus = <span style=\"color: blue\">'U'</span> <i>\"SetHER2Unbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapHER2Value\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapHER2Obs\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryHER2\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Menopausenstatus (LOINC 63612-8 = Menopause status)</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Nur in Diagnose und Verlauf relevant (nicht OP)</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">menoEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '63612-8')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    menoEntry.resource<b> as </b><span style=\"color: maroon\">menoObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      menoObs.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        <span style=\"color: navy\">// </span><span style=\"color: green\">Praemenopausal: SNOMED 309606002 -&gt; oBDS 1</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '309606002'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.praetherapeutischerMenopausenstatus = <span style=\"color: blue\">'1'</span> <i>\"SetMenoPrae\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">// </span><span style=\"color: green\">Postmenopausal: SNOMED 309608001 -&gt; oBDS 3</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '309608001'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.praetherapeutischerMenopausenstatus = <span style=\"color: blue\">'3'</span> <i>\"SetMenoPost\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">// </span><span style=\"color: green\">Perimenopausal: SNOMED 309607006 -&gt; oBDS U (kein oBDS-Code fuer perimenopausal)</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '309607006'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.praetherapeutischerMenopausenstatus = <span style=\"color: blue\">'U'</span> <i>\"SetMenoPeri\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">// </span><span style=\"color: green\">Unbekannt: SNOMED 261665006 -&gt; oBDS U</span>#xD;\n        val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = '261665006'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.praetherapeutischerMenopausenstatus = <span style=\"color: blue\">'U'</span> <i>\"SetMenoUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapMenoValue\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapMenoObs\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryMenopause\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Praeoperative Drahtmarkierung (aus Senologie_OP_Planung ServiceRequest.extension[preOpMarkierung])</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ValueCodeableConcept mit code M/S/T/N/U oder Freitext; wird nur fuer OP-Meldung verwendet.</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">srEntry</span><b> where </b>resource.is(ServiceRequest)<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    srEntry.resource<b> as </b><span style=\"color: maroon\">sr</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      sr.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ex-senologie-pre-op-markierung'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'M'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.praeopDrahtmarkierung = <span style=\"color: blue\">'M'</span> <i>\"SetDrahtMammografie\"</i><span style=\"color: navy\">;</span>#xD;\n          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'S'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.praeopDrahtmarkierung = <span style=\"color: blue\">'S'</span> <i>\"SetDrahtSonografie\"</i><span style=\"color: navy\">;</span>#xD;\n          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'T'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.praeopDrahtmarkierung = <span style=\"color: blue\">'T'</span> <i>\"SetDrahtMRT\"</i><span style=\"color: navy\">;</span>#xD;\n          val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>code = 'N'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.praeopDrahtmarkierung = <span style=\"color: blue\">'N'</span> <i>\"SetDrahtNein\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"MapDrahtValue\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapDrahtExt\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapDrahtSR\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryDrahtmarkierung\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Intraoperative Praeparatkontrolle (QI-3) — aus Specimen im Bundle</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Specimen.processing.procedure.coding mit oBDS-Kode (M/S/N/U)</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">specEntry</span><b> where </b>resource.is(Specimen)<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    specEntry.resource<b> as </b><span style=\"color: maroon\">spec</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      spec.processing<b> as </b><span style=\"color: maroon\">proc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        proc.procedure<b> as </b><span style=\"color: maroon\">p</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          p.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'https://www.senologie.org/fhir/CodeSystem/cs-senologie-obds-intraop-praeparatkontrolle'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.intraopPraeparatkontrolle = <span style=\"color: navy\">(</span>c.code<span style=\"color: navy\">)</span> <i>\"SetIntraopKontrolle\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"MapIntraopProc\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapIntraopProcessing\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapIntraopSpec\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryIntraopKontrolle\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Tumorgroesse invasiv (LOINC 33728-7 = Size of tumor in Specimen; component/valueQuantity in mm)</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">sizeEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '33728-7')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    sizeEntry.resource<b> as </b><span style=\"color: maroon\">sizeObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      sizeObs.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        val.value<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorgroesseInvasiv = <span style=\"color: maroon\">v</span> <i>\"SetTumorgroesseInvasiv\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapSizeInvasiv\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapSizeObs\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryTumorSize\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
  ] ; # 
