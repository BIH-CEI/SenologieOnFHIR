style=\"color: navy\">}</span> <i>\"MapOpDetailAustauschValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapOpDetailAustausch\"</i><span style=\"color: navy\">;</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">inner</span><b> where </b>url = 'revision'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    inner.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.operationsdetailRevisionSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetOpDetailRevision\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapOpDetailRevisionCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapOpDetailRevisionValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapOpDetailRevision\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Befund: Extension -&gt; BEB_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapBefund<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>BackboneElement, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  src.extension<b> as </b><span style=\"color: maroon\">inner</span><b> where </b>url = 'befund'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    inner.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.befundSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetBefund\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapBefundCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapBefundValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapBefundRevision\"</i><span style=\"color: navy\">;</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">inner</span><b> where </b>url = 'befundAustausch'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    inner.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.befundAustauschSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetBefundAustausch\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapBefundAustauschCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapBefundAustauschValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapBefundAustausch\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Artikelidentifikation: Device -&gt; ARI_* + ARB_* + ABI_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">UDI, Hersteller, Seriennummer, LOT, Form, Oberflaeche, Fuellung, Volumen</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapArtikelidentifikation<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Device, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">--- ARI_* Identifikation ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ARI_LaufendeNummer: aus Device.identifier oder Sequenz</span>#xD;\n  src.identifier<b> as </b><span style=\"color: maroon\">id</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    id.value<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.laufendeNummer = <span style=\"color: maroon\">v</span> <i>\"SetAriLaufendeNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapAriLaufendeNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>identifier.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.laufendeNummer = <span style=\"color: blue\">1</span> <i>\"SetAriLaufendeNummerDefault\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ARI_Artikelkennzeichen: UDI oder REF-Nummer</span>#xD;\n  src.udiCarrier<b> as </b><span style=\"color: maroon\">udi</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    udi.deviceIdentifier<b> as </b><span style=\"color: maroon\">di</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelkennzeichen = <span style=\"color: maroon\">di</span> <i>\"SetArtikelkennzeichenUDI\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">// </span><span style=\"color: green\">Wenn UDI vorhanden, Typ = UDI</span>#xD;\n    udi<span style=\"color: navy\"><b> -&gt; </b></span>tgt.kennzeichenTypSchluessel = <span style=\"color: blue\">'1'</span> <i>\"SetKennzeichenTypUDI\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapUdiCarrier\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Fallback: lotNumber als REF-Nummer (Katalognummer)</span>#xD;\n  src<b> where </b>udiCarrier.exists().not()<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    src.lotNumber<b> as </b><span style=\"color: maroon\">lot</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelkennzeichen = <span style=\"color: maroon\">lot</span> <i>\"SetArtikelkennzeichenREF\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.kennzeichenTypSchluessel = <span style=\"color: blue\">'2'</span> <i>\"SetKennzeichenTypREF\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapArtikelkennzeichenFallback\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ARI_ArtikelArtSchluessel (enum_0067): Implantat/Explantat</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Bestimmung aus Device.status oder Procedure-Kontext</span>#xD;\n  src.status<b> as </b><span style=\"color: maroon\">st</span><b> where </b>$this = 'active'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelArtSchluessel = <span style=\"color: blue\">'1'</span> <i>\"SetArtikelArtImplantat\"</i><span style=\"color: navy\">;</span>#xD;\n  src.status<b> as </b><span style=\"color: maroon\">st</span><b> where </b>$this = 'inactive'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelArtSchluessel = <span style=\"color: blue\">'2'</span> <i>\"SetArtikelArtExplantat\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- ARB_* Artikelbeschreibung ---</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelbeschreibung<b> as </b><span style=\"color: maroon\">arb</span><b> then </b>MapArtikelbeschreibung<span style=\"color: navy\">(</span><span style=\"color: maroon\">src</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">arb</span><span style=\"color: navy\">)</span> <i>\"CallMapArb\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Artikelbeschreibung: Device -&gt; ARB_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">LOT-Nummer, Seriennummer, Verfalldatum, Bezeichnung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapArtikelbeschreibung<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Device, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">ARB_LotNummer</span>#xD;\n  src.lotNumber<b> as </b><span style=\"color: maroon\">lot</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.lotNummer = <span style=\"color: maroon\">lot</span> <i>\"SetLotNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>lotNumber.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.lotNummerUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetLotNummerUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ARB_SerienNummer</span>#xD;\n  src.serialNumber<b> as </b><span style=\"color: maroon\">sn</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.serienNummer = <span style=\"color: maroon\">sn</span> <i>\"SetSerienNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>serialNumber.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.serienNummerUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetSerienNummerUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ARB_Artikelbezeichnung: aus Device.deviceName oder Device.type.text</span>#xD;\n  src.deviceName<b> as </b><span style=\"color: maroon\">dn</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    dn.name<b> as </b><span style=\"color: maroon\">n</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelbezeichnung = <span style=\"color: maroon\">n</span> <i>\"SetArtikelbezeichnung\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapDeviceName\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ARB_Barcode: aus UDI carrierHRF</span>#xD;\n  src.udiCarrier<b> as </b><span style=\"color: maroon\">udi</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    udi.carrierHRF<b> as </b><span style=\"color: maroon\">hrf</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.barcode = <span style=\"color: maroon\">hrf</span> <i>\"SetBarcode\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapBarcode\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- ABI_* Brustimplantat-spezifische Artikeldaten ---</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelBrustimplantat<b> as </b><span style=\"color: maroon\">abi</span><b> then </b>MapArtikelBrustimplantat<span style=\"color: navy\">(</span><span style=\"color: maroon\">src</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">abi</span><span style=\"color: navy\">)</span> <i>\"CallMapAbi\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">ArtikelBrustimplantat: Device -&gt; ABI_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Hersteller, Artikeltyp, Form, Oberflaeche, Fuellung, Volumen</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapArtikelBrustimplantat<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Device, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">ABI_HerstellerSchluessel: aus Device.manufacturer (Klartext -&gt; Katalogkode)</span>#xD;\n  src.manufacturer<b> as </b><span style=\"color: maroon\">mfr</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.herstellerSonstiger = <span style=\"color: maroon\">mfr</span> <i>\"SetHerstellerSonstiger\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>manufacturer.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.herstellerUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetHerstellerUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ABI_ArtikelTypSchluessel (enum_0190): aus Device.type</span>#xD;\n  src.type<b> as </b><span style=\"color: maroon\">t</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    t.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'https://www.senologie.org/fhir/CodeSystem/ireg-artikel-typ'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelTypSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetArtikelTypDirect\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapArtikelTypCoding\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapArtikelTyp\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Fallback: Brustimplantat Silikon als Standard</span>#xD;\n  src<b> where </b>type.coding.where(system = 'https://www.senologie.org/fhir/CodeSystem/ireg-artikel-typ').exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelTypSchluessel = <span style=\"color: blue\">'1'</span> <i>\"SetArtikelTypDefault\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ABI_FormSchluessel (enum_0126): aus Extension</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-form'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.formSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetForm\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapFormCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapFormValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapForm\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>extension.where(url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-form').exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.formUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetFormUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ABI_OberflaecheSchluessel (enum_0128): aus Extension</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-oberflaeche'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.oberflaecheSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetOberflaeche\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapOberflaecheCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapOberflaecheValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapOberflaeche\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>extension.where(url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-oberflaeche').exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.oberflaecheUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetOberflaecheUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ABI_FuellungSchluessel (enum_0124): aus Extension</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-fuellung'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.fuellungSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetFuellung\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapFuellungCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapFuellungValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapFuellung\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>extension.where(url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-fuellung').exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.fuellungUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetFuellungUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ABI_Volumen: aus Extension (in ml)</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-volumen'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.volumen = <span style=\"color: maroon\">val</span> <i>\"SetVolumen\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapVolumen\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>extension.where(url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-volumen').exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.volumenUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetVolumenUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ABI_IntraoperativesVolumen: aus Extension</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-implantat-intraop-volumen'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.intraoperativesVolumen = <span style=\"color: maroon\">val</span> <i>\"SetIntraopVolumen\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapIntraopVolumen\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Zubehoer: Device -&gt; ZUB_* + ZBI_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">ADM/Netz-Zubehoer zum Brustimplantat-Eingriff</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapZubehoer<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Device, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">ZUB_LaufendeNummer</span>#xD;\n  src.identifier<b> as </b><span style=\"color: maroon\">id</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    id.value<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.laufendeNummer = <span style=\"color: maroon\">v</span> <i>\"SetZubLaufendeNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapZubLaufendeNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>identifier.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.laufendeNummer = <span style=\"color: blue\">1</span> <i>\"SetZubLaufendeNummerDefault\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ZUB_ZubehoerArtSchluessel (enum_0069): Implantat/Explantat</span>#xD;\n  src.status<b> as </b><span style=\"color: maroon\">st</span><b> where </b>$this = 'active'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.zubehoerArtSchluessel = <span style=\"color: blue\">'1'</span> <i>\"SetZubArtImplantat\"</i><span style=\"color: navy\">;</span>#xD;\n  src.status<b> as </b><span style=\"color: maroon\">st</span><b> where </b>$this = 'inactive'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.zubehoerArtSchluessel = <span style=\"color: blue\">'2'</span> <i>\"SetZubArtExplantat\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ZUB_ArtikelNummer</span>#xD;\n  src.udiCarrier<b> as </b><span style=\"color: maroon\">udi</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    udi.deviceIdentifier<b> as </b><span style=\"color: maroon\">di</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelNummer = <span style=\"color: maroon\">di</span> <i>\"SetZubArtikelNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapZubArtikelNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>udiCarrier.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelNummerUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetZubArtikelNummerUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ZUB_LotNummer</span>#xD;\n  src.lotNumber<b> as </b><span style=\"color: maroon\">lot</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.lotNummer = <span style=\"color: maroon\">lot</span> <i>\"SetZubLotNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>lotNumber.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.lotNummerUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetZubLotNummerUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ZUB_SerienNummer</span>#xD;\n  src.serialNumber<b> as </b><span style=\"color: maroon\">sn</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.serienNummer = <span style=\"color: maroon\">sn</span> <i>\"SetZubSerienNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>serialNumber.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.serienNummerUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetZubSerienNummerUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ZUB_Artikelbezeichnung</span>#xD;\n  src.deviceName<b> as </b><span style=\"color: maroon\">dn</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    dn.name<b> as </b><span style=\"color: maroon\">n</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelbezeichnung = <span style=\"color: maroon\">n</span> <i>\"SetZubArtikelbezeichnung\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapZubDeviceName\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- ZBI_* Brustimplantat-spezifisches Zubehoer ---</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.zubehoerBrustimplantat<b> as </b><span style=\"color: maroon\">zbi</span><b> then </b>MapZubehoerBrustimplantat<span style=\"color: navy\">(</span><span style=\"color: maroon\">src</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">zbi</span><span style=\"color: navy\">)</span> <i>\"CallMapZbi\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">ZubehoerBrustimplantat: Device -&gt; ZBI_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapZubehoerBrustimplantat<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Device, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">ZBI_HerstellerSchluessel (enum_0131)</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-zubehoer-hersteller'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.herstellerSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetZbiHersteller\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapZbiHerstellerCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapZbiHerstellerValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapZbiHersteller\"</i><span style=\"color: navy\">;</span>#xD;\n  src<b> where </b>extension.where(url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-zubehoer-hersteller').exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.herstellerUnbekannt = <span style=\"color: blue\">1</span> <i>\"SetZbiHerstellerUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ZBI_HerstellerSonstiger</span>#xD;\n  src.manufacturer<b> as </b><span style=\"color: maroon\">mfr</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.herstellerSonstiger = <span style=\"color: maroon\">mfr</span> <i>\"SetZbiHerstellerSonstiger\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">ZBI_ZubehoerTypSchluessel (enum_0191)</span>#xD;\n  src.type<b> as </b><span style=\"color: maroon\">t</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    t.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'https://www.senologie.org/fhir/CodeSystem/ireg-zubehoer-typ'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.zubehoerTypSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetZbiZubehoerTyp\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapZbiTypCoding\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapZbiZubehoerTyp\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:url [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToIRegOperation"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToIRegOperation>
  ] ; # 
  fhir:version [ fhir:v "0.1.0"] ; # 
  fhir:name [ fhir:v "SenologieToIRegOperation"] ; # 
  fhir:status [ fhir:v "draft"] ; # 
  fhir:date [ fhir:v "2026-05-03T21:28:00+00:00"^^xsd:dateTime] ; # 
  fhir:publisher [ fhir:v "Berlin Institute of Health at Charité (BIH)"] ; # 
  fhir:contact ( [
     fhir:name [ fhir:v "Berlin Institute of Health at Charité (BIH)" ] ;
     fhir:telecom ( [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://www.bihealth.org" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "title: Senologie Procedure + Device to IRegG Operation + Artikelidentifikation\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Procedure"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Procedure>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Procedure" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Device"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Device>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Device" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/ireg-brustimplantat-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/ireg-brustimplantat-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "IRegMeldung" ]
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "MapOperation" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups use `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the Logical Model sub-path for BackboneElement\r\nslices passed from parent groups. The IG Publisher may produce SM_TARGET_PATH\r\nerrors. The element names are correct per the IRegG Brustimplantat LM.\r\n============================================================================\r\nOperation: Procedure -> OPE_* + OBI_*\r\nBildet eine Senologie_Operation (Procedure) auf die IRegG-Operationsstruktur\r\nab. Umfasst Basisdaten (Datum, Seitenlokalisation, ASA, Implantattyp) sowie\r\nbrustimplantat-spezifische Angaben (Art des Eingriffs, Grund, Lage, Zugang).\r\nDie Artikelidentifikation (Device -> ARI_* + ARB_* + ABI_*) wird ueber\r\nProcedure.focalDevice.manipulated oder Device-Referenzen im Bundle aufgeloest.\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Procedure" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapOpLaufendeNummer" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "identifier" ] ;
         fhir:variable [ fhir:v "id" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetOpLaufendeNummer" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "id" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "v" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "laufendeNummer" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "v"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetOpLaufendeNummerDefault" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:condition [ fhir:v "identifier.exists().not()" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "laufendeNummer" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Integer ;
             fhir:v 1
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetOpDatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "performed" ] ;
         fhir:variable [ fhir:v "perf" ] ;
         fhir:condition [ fhir:v "$this.is(dateTime)" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "datum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "perf"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapSeitenLokalisation" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "bodySite" ] ;
         fhir:variable [ fhir:v "bs" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapSeiteSCT" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "bs" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'http://snomed.info/sct'" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetSeiteRechts" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this = '24028007'" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "seitenLokalisationSchluessel" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "1"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetSeiteLinks" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this = '7771000'" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "seitenLokalisationSchluessel" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "2"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetSeiteBeidseits" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this = '51440002'" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "seitenLokalisationSchluessel" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "3"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapAsaKlassifikation" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
