# - resource -------------------------------------------------------------------

<https://www.senologie.org/fhir/StructureMap/SenologieToIRegOperation> a fhir:StructureMap ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "SenologieToIRegOperation"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToIRegOperation</b></p><a name=\"SenologieToIRegOperation\"> </a><a name=\"hcSenologieToIRegOperation\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToIRegOperation<span style=\"color: navy\">\" = \"</span>SenologieToIRegOperation<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie Procedure + Device to IRegG Operation + Artikelidentifikation</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/procedure.html\" title=\"Procedure\">http://hl7.org/fhir/StructureDefinition/Procedure</a><span style=\"color: navy\">\" </span><b>alias </b>Procedure <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/device.html\" title=\"Device\">http://hl7.org/fhir/StructureDefinition/Device</a><span style=\"color: navy\">\" </span><b>alias </b>Device <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-ireg-brustimplantat-meldung.html\" title=\"IRegG Brustimplantat Meldung (Logical Model)\">https://www.senologie.org/fhir/StructureDefinition/ireg-brustimplantat-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>IRegMeldung <b>as </b><b>target</b>#xD;\n#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Known limitation: Sub-groups use `target tgt : BackboneElement` because FML</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">has no syntax to declare the Logical Model sub-path for BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">slices passed from parent groups. The IG Publisher may produce SM_TARGET_PATH</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">errors. The element names are correct per the IRegG Brustimplantat LM.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Operation: Procedure -&gt; OPE_* + OBI_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Bildet eine Senologie_Operation (Procedure) auf die IRegG-Operationsstruktur</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">ab. Umfasst Basisdaten (Datum, Seitenlokalisation, ASA, Implantattyp) sowie</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">brustimplantat-spezifische Angaben (Art des Eingriffs, Grund, Lage, Zugang).</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Die Artikelidentifikation (Device -&gt; ARI_* + ARB_* + ABI_*) wird ueber</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Procedure.focalDevice.manipulated oder Device-Referenzen im Bundle aufgeloest.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapOperation<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Procedure, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement, <b>source</b> <span style=\"color: maroon\">bundle</span><span style=\"color: navy\"> : </span>Bundle<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">--- OPE_* Basisdaten ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OPE_LaufendeNummer: aus Procedure.identifier oder Sequenz</span>#xD;\n  src.identifier<b> as </b><span style=\"color: maroon\">id</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    id.value<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.laufendeNummer = <span style=\"color: maroon\">v</span> <i>\"SetOpLaufendeNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapOpLaufendeNummer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Fallback: wenn kein Identifier, laufende Nummer 1</span>#xD;\n  src<b> where </b>identifier.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.laufendeNummer = <span style=\"color: blue\">1</span> <i>\"SetOpLaufendeNummerDefault\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OPE_Datum: aus Procedure.performedDateTime</span>#xD;\n  src.performed<b> as </b><span style=\"color: maroon\">perf</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.datum = <span style=\"color: maroon\">perf</span> <i>\"SetOpDatum\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OPE_SeitenLokalisationSchluessel (enum_0050): aus Procedure.bodySite</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">rechts = 1, links = 2, beidseits = 3</span>#xD;\n  src.bodySite<b> as </b><span style=\"color: maroon\">bs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    bs.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'http://snomed.info/sct'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '24028007'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.seitenLokalisationSchluessel = <span style=\"color: blue\">'1'</span> <i>\"SetSeiteRechts\"</i><span style=\"color: navy\">;</span>#xD;\n      c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '7771000'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.seitenLokalisationSchluessel = <span style=\"color: blue\">'2'</span> <i>\"SetSeiteLinks\"</i><span style=\"color: navy\">;</span>#xD;\n      c.code<b> as </b><span style=\"color: maroon\">cd</span><b> where </b>$this = '51440002'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.seitenLokalisationSchluessel = <span style=\"color: blue\">'3'</span> <i>\"SetSeiteBeidseits\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapSeiteSCT\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapSeitenLokalisation\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OPE_AsaSchluessel (enum_0044): aus Extension oder Observation</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-asa-klassifikation'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.asaSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetAsaCode\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapAsaCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapAsaValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapAsaKlassifikation\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OPE_ImplantattypSchluessel (enum_0080): Brustimplantat = 3</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.implantattypSchluessel = <span style=\"color: blue\">'3'</span> <i>\"SetImplantattypBrust\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- OBI_* Brustimplantat-spezifische Operationsdaten ---</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.operationBrustimplantat<b> as </b><span style=\"color: maroon\">obi</span><b> then </b>MapOperationBrustimplantat<span style=\"color: navy\">(</span><span style=\"color: maroon\">src</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">obi</span><span style=\"color: navy\">)</span> <i>\"CallMapOBI\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Artikelidentifikation: Device-Ressourcen ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Aufloesen ueber Procedure.focalDevice.manipulated (Device-Referenz)</span>#xD;\n  src.focalDevice<b> as </b><span style=\"color: maroon\">fd</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    fd.manipulated<b> as </b><span style=\"color: maroon\">ref</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">Suche die referenzierte Device-Ressource im Bundle</span>#xD;\n      bundle.entry<b> as </b><span style=\"color: maroon\">devEntry</span><b> where </b>resource.is(Device) and (fullUrl = (%ref.reference))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>        devEntry.resource<b> as </b><span style=\"color: maroon\">device</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelidentifikation<b> as </b><span style=\"color: maroon\">art</span><b> then </b>MapArtikelidentifikation<span style=\"color: navy\">(</span><span style=\"color: maroon\">device</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">art</span><span style=\"color: navy\">)</span> <i>\"CallMapArtikel\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ResolveDeviceRef\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapDeviceRef\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapFocalDevice\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Fallback: alle Device-Ressourcen im Bundle, falls kein focalDevice vorhanden</span>#xD;\n  src<b> where </b>focalDevice.exists().not()<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    bundle.entry<b> as </b><span style=\"color: maroon\">devEntry</span><b> where </b>resource.is(Device) and resource.meta.profile.exists($this.contains('senologie-implantat'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      devEntry.resource<b> as </b><span style=\"color: maroon\">device</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artikelidentifikation<b> as </b><span style=\"color: maroon\">art</span><b> then </b>MapArtikelidentifikation<span style=\"color: navy\">(</span><span style=\"color: maroon\">device</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">art</span><span style=\"color: navy\">)</span> <i>\"CallMapArtikelFallback\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"EntryDeviceFallback\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"FallbackDevice\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- Zubehoer (ADM/Netz): Device mit Zubehoer-Profil ---</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">entry</span><b> where </b>resource.is(Device) and resource.meta.profile.exists($this.contains('ireg-zubehoer') or $this.contains('senologie-zubehoer'))<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    entry.resource<b> as </b><span style=\"color: maroon\">device</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.zubehoer<b> as </b><span style=\"color: maroon\">zub</span><b> then </b>MapZubehoer<span style=\"color: navy\">(</span><span style=\"color: maroon\">device</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">zub</span><span style=\"color: navy\">)</span> <i>\"CallMapZubehoer\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryZubehoer\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Brustimplantat-spezifische Operationsdaten: Procedure -&gt; OBI_*</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Art des Eingriffs, Grund, Lage, Zugang, Vorbehandlung, Massnahmen</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapOperationBrustimplantat<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Procedure, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">OBI_ArtEingriffSchluessel (enum_0100): aus Procedure.category oder Extension</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Primaereingriff = 1, Austausch Expander-&gt;Implantat = 2,</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Revision mit Austausch = 3, Revision ohne Austausch = 4, Explantation = 5</span>#xD;\n  src.category<b> as </b><span style=\"color: maroon\">cat</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    cat.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'https://www.senologie.org/fhir/CodeSystem/ireg-art-eingriff'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>      c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.artEingriffSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetArtEingriffDirect\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapArtEingriffCoding\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapArtEingriff\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OBI_GrundPrimaerEingriffSchluessel (enum_0102): bei Primaereingriff</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-grund-primaereingriff'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.grundPrimaerEingriffSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetGrundPrimaer\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapGrundPrimaerCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapGrundPrimaerValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapGrundPrimaerEingriff\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OBI_GrundAustauschSchluessel (enum_0104): bei Austausch/Revision</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-grund-austausch'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.grundAustauschSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetGrundAustausch\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapGrundAustauschCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapGrundAustauschValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapGrundAustausch\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OBI_GrundRevisionExplantationSchluessel (enum_0106): bei Explantation</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-grund-revision-explantation'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.grundRevisionExplantationSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetGrundExplantation\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapGrundExplCoding\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapGrundExplValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapGrundRevisionExplantation\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">OBI_LageSchluessel (enum_0112): Lage des neuen Implantats</span>#xD;\n  src.extension<b> as </b><span style=\"color: maroon\">ext</span><b> where </b>url = 'https://www.senologie.org/fhir/StructureDefinition/ireg-lage-implantat'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    ext.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.lageSchluessel = <span style=\"color: maroon\">cd</span> <i>\"SetLage\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapLageCoding\"</i><span style=\"color: navy\">;</span>#xD;\n