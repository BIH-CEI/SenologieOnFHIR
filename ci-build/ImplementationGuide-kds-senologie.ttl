           fhir:v "ConceptMap"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://www.senologie.org/fhir/ConceptMap/cm-oncobox-endokrine-substanz-atc> ;
         fhir:reference [ fhir:v "ConceptMap/cm-oncobox-endokrine-substanz-atc" ]
       ] ;
       fhir:name [ fhir:v "OncoBox Endokrine Substanzklasse zu ATC" ] ;
       fhir:description [ fhir:v "Mapping von ATC-Codes endokriner Substanzen zu OncoBox-Substanzklassen (1=Tamoxifen, 2=Aromatasehemmer, 3=GnRH-Analogon, 4=Fulvestrant, 5=CDK4/6-Inhibitor)" ] ;
