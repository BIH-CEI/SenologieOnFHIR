         fhir:reference [ fhir:v "StructureDefinition/ex-senologie-studienkontakt" ]
       ] ;
       fhir:name [ fhir:v "Kontaktperson Studie" ] ;
       fhir:description [ fhir:v "Kontaktperson für die klinische Studie — kein natives FHIR-Äquivalent in ResearchSubject" ] ;
