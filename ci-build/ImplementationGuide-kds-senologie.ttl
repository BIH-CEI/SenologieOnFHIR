         fhir:l <https://www.senologie.org/fhir/StructureDefinition/obds-meldung> ;
         fhir:reference [ fhir:v "StructureDefinition/obds-meldung" ]
       ] ;
       fhir:name [ fhir:v "oBDS Meldung" ] ;
       fhir:description [ fhir:v "Logisches Modell einer oBDS-Meldung (Onkologischer Basisdatensatz v3.0.5). Bildet die XML-Struktur einer einzelnen Meldung ab, wie sie von Meldestellen an die Krebsregister übermittelt wird." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
