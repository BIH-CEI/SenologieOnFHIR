     fhir:telecom ( [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://www.bihealth.org" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "title: Senologie Verlauf Bundle to oBDS Verlaufsmeldung\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Condition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Condition>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Condition" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Observation"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Observation>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Observation" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/obds-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/obds-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OBDSMeldung" ]
  ] ) ; # 
  fhir:import ( [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsFernmetastasen"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsFernmetastasen>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsLeistungszustand"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsLeistungszustand>
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "SenologieToObdsVerlauf" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups (MapVerlauf) use `target tgt : BackboneElement`.\r\nSee SenologieToObdsTNM.map for details.\r\n============================================================================\r\nHauptgruppe: Bundle -> oBDS Verlaufsmeldung\r\nDas Bundle enthaelt eine Condition (Rezidiv, clinicalStatus = recurrence)\r\nsowie zugehoerige Observations (TNM, Histologie, Fernmetastasen,\r\nHormonrezeptoren, Leistungszustand).\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "OBDSMeldung" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntryConditionTZ" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "ConditionContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "CallMapTumorzuordnung" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "condition" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "tumorzuordnung" ] ;
             fhir:variable [ fhir:v "tz" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapTumorzuordnung" ] ;
             fhir:variable ( [ fhir:v "condition" ] [ fhir:v "tz" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryConditionVerlauf" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapVerlauf" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "verlauf" ] ;
           fhir:variable [ fhir:v "verl" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapVerlauf" ] ;
           fhir:variable ( [ fhir:v "condition" ] [ fhir:v "verl" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapVerlauf" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nVerlauf: Condition (Rezidiv) -> OBDSMeldung.verlauf\r\nVerlauf_ID, Meldeanlass, Untersuchungsdatum, Gesamtbeurteilung Tumorstatus,\r\nlokaler Tumorstatus, LK-Status, FM-Status\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Condition" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapVerlaufID" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "identifier" ] ;
         fhir:variable [ fhir:v "id" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetVerlaufID" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "id" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "v" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "verlaufID" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "v"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetMeldeanlass" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "meldeanlass" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "statusaenderung"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapUntersuchungsdatumExt" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "extension" ] ;
         fhir:variable [ fhir:v "ext" ] ;
         fhir:condition [ fhir:v "url = 'https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-ex-onko-feststellungsdatum'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetUntersuchungsdatumExt" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "ext" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ] ;
           fhir:condition [ fhir:v "$this.is(dateTime)" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "untersuchungsdatum" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "val"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetUntersuchungsdatumFallback" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "recordedDate" ] ;
         fhir:variable [ fhir:v "rd" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "untersuchungsdatum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "rd"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapGesamtbeurteilung" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "stage" ] ;
         fhir:variable [ fhir:v "stg" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "ExtractGesamtbeurteilungCoding" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "stg" ] ;
           fhir:element [ fhir:v "summary" ] ;
           fhir:variable [ fhir:v "sum" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "TranslateGesamtbeurteilung" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "sum" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ] ;
             fhir:condition [ fhir:v "system = 'http://snomed.info/sct'" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "gesamtbeurteilungTumorstatus" ] ;
             fhir:transform [ fhir:v "translate" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "c"
               ]
             ] [
               fhir:value [
                 a fhir:String ;
                 fhir:v "https://www.senologie.org/fhir/ConceptMap/cm-sct-to-obds-verlauf-gesamtbeurteilung"
               ]
             ] [
               fhir:value [
                 a fhir:String ;
                 fhir:v "code"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetGesamtbeurteilungRezidiv" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "clinicalStatus" ] ;
         fhir:variable [ fhir:v "cs" ] ;
         fhir:condition [ fhir:v "coding.exists(code = 'recurrence')" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "gesamtbeurteilungTumorstatus" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "Y"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapLokalerTumorstatus" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "extension" ] ;
         fhir:variable [ fhir:v "ext" ] ;
         fhir:condition [ fhir:v "url = 'https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-ex-onko-verlauf-lokaler-tumorstatus'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapLokalerStatusValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "ext" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractLokalerStatus" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetLokalerTumorstatus" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "verlaufLokalerTumorstatus" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTumorstatusLymphknoten" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "extension" ] ;
         fhir:variable [ fhir:v "ext" ] ;
         fhir:condition [ fhir:v "url = 'https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-ex-onko-verlauf-tumorstatus-lymphknoten'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapLKStatusValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "ext" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractLKStatus" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetLKStatus" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "verlaufTumorstatusLymphknoten" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTumorstatusFernmetastasen" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "extension" ] ;
         fhir:variable [ fhir:v "ext" ] ;
         fhir:condition [ fhir:v "url = 'https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/StructureDefinition/mii-ex-onko-verlauf-tumorstatus-fernmetastasen'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapFMStatusValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "ext" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractFMStatus" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetFMStatus" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "verlaufTumorstatusFernmetastasen" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapFernmetastasen" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapFernmetastasenFromBundle" ] ;
         fhir:variable ( [ fhir:v "bundle" ] [ fhir:v "tgt" ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryHistologie" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "histEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '59847-4')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapHistologie" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "histEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "histObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "histologie" ] ;
           fhir:variable [ fhir:v "histo" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapHistologie" ] ;
           fhir:variable ( [ fhir:v "histObs" ] [ fhir:v "histo" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryTNMClinical" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "tnmEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '21908-9')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapTNMClinical" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "tnmEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "tnmObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "tnm" ] ;
           fhir:variable [ fhir:v "tnm" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapTNM" ] ;
           fhir:variable ( [ fhir:v "tnmObs" ] [ fhir:v "tnm" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryTNMPathological" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "tnmEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '21902-2')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapTNMPathological" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "tnmEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "tnmObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "tnm" ] ;
           fhir:variable [ fhir:v "tnm" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapTNM" ] ;
           fhir:variable ( [ fhir:v "tnmObs" ] [ fhir:v "tnm" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapLeistungszustand" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapLeistungszustandFromBundle" ] ;
         fhir:variable ( [ fhir:v "bundle" ] [ fhir:v "tgt" ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapModulMamma" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "modulMamma" ] ;
         fhir:variable [ fhir:v "mamma" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapModulMamma" ] ;
         fhir:variable ( [ fhir:v "bundle" ] [ fhir:v "mamma" ] )
       ] )
     ] )
  ] ) . # 

