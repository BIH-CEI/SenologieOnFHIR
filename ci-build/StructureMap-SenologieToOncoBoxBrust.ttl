  fhir:group ( [
     fhir:name [ fhir:v "SenologieToOncoBoxBrust" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nMaster Orchestrator: Bundle -> OncoBox Brust N1.1.1 Meldung\r\nErzeugt aus einem FHIR-Bundle mit Senologie-Ressourcen eine OncoBox-Brust-\r\nMeldung. Pro Patientin/Fall wird ein Primaerfall-Block erzeugt. Die Kennzahlen\r\n(KB-1 bis KB-20) werden ueber eine separate Sub-Map aggregiert befuellt.\r\nScope: OncoBox Brust N1.1.1 + OncoBox 2.0 FM-Erweiterung (J03-J05)\r\n(DKG/OnkoZert-Zertifizierung Brustzentren)\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "OncoBoxBrust" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "CallMapZentrum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "zentrum" ] ;
         fhir:variable [ fhir:v "zentrum" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapZentrum" ] ;
         fhir:variable ( [ fhir:v "src" ] [ fhir:v "zentrum" ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryPrimaerfall" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition) and resource.code.coding.exists((system = 'http://fhir.de/CodeSystem/bfarm/icd-10-gm') and (code.startsWith('C50') or code.startsWith('D05') or code.startsWith('D24') or code.startsWith('Z40') or code.startsWith('Z42')))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapPrimaerfall" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "primaerfall" ] ;
           fhir:variable [ fhir:v "pf" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapPrimaerfall" ] ;
           fhir:variable ( [ fhir:v "condition" ] [ fhir:v "pf" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapKennzahlen" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapKennzahlen" ] ;
         fhir:variable ( [ fhir:v "src" ] [ fhir:v "tgt" ] )
       ] )
     ] )
  ] ) . # 

