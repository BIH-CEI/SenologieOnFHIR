             fhir:rule ( [
               fhir:name [ fhir:v "SetNwBezeichnungDisplay" ] ;
               fhir:source ( [
                 fhir:context [ fhir:v "coding" ] ;
                 fhir:element [ fhir:v "display" ] ;
                 fhir:variable [ fhir:v "d" ] ;
                 fhir:condition [ fhir:v "%obsCode.text.exists().not()" ]
               ] ) ;
               fhir:target ( [
                 fhir:context [ fhir:v "nw" ] ;
                 fhir:contextType [ fhir:v "variable" ] ;
                 fhir:element [ fhir:v "artBezeichnung" ] ;
                 fhir:transform [ fhir:v "copy" ] ;
                 fhir:parameter ( [
                   fhir:value [
                     a fhir:Id ;
                     fhir:v "d"
                   ]
                 ] )
               ] )
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetNwGrad" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "g" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "nw" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "grad" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "g"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "ExtractNwVersion" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "src" ] ;
