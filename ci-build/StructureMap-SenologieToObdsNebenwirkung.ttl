# - resource -------------------------------------------------------------------

<https://www.senologie.org/fhir/StructureMap/SenologieToObdsNebenwirkung> a fhir:StructureMap ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "SenologieToObdsNebenwirkung"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToObdsNebenwirkung</b></p><a name=\"SenologieToObdsNebenwirkung\"> </a><a name=\"hcSenologieToObdsNebenwirkung\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToObdsNebenwirkung<span style=\"color: navy\">\" = \"</span>SenologieToObdsNebenwirkung<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie Nebenwirkung Observations to oBDS Nebenwirkungen BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/observation.html\" title=\"Observation\">http://hl7.org/fhir/StructureDefinition/Observation</a><span style=\"color: navy\">\" </span><b>alias </b>Observation <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-obds-meldung.html\" title=\"oBDS Meldung\">https://www.senologie.org/fhir/StructureDefinition/obds-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>OBDSMeldung <b>as </b><b>target</b>#xD;\n#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Known limitation: Sub-groups use `target tgt : BackboneElement` because FML</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">has no syntax to declare the Logical Model sub-path for BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">slices. The IG Publisher produces SM_TARGET_PATH errors (~3). Element names</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">are correct per the oBDS Logical Model.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Gemeinsame Nebenwirkungen-Map: Extrahiert Nebenwirkungen (Adverse Events)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">aus dem Bundle und mappt auf das oBDS Nebenwirkungen-BackboneElement.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Wird von SYST und ST importiert.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MII Onko Profil: mii-pr-onko-nebenwirkung-adverse-event</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Die Nebenwirkung wird als Observation modelliert mit:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- code: CTCAE-Term (NCI Thesaurus Code + Text)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- value: CTCAE-Grad als CodeableConcept</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- method: CTCAE-Version</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">oBDS-Struktur:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">nebenwirkungen.gradMaximal2OderUnbekannt: Wenn alle Nebenwirkungen</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Grad &lt;=2 oder unbekannt sind, wird hier \"2\" oder \"U\" gesetzt.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">nebenwirkungen.nebenwirkung[]: Einzelne Nebenwirkungen Grad &gt;=3</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">mit art/bezeichnung, grad (3, 4, 5) und CTCAE-Version.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapNebenwirkungenSYST: Bundle -&gt; oBDS Nebenwirkungen (fuer Systemtherapie)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Bei SYST: Observations mit CTCAE-Codierung extrahieren,</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Grad &gt;=3 als einzelne Eintraege, sonst gradMaximal2OderUnbekannt</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapNebenwirkungenSYST<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Bundle, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Default: Wenn keine Nebenwirkungen vorhanden -&gt; U (unbekannt)</span>#xD;\n  src<b> where </b>entry.where(resource.is(Observation) and resource.code.coding.exists(system = 'http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl')).exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.gradMaximal2OderUnbekannt = <span style=\"color: blue\">'U'</span> <i>\"SetGradUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Nebenwirkungen mit CTCAE-Codierung: jede Observation einzeln verarbeiten</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">obsEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(system = 'http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    obsEntry.resource<b> as </b><span style=\"color: maroon\">obs</span><b> then </b>MapNebenwirkungEinzeln<span style=\"color: navy\">(</span><span style=\"color: maroon\">obs</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">tgt</span><span style=\"color: navy\">)</span> <i>\"CallMapNebenwirkungEinzeln\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryNebenwirkungen\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapNebenwirkungenST: Bundle -&gt; oBDS Nebenwirkungen (fuer Strahlentherapie)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Gleiche Logik wie SYST, aber separat um verschiedene Kontexte zu ermoeglichen</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapNebenwirkungenST<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Bundle, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Default: Wenn keine Nebenwirkungen vorhanden -&gt; U (unbekannt)</span>#xD;\n  src<b> where </b>entry.where(resource.is(Observation) and resource.code.coding.exists(system = 'http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl')).exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>tgt.gradMaximal2OderUnbekannt = <span style=\"color: blue\">'U'</span> <i>\"SetGradUnbekannt\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Nebenwirkungen mit CTCAE-Codierung</span>#xD;\n  src.entry<b> as </b><span style=\"color: maroon\">obsEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(system = 'http://ncicb.nci.nih.gov/xml/owl/EVS/Thesaurus.owl')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    obsEntry.resource<b> as </b><span style=\"color: maroon\">obs</span><b> then </b>MapNebenwirkungEinzeln<span style=\"color: navy\">(</span><span style=\"color: maroon\">obs</span><span style=\"color: navy\">, </span><span style=\"color: maroon\">tgt</span><span style=\"color: navy\">)</span> <i>\"CallMapNebenwirkungEinzeln\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryNebenwirkungen\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapNebenwirkungEinzeln: Observation -&gt; oBDS Nebenwirkung (einzeln)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Erzeugt einen Nebenwirkung-Eintrag mit Art/Bezeichnung, Grad und Version</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapNebenwirkungEinzeln<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Observation, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Einzelne Nebenwirkung</span>#xD;\n  src.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    val.coding<b> as </b><span style=\"color: maroon\">c</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.nebenwirkung<b> as </b><span style=\"color: maroon\">nw</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">Art/Bezeichnung der Nebenwirkung (aus Observation.code)</span>#xD;\n      src.code<b> as </b><span style=\"color: maroon\">obsCode</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        obsCode.text<b> as </b><span style=\"color: maroon\">t</span><span style=\"color: navy\"><b> -&gt; </b></span>nw.artBezeichnung = <span style=\"color: maroon\">t</span> <i>\"SetNwBezeichnung\"</i><span style=\"color: navy\">;</span>#xD;\n        obsCode.coding<b> as </b><span style=\"color: maroon\">coding</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          coding.display<b> as </b><span style=\"color: maroon\">d</span><b> where </b>%obsCode.text.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>nw.artBezeichnung = <span style=\"color: maroon\">d</span> <i>\"SetNwBezeichnungDisplay\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"FallbackNwBezeichnung\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ExtractNwBezeichnung\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">CTCAE-Grad (1-5)</span>#xD;\n      c.code<b> as </b><span style=\"color: maroon\">g</span><span style=\"color: navy\"><b> -&gt; </b></span>nw.grad = <span style=\"color: maroon\">g</span> <i>\"SetNwGrad\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">CTCAE-Version (z.B. \"4.03\", \"5.0\")</span>#xD;\n      src.method<b> as </b><span style=\"color: maroon\">method</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        method.text<b> as </b><span style=\"color: maroon\">t</span><span style=\"color: navy\"><b> -&gt; </b></span>nw.version = <span style=\"color: maroon\">t</span> <i>\"SetNwVersion\"</i><span style=\"color: navy\">;</span>#xD;\n        method.coding<b> as </b><span style=\"color: maroon\">mc</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>          mc.code<b> as </b><span style=\"color: maroon\">v</span><b> where </b>%method.text.exists().not()<span style=\"color: navy\"><b> -&gt; </b></span>nw.version = <span style=\"color: maroon\">v</span> <i>\"SetNwVersionFromCoding\"</i><span style=\"color: navy\">;</span>#xD;\n        <span style=\"color: navy\">}</span> <i>\"FallbackNwVersion\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ExtractNwVersion\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"CreateNebenwirkung\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapNebenwirkungGrad\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
  ] ; # 
