       fhir:l <https://www.senologie.org/fhir/StructureDefinition/oncobox-brust-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OncoBoxBrust" ]
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "MapZentrum" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: MapZentrum uses `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the Logical Model sub-path for BackboneElement\r\nslices. The IG Publisher produces SM_TARGET_PATH / SM_SOURCE_PATH errors\r\n(~12). Element names are correct per the OncoBox Brust Logical Model.\r\n============================================================================\r\nZentrum / Meldungs-Metadaten: Organization + Bundle.timestamp -> Zentrum\r\nDie Zentrums-ID (OnkoZert-Kennung) ist zentrumsspezifisch und wird als\r\nKonfigurationswert oder ueber Organization.identifier gepflegt. Der\r\nBerichtszeitraum (01.07.Vorjahr - 30.06.aktuellesJahr) ist meldungs-\r\nspezifisch und wird hier aus Bundle.timestamp abgeleitet; in der Praxis\r\ntypischerweise ueber Parameter gesetzt.\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "SetOncoBoxVersion" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "oncoBoxVersion" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "N1.1.1"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetMeldungsdatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "timestamp" ] ;
         fhir:variable [ fhir:v "ts" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "meldungsdatum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "ts"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryOrganization" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Organization)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "OrgContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "org" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetZentrumName" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "name" ] ;
             fhir:variable [ fhir:v "name" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "zentrumName" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "name"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "FilterIKNR" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'https://fhir.de/sid/arge-ik/iknr'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetIKNR" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "iknr" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "FilterStandort" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'http://fhir.de/sid/standortnummer'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetStandortId" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "standortId" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "FilterZentrumIdOZ" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'https://www.onkozert.de/sid/zentrum-id'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetZentrumId" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "zentrumId" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "FilterZentrumIdIKNR" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "org" ] ;
             fhir:element [ fhir:v "identifier" ] ;
             fhir:variable [ fhir:v "id" ] ;
             fhir:condition [ fhir:v "system = 'https://fhir.de/sid/arge-ik/iknr'" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetZentrumIdIKNRFallback" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "id" ] ;
               fhir:element [ fhir:v "value" ] ;
               fhir:variable [ fhir:v "v" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "zentrumId" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "v"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] )
  ] ) . # 

