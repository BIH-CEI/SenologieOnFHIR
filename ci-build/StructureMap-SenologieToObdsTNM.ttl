<https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM> a fhir:StructureMap ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "SenologieToObdsTNM"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToObdsTNM</b></p><a name=\"SenologieToObdsTNM\"> </a><a name=\"hcSenologieToObdsTNM\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM<span style=\"color: navy\">\" = \"</span>SenologieToObdsTNM<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie TNM Observations to oBDS TNM BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/observation.html\" title=\"Observation\">http://hl7.org/fhir/StructureDefinition/Observation</a><span style=\"color: navy\">\" </span><b>alias </b>Observation <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-obds-meldung.html\" title=\"oBDS Meldung\">https://www.senologie.org/fhir/StructureDefinition/obds-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>OBDSMeldung <b>as </b><b>target</b>#xD;\n#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Known limitation: MapTNM uses `target tgt : BackboneElement` because FML</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">has no syntax to declare the Logical Model sub-path for BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">slices passed from parent groups (diagnose.cTNM, diagnose.pTNM, op.tnm,</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">verlauf.tnm). The IG Publisher produces SM_TARGET_PATH errors (~24). The</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">element names are correct per the oBDS Logical Model.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Gemeinsame TNM-Map: Extrahiert TNM-Staging aus einer TNM-Klassifikation-</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Observation (MII Onko) und mappt auf das oBDS TNM-BackboneElement.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Wird von Diagnose (cTNM), OP (pTNM) und Verlauf (c/pTNM) importiert.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Die TNM-Klassifikation-Observation enthaelt T/N/M/L/V/Pn als components</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">mit LOINC-kodierten Codes.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MII Onko TNM LOINC-Codes:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Klinisch: 21908-9 (Gesamt), 21905-5 (cT), 21906-3 (cN), 21907-1 (cM)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Pathologisch: 21902-2 (Gesamt), 21899-0 (pT), 21900-6 (pN), 21901-4 (pM)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Symbole: 59479-6 (y), 21983-2 (r), 101659-7 (a), 42030-7 (m)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Zusatz: 33739-4 (L), 33740-2 (V), 92837-4 (Pn)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapTNM: Observation (TNM-Klassifikation) -&gt; oBDS TNM BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Generische Gruppe, die sowohl klinisches als auch pathologisches TNM</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">verarbeitet. Der c/p/u-Praefix wird aus dem jeweiligen LOINC-Code</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">der T/N/M-Komponenten abgeleitet.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapTNM<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Observation, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement, <b>source</b> <span style=\"color: maroon\">bundle</span><span style=\"color: navy\"> : </span>Bundle<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Datum der TNM-Klassifikation</span>#xD;\n  src.effective<b> as </b><span style=\"color: maroon\">eff</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.datum = <span style=\"color: maroon\">eff</span> <i>\"SetTNMDatum\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">TNM-Auflage (Version): aus Observation.method</span>#xD;\n  src.method<b> as </b><span style=\"color: maroon\">method</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    method.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.version = <span style=\"color: maroon\">cd</span> <i>\"SetTNMVersion\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"ExtractTNMVersionCode\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapTNMVersion\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">y-Symbol (nach multimodaler Therapie) — LOINC 59479-6</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '59479-6')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.ySymbol = <span style=\"color: maroon\">cd</span> <i>\"SetYSymbol\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ExtractYCode\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapYValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapYSymbol\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">r-Symbol (Rezidivklassifikation) — LOINC 21983-2</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '21983-2')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.rSymbol = <span style=\"color: maroon\">cd</span> <i>\"SetRSymbol\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ExtractRCode\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapRValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapRSymbol\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">a-Symbol (Autopsie) — LOINC 101659-7</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '101659-7')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.aSymbol = <span style=\"color: maroon\">cd</span> <i>\"SetASymbol\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ExtractACode\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapAValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapASymbol\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- T-Kategorie ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">T klinisch (LOINC 21905-5) -&gt; Praefix c</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '21905-5')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp<span style=\"color: navy\"><b> -&gt; </b></span>tgt.cpuPraefixT = <span style=\"color: blue\">'c'</span> <i>\"SetCPrefixT\"</i><span style=\"color: navy\">;</span>#xD;\n    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.t = <span style=\"color: maroon\">cd</span> <i>\"SetTClinical\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ExtractTClinCode\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapTClinValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapTClinical\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">T pathologisch (LOINC 21899-0) -&gt; Praefix p</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '21899-0')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp<span style=\"color: navy\"><b> -&gt; </b></span>tgt.cpuPraefixT = <span style=\"color: blue\">'p'</span> <i>\"SetPPrefixT\"</i><span style=\"color: navy\">;</span>#xD;\n    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.t = <span style=\"color: maroon\">cd</span> <i>\"SetTPathological\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ExtractTPathCode\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapTPathValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapTPathological\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">m_Symbol: multiple Primaertumoren — LOINC 42030-7</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '42030-7')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.mSymbol = <span style=\"color: maroon\">cd</span> <i>\"SetMSymbol\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"ExtractMSymbolCode\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapMSymbolValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapMSymbol\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">--- N-Kategorie ---</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">N klinisch (LOINC 21906-3) -&gt; Praefix c</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '21906-3')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp<span style=\"color: navy\"><b> -&gt; </b></span>tgt.cpuPraefixN = <span style=\"color: blue\">'c'</span> <i>\"SetCPrefixN\"</i><span style=\"color: 