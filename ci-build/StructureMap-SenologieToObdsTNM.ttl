  fhir:group ( [
     fhir:name [ fhir:v "MapTNM" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: MapTNM uses `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the Logical Model sub-path for BackboneElement\r\nslices passed from parent groups (diagnose.cTNM, diagnose.pTNM, op.tnm,\r\nverlauf.tnm). The IG Publisher produces SM_TARGET_PATH errors (~24). The\r\nelement names are correct per the oBDS Logical Model.\r\n============================================================================\r\nGemeinsame TNM-Map: Extrahiert TNM-Staging aus einer TNM-Klassifikation-\r\nObservation (MII Onko) und mappt auf das oBDS TNM-BackboneElement.\r\nWird von Diagnose (cTNM), OP (pTNM) und Verlauf (c/pTNM) importiert.\r\nDie TNM-Klassifikation-Observation enthaelt T/N/M/L/V/Pn als components\r\nmit LOINC-kodierten Codes.\r\nMII Onko TNM LOINC-Codes:\r\nKlinisch: 21908-9 (Gesamt), 21905-5 (cT), 21906-3 (cN), 21907-1 (cM)\r\nPathologisch: 21902-2 (Gesamt), 21899-0 (pT), 21900-6 (pN), 21901-4 (pM)\r\nSymbole: 59479-6 (y), 21983-2 (r), 101659-7 (a), 42030-7 (m)\r\nZusatz: 33739-4 (L), 33740-2 (V), 92837-4 (Pn)\r\n============================================================================\r\n============================================================================\r\nMapTNM: Observation (TNM-Klassifikation) -> oBDS TNM BackboneElement\r\nGenerische Gruppe, die sowohl klinisches als auch pathologisches TNM\r\nverarbeitet. Der c/p/u-Praefix wird aus dem jeweiligen LOINC-Code\r\nder T/N/M-Komponenten abgeleitet.\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Observation" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "SetTNMDatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "effective" ] ;
         fhir:variable [ fhir:v "eff" ] ;
         fhir:condition [ fhir:v "$this.is(dateTime)" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "datum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "eff"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTNMVersion" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "method" ] ;
         fhir:variable [ fhir:v "method" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "ExtractTNMVersionCode" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "method" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetTNMVersion" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "version" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "cd"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapYSymbol" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "component" ] ;
         fhir:variable [ fhir:v "comp" ] ;
         fhir:condition [ fhir:v "code.coding.exists(code = '59479-6')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapYValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "comp" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractYCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetYSymbol" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "ySymbol" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapRSymbol" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "component" ] ;
         fhir:variable [ fhir:v "comp" ] ;
         fhir:condition [ fhir:v "code.coding.exists(code = '21983-2')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapRValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "comp" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractRCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetRSymbol" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "rSymbol" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapASymbol" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "component" ] ;
         fhir:variable [ fhir:v "comp" ] ;
         fhir:condition [ fhir:v "code.coding.exists(code = '101659-7')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapAValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "comp" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractACode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetASymbol" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "aSymbol" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTClinical" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "component" ] ;
         fhir:variable [ fhir:v "comp" ] ;
         fhir:condition [ fhir:v "code.coding.exists(code = '21905-5')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetCPrefixT" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "comp" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "cpuPraefixT" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:String ;
               fhir:v "c"
             ]
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "MapTClinValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "comp" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractTClinCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetTClinical" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
             ] ) ;
             fhir:target ( [
               fhir:context [ fhir:v "tgt" ] ;
               fhir:contextType [ fhir:v "variable" ] ;
               fhir:element [ fhir:v "t" ] ;
               fhir:transform [ fhir:v "copy" ] ;
               fhir:parameter ( [
                 fhir:value [
                   a fhir:Id ;
                   fhir:v "cd"
                 ]
               ] )
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTPathological" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "component" ] ;
         fhir:variable [ fhir:v "comp" ] ;
         fhir:condition [ fhir:v "code.coding.exists(code = '21899-0')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetPPrefixT" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "comp" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "cpuPraefixT" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:String ;
               fhir:v "p"
             ]
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "MapTPathValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "comp" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "val" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "ExtractTPathCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "val" ] ;
             fhir:element [ fhir:v "coding" ] ;
             fhir:variable [ fhir:v "c" ]
           ] ) ;
           fhir:rule ( [
             fhir:name [ fhir:v "SetTPathological" ] ;
             fhir:source ( [
               fhir:context [ fhir:v "c" ] ;
               fhir:element [ fhir:v "code" ] ;
               fhir:variable [ fhir:v "cd" ]
