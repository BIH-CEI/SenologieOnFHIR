  fhir:name [ fhir:v "SenologieToObdsTNM"] ; # 
  fhir:status [ fhir:v "draft"] ; # 
  fhir:date [ fhir:v "2026-05-04T06:23:23+00:00"^^xsd:dateTime] ; # 
