  <group>
    <name value="SenologieToObdsDiagnose"/>
    <typeMode value="none"/>
    <documentation value="Known limitation: Sub-groups (MapDiagnose, MapWeitereKlassifikation) use&#xD;&#xA;`target tgt : BackboneElement`. See SenologieToObdsTNM.map for details.&#xD;&#xA;============================================================================&#xD;&#xA;Hauptgruppe: Bundle -&gt; oBDS Diagnosemeldung&#xD;&#xA;Das Bundle enthaelt eine Condition (Diagnose) sowie zugehoerige&#xD;&#xA;Observations (TNM, Histologie, Hormonrezeptoren).&#xD;&#xA;============================================================================"/>
    <input>
      <name value="src"/>
      <type value="Bundle"/>
      <mode value="source"/>
    </input>
    <input>
      <name value="tgt"/>
      <type value="OBDSMeldung"/>
      <mode value="target"/>
    </input>
    <rule>
      <name value="EntryConditionTZ"/>
      <source>
        <context value="src"/>
        <element value="entry"/>
        <variable value="entry"/>
        <condition value="resource.is(Condition)"/>
      </source>
      <rule>
        <name value="ConditionContext"/>
        <source>
