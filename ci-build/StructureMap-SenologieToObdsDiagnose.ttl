  fhir:description [ fhir:v "title: Senologie Diagnose Bundle to oBDS Diagnosemeldung\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Condition"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Condition>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Condition" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Observation"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Observation>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Observation" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/RiskAssessment"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/RiskAssessment>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "RiskAssessment" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/obds-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/obds-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OBDSMeldung" ]
  ] ) ; # 
  fhir:import ( [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsModulMamma>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsLeistungszustand"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsLeistungszustand>
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "SenologieToObdsDiagnose" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups (MapDiagnose, MapWeitereKlassifikation) use\r\n`target tgt : BackboneElement`. See SenologieToObdsTNM.map for details.\r\n============================================================================\r\nHauptgruppe: Bundle -> oBDS Diagnosemeldung\r\nDas Bundle enthaelt eine Condition (Diagnose) sowie zugehoerige\r\nObservations (TNM, Histologie, Hormonrezeptoren).\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "OBDSMeldung" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntryConditionTZ" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "ConditionContext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "CallMapTumorzuordnung" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "condition" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "tumorzuordnung" ] ;
             fhir:variable [ fhir:v "tz" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapTumorzuordnung" ] ;
             fhir:variable ( [ fhir:v "condition" ] [ fhir:v "tz" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryConditionDX" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapDiagnose" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "diagnose" ] ;
           fhir:variable [ fhir:v "dx" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapDiagnose" ] ;
           fhir:variable ( [ fhir:v "condition" ] [ fhir:v "dx" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapDiagnose" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nDiagnose: Condition -> OBDSMeldung.diagnose\r\nFreitextdiagnose, ICD-O Topographie, Diagnosesicherung, fruehere Erkrankungen\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Condition" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapDiagnosetext" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "code" ] ;
         fhir:variable [ fhir:v "code" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetDiagnosetext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "code" ] ;
           fhir:element [ fhir:v "text" ] ;
           fhir:variable [ fhir:v "t" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "primaertumorDiagnosetext" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "t"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTopographie" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "bodySite" ] ;
         fhir:variable [ fhir:v "bs" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapTopoCoding" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "bs" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'urn:oid:2.16.840.1.113883.6.43.1'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "primaertumorTopographieICDO" ] ;
           fhir:variable [ fhir:v "topo" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetTopoCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "topo" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "cd"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetTopoVersion" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "version" ] ;
             fhir:variable [ fhir:v "v" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "topo" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "version" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "v"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapTopoFreitext" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "bodySite" ] ;
         fhir:variable [ fhir:v "bs" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetTopoFreitext" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "bs" ] ;
           fhir:element [ fhir:v "text" ] ;
           fhir:variable [ fhir:v "t" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "primaertumorTopographieFreitext" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "t"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapDiagnosesicherung" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "verificationStatus" ] ;
         fhir:variable [ fhir:v "vs" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "ExtractDiagnosesicherungCode" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "vs" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/CodeSystem/mii-cs-onko-primaertumor-diagnosesicherung'" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetDiagnosesicherung" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "diagnosesicherung" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "cd"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapFruehereErkrankungen" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "extension" ] ;
         fhir:variable [ fhir:v "ext" ] ;
         fhir:condition [ fhir:v "url = 'http://hl7.org/fhir/StructureDefinition/condition-related'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapFruehereErkrankung" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "ext" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "ref" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "fruehereErkrankungen" ] ;
           fhir:variable [ fhir:v "fe" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetFrueherFreitext" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "ref" ] ;
             fhir:element [ fhir:v "display" ] ;
             fhir:variable [ fhir:v "d" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "fe" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "freitext" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "d"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryHistologie" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "histEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '59847-4')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapHistologie" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "histEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "histObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "histologie" ] ;
           fhir:variable [ fhir:v "histo" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapHistologie" ] ;
           fhir:variable ( [ fhir:v "histObs" ] [ fhir:v "histo" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryCTNM" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "tnmEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '21908-9')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapCTNM" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "tnmEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "tnmObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "cTNM" ] ;
           fhir:variable [ fhir:v "ctnm" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapTNM" ] ;
           fhir:variable ( [ fhir:v "tnmObs" ] [ fhir:v "ctnm" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapLeistungszustand" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapLeistungszustandFromBundle" ] ;
         fhir:variable ( [ fhir:v "bundle" ] [ fhir:v "tgt" ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapModulMamma" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "modulMamma" ] ;
         fhir:variable [ fhir:v "mamma" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapModulMamma" ] ;
         fhir:variable ( [ fhir:v "bundle" ] [ fhir:v "mamma" ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryWeitereKlassifikation" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "raEntry" ] ;
         fhir:condition [ fhir:v "resource.is(RiskAssessment)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapWeitereKlassifikation" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "raEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "ra" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "weitereKlassifikationen" ] ;
           fhir:variable [ fhir:v "wk" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapWeitereKlassifikation" ] ;
           fhir:variable ( [ fhir:v "ra" ] [ fhir:v "bundle" ] [ fhir:v "wk" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapWeitereKlassifikation" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nWeitere Klassifikation: RiskAssessment (Genexpressionstest) -> Menge_Weitere_Klassifikation\r\nMappt Genexpressionstests wie Oncotype DX, MammaPrint auf das oBDS-Element\r\n\"Weitere_Klassifikation\" (Datum, Name, Stadium/Ergebnis).\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "RiskAssessment" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "SetWKDatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "occurrence" ] ;
         fhir:variable [ fhir:v "occ" ] ;
         fhir:condition [ fhir:v "$this.is(dateTime)" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "datum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "occ"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapWKMethod" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "method" ] ;
         fhir:variable [ fhir:v "m" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapWKMethodCoding" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "m" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'https://www.senologie.org/fhir/CodeSystem/cs-senologie-genexpressionstest'" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetWKNameDisplay" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "display" ] ;
             fhir:variable [ fhir:v "d" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "name" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "d"
               ]
             ] )
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "SetWKNameText" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "m" ] ;
           fhir:element [ fhir:v "text" ] ;
           fhir:variable [ fhir:v "t" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "name" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "t"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapWKPrediction" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "prediction" ] ;
         fhir:variable [ fhir:v "pred" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapWKQR" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "pred" ] ;
           fhir:element [ fhir:v "qualitativeRisk" ] ;
           fhir:variable [ fhir:v "qr" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetWKStadiumQualitativeText" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "qr" ] ;
             fhir:element [ fhir:v "text" ] ;
             fhir:variable [ fhir:v "t" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "stadium" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "t"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "MapWKQRCoding" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "qr" ] ;
             fhir:element [ fhir:v "coding" ] ;
