       fhir:enableWhen ( [
         fhir:question [ fhir:v "rt-boost" ] ;
         fhir:operator [ fhir:v "=" ] ;
         fhir:answer [
           a fhir:Boolean ;
           fhir:v true
         ]
       ] ) ;
       fhir:required [ fhir:v false ]
     ] )
  ] [
     fhir:linkId [ fhir:v "ergebnis" ] ;
     fhir:text [ fhir:v "Ergebnis" ] ;
     fhir:type [ fhir:v "group" ] ;
     fhir:required [ fhir:v false ] ;
     fhir:item ( [
       fhir:linkId [ fhir:v "rt-nebenwirkungen" ] ;
       fhir:text [ fhir:v "Akute Nebenwirkungen" ] ;
       fhir:type [ fhir:v "text" ] ;
       fhir:required [ fhir:v false ]
     ] [
       fhir:linkId [ fhir:v "rt-therapiestatus" ] ;
       fhir:text [ fhir:v "Therapiestatus" ] ;
       fhir:type [ fhir:v "choice" ] ;
       fhir:required [ fhir:v false ] ;
       fhir:answerOption ( [
         fhir:value [
           a fhir:String ;
           fhir:v "Abgeschlossen"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Abgebrochen"
         ]
       ] [
         fhir:value [
           a fhir:String ;
           fhir:v "Laufend"
         ]
       ] )
     ] [
       fhir:linkId [ fhir:v "rt-abbruchgrund" ] ;
       fhir:text [ fhir:v "Abbruchgrund" ] ;
       fhir:type [ fhir:v "text" ] ;
       fhir:enableWhen ( [
         fhir:question [ fhir:v "rt-therapiestatus" ] ;
         fhir:operator [ fhir:v "=" ] ;
         fhir:answer [
           a fhir:String ;
           fhir:v "Abgebrochen"
         ]
       ] ) ;
       fhir:required [ fhir:v false ]
     ] )
  ] ) . # 

