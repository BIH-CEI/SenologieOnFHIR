     ] )
  ] ) ; # 
  fhir:description [ fhir:v "title: Senologie Fernmetastasen Observations to oBDS Fernmetastasen BackboneElement\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Observation"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Observation>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Observation" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/obds-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/obds-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OBDSMeldung" ]
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "MapFernmetastasenFromBundle" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups use `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the Logical Model sub-path for BackboneElement\r\nslices passed from parent groups. The IG Publisher produces SM_TARGET_PATH\r\nerrors. The element names are correct per the oBDS Logical Model.\r\n============================================================================\r\nGemeinsame Fernmetastasen-Map: Extrahiert Fernmetastasen-Observations\r\naus dem Bundle und mappt auf das oBDS Fernmetastasen-BackboneElement.\r\nWird von Diagnose und Verlauf importiert.\r\nMII Onko Profil: mii-pr-onko-fernmetastasen\r\n- LOINC 21907-1: Distant metastases.clinical Cancer\r\n- Alternative: LOINC 97956-3 (Fernmetastasen-Assessment)\r\nJede Fernmetastasen-Observation erzeugt einen separaten Eintrag mit\r\nDiagnosedatum und Lokalisation. Die Lokalisation wird via ConceptMap\r\nvon SNOMED zu oBDS-Kuerzeln (PUL, OSS, HEP, BRA, etc.) uebersetzt.\r\n============================================================================\r\n============================================================================\r\nMapFernmetastasenFromBundle: Bundle -> oBDS Fernmetastasen (repeating)\r\nIteriert ueber alle Fernmetastasen-Observations im Bundle\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntryFernmetastasen" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "fmEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '21907-1')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapFernmetastase" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "fmEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "fmObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "fernmetastasen" ] ;
           fhir:variable [ fhir:v "fm" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapFernmetastase" ] ;
           fhir:variable ( [ fhir:v "fmObs" ] [ fhir:v "fm" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryFernmetastasenAlt" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "fmEntry" ] ;
         fhir:condition [ fhir:v "resource.is(Observation) and resource.code.coding.exists(code = '97956-3')" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapFernmetastaseAlt" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "fmEntry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "fmObs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "fernmetastasen" ] ;
           fhir:variable [ fhir:v "fm" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapFernmetastase" ] ;
           fhir:variable ( [ fhir:v "fmObs" ] [ fhir:v "fm" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapFernmetastase" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nMapFernmetastase: Observation -> oBDS Fernmetastase (einzeln)\r\nDiagnosedatum und Lokalisation einer Fernmetastase\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Observation" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "SetFMDiagnosedatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "effective" ] ;
         fhir:variable [ fhir:v "eff" ] ;
         fhir:condition [ fhir:v "$this.is(dateTime)" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "diagnosedatum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "eff"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapFMLokalisation" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "bodySite" ] ;
         fhir:variable [ fhir:v "bs" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "TranslateFMLokalisation" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "bs" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'http://snomed.info/sct'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "lokalisation" ] ;
           fhir:transform [ fhir:v "translate" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "c"
             ]
           ] [
             fhir:value [
               a fhir:String ;
               fhir:v "https://www.senologie.org/fhir/ConceptMap/cm-sct-to-obds-fm-lokalisation"
             ]
           ] [
             fhir:value [
               a fhir:String ;
               fhir:v "code"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapFMLokalisationValue" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "value" ] ;
         fhir:variable [ fhir:v "val" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "TranslateFMLokalisationValue" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "val" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'http://snomed.info/sct'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "lokalisation" ] ;
           fhir:transform [ fhir:v "translate" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "c"
             ]
           ] [
             fhir:value [
               a fhir:String ;
               fhir:v "https://www.senologie.org/fhir/ConceptMap/cm-sct-to-obds-fm-lokalisation"
             ]
           ] [
             fhir:value [
               a fhir:String ;
               fhir:v "code"
             ]
           ] )
         ] )
       ] )
     ] )
  ] ) . # 

