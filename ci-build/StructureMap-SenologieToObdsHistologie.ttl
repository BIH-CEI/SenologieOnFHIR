<https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie> a fhir:StructureMap ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "SenologieToObdsHistologie"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToObdsHistologie</b></p><a name=\"SenologieToObdsHistologie\"> </a><a name=\"hcSenologieToObdsHistologie\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToObdsHistologie<span style=\"color: navy\">\" = \"</span>SenologieToObdsHistologie<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie Histologie Observations to oBDS Histologie BackboneElement</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/observation.html\" title=\"Observation\">http://hl7.org/fhir/StructureDefinition/Observation</a><span style=\"color: navy\">\" </span><b>alias </b>Observation <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/specimen.html\" title=\"Specimen\">http://hl7.org/fhir/StructureDefinition/Specimen</a><span style=\"color: navy\">\" </span><b>alias </b>Specimen <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-obds-meldung.html\" title=\"oBDS Meldung\">https://www.senologie.org/fhir/StructureDefinition/obds-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>OBDSMeldung <b>as </b><b>target</b>#xD;\n#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Known limitation: Sub-groups use `target tgt : BackboneElement`. See</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">SenologieToObdsTNM.map for details on SM_TARGET_PATH errors.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Gemeinsame Histologie-Map: Extrahiert Histologiebefunde aus MII Onko</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Observations und mappt auf das oBDS Histologie-BackboneElement.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Wird von Diagnose, OP und Verlauf importiert.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MII Onko Histologie-Profile:</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-histologie-icdo3 (LOINC 59847-4): Morphologie + Freitext</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-grading (LOINC 59542-1): Histopathologisches Grading</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-anzahl-untersuchte-lymphknoten (LOINC 21894-1)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-anzahl-befallene-lymphknoten (LOINC 21893-3)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-anzahl-untersuchte-sentinel-lymphknoten (LOINC 92832-5)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">- mii-pr-onko-anzahl-befallene-sentinel-lymphknoten (LOINC 92831-7)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Die Histologie-Observation (59847-4) ist die Haupt-Ressource.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Grading und Lymphknoten koennen als components in der Haupt-Observation</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">oder als separate Observations vorliegen.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">MapHistologie: Observation (Histologie ICD-O-3) -&gt; oBDS Histologie</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Verarbeitet die Haupt-Histologie-Observation und extrahiert Morphologie,</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Grading und Lymphknoten-Daten aus deren components.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapHistologie<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Observation, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>BackboneElement, <b>source</b> <span style=\"color: maroon\">bundle</span><span style=\"color: navy\"> : </span>Bundle<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">Histologie_ID: aus Observation.identifier</span>#xD;\n  src.identifier<b> as </b><span style=\"color: maroon\">id</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    id.value<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.histologieID = <span style=\"color: maroon\">v</span> <i>\"SetHistologieID\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapHistologieID\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Tumor_Histologiedatum: aus Observation.effectiveDateTime</span>#xD;\n  src.effective<b> as </b><span style=\"color: maroon\">eff</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorHistologiedatum = <span style=\"color: maroon\">eff</span> <i>\"SetHistologiedatum\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Histologie_EinsendeNr: aus Observation.identifier (Pathologie-Einsende-Nr)</span>#xD;\n  src.identifier<b> as </b><span style=\"color: maroon\">id</span><b> where </b>system = 'http://pathologie.charite.de/fhir/sid/einsende-nr'<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    id.value<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.histologieEinsendeNr = <span style=\"color: maroon\">v</span> <i>\"SetEinsendeNr\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapEinsendeNr\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Histologiedatum aus Specimen.collection.collectedDateTime (falls vorhanden)</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Das Specimen wird ueber Observation.specimen referenziert</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">specEntry</span><b> where </b>resource.is(Specimen)<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    specEntry.resource<b> as </b><span style=\"color: maroon\">specimen</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      <span style=\"color: navy\">// </span><span style=\"color: green\">Einsende-Nummer aus Specimen.accessionIdentifier</span>#xD;\n      specimen.accessionIdentifier<b> as </b><span style=\"color: maroon\">accId</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        accId.value<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.histologieEinsendeNr = <span style=\"color: maroon\">v</span> <i>\"SetEinsendeNrFromSpecimen\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapAccessionId\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">// </span><span style=\"color: green\">Histologiedatum aus Specimen.collection.collectedDateTime</span>#xD;\n      specimen.collection<b> as </b><span style=\"color: maroon\">coll</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        coll.collected<b> as </b><span style=\"color: maroon\">collDt</span><b> where </b>$this.is(dateTime)<span style=\"color: navy\"><b> -&gt; </b></span>tgt.tumorHistologiedatum = <span style=\"color: maroon\">collDt</span> <i>\"SetHistologiedatumFromSpecimen\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapSpecimenCollection\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"SpecimenContext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntrySpecimen\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Morphologie_ICD_O: aus Observation.value (ICD-O Morphologie)</span>#xD;\n  src.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    val.coding<b> as </b><span style=\"color: maroon\">c</span><b> where </b>system = 'urn:oid:2.16.840.1.113883.6.43.1'<span style=\"color: navy\"><b> -&gt; </b></span>tgt.morphologieICDO<b> as </b><span style=\"color: maroon\">morph</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      c.code<b> as </b><span style=\"color: maroon\">cd</span><span style=\"color: navy\"><b> -&gt; </b></span>morph.code = <span style=\"color: maroon\">cd</span> <i>\"SetMorphCode\"</i><span style=\"color: navy\">;</span>#xD;\n      c.version<b> as </b><span style=\"color: maroon\">v</span><span style=\"color: navy\"><b> -&gt; </b></span>morph.version = <span style=\"color: maroon\">v</span> <i>\"SetMorphVersion\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapMorphCoding\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapMorphologie\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Morphologie_Freitext: aus Observation.value.text</span>#xD;\n  src.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    val.text<b> as </b><span style=\"color: maroon\">t</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.morphologieFreitext = <span style=\"color: maroon\">t</span> <i>\"SetMorphFreitext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapMorphFreitext\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Grading: aus component (LOINC 59542-1) mit Uebersetzung SNOMED -&gt; oBDS</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '59542-1')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      val.coding<b> as </b><span style=\"color: maroon\">c</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.grading = <b>translate</b><span style=\"color: navy\">(</span><span style=\"color: maroon\">c</span><span style=\"color: navy\">, </span><span style=\"color: blue\">'https://www.senologie.org/fhir/ConceptMap/cm-sct-to-obds-grading'</span><span style=\"color: navy\">, </span><span style=\"color: blue\">'code'</span><span style=\"color: navy\">)</span> <i>\"TranslateGrading\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapGradingValue\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapGrading\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Grading: aus separater Observation im Bundle (Fallback)</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">gradEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '59542-1')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    gradEntry.resource<b> as </b><span style=\"color: maroon\">gradObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      gradObs.value<b> as </b><span style=\"color: maroon\">val</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>        val.coding<b> as </b><span style=\"color: maroon\">c</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.grading = <b>translate</b><span style=\"color: navy\">(</span><span style=\"color: maroon\">c</span><span style=\"color: navy\">, </span><span style=\"color: blue\">'https://www.senologie.org/fhir/ConceptMap/cm-sct-to-obds-grading'</span><span style=\"color: navy\">, </span><span style=\"color: blue\">'code'</span><span style=\"color: navy\">)</span> <i>\"TranslateGradingSeparate\"</i><span style=\"color: navy\">;</span>#xD;\n      <span style=\"color: navy\">}</span> <i>\"MapGradingSepValue\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapGradingSepObs\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryGrading\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">LK_untersucht: Anzahl untersuchter Lymphknoten (LOINC 21894-1)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '21894-1')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.lkUntersucht = <span style=\"color: maroon\">val</span> <i>\"SetLKUntersucht\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapLKUntersucht\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">LK_untersucht: aus separater Observation im Bundle (Fallback)</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">lkEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '21894-1')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    lkEntry.resource<b> as </b><span style=\"color: maroon\">lkObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      lkObs.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.lkUntersucht = <span style=\"color: maroon\">val</span> <i>\"SetLKUntersuchtSeparate\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapLKUntersuchtSep\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryLKUntersucht\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">LK_befallen: Anzahl befallener Lymphknoten (LOINC 21893-3)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '21893-3')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.lkBefallen = <span style=\"color: maroon\">val</span> <i>\"SetLKBefallen\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapLKBefallen\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">LK_befallen: aus separater Observation im Bundle (Fallback)</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">lkbEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '21893-3')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    lkbEntry.resource<b> as </b><span style=\"color: maroon\">lkbObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      lkbObs.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.lkBefallen = <span style=\"color: maroon\">val</span> <i>\"SetLKBefallenSeparate\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapLKBefallenSep\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntryLKBefallen\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Sentinel_LK_untersucht (LOINC 92832-5)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '92832-5')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.sentinelLKUntersucht = <span style=\"color: maroon\">val</span> <i>\"SetSentinelLKUntersucht\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapSentinelLKUntersucht\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Sentinel_LK_untersucht: aus separater Observation im Bundle (Fallback)</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">slkEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '92832-5')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    slkEntry.resource<b> as </b><span style=\"color: maroon\">slkObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      slkObs.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.sentinelLKUntersucht = <span style=\"color: maroon\">val</span> <i>\"SetSentinelLKUntersuchtSeparate\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapSentinelLKUntersuchtSep\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntrySentinelLKUntersucht\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Sentinel_LK_befallen (LOINC 92831-7)</span>#xD;\n  src.component<b> as </b><span style=\"color: maroon\">comp</span><b> where </b>code.coding.exists(code = '92831-7')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    comp.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.sentinelLKBefallen = <span style=\"color: maroon\">val</span> <i>\"SetSentinelLKBefallen\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"MapSentinelLKBefallen\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">Sentinel_LK_befallen: aus separater Observation im Bundle (Fallback)</span>#xD;\n  bundle.entry<b> as </b><span style=\"color: maroon\">slkbEntry</span><b> where </b>resource.is(Observation) and resource.code.coding.exists(code = '92831-7')<b> then</b><span style=\"color: navy\"> {#xD;\n</span>    slkbEntry.resource<b> as </b><span style=\"color: maroon\">slkbObs</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>      slkbObs.value<b> as </b><span style=\"color: maroon\">val</span><span style=\"color: navy\"><b> -&gt; </b></span>tgt.sentinelLKBefallen = <span style=\"color: maroon\">val</span> <i>\"SetSentinelLKBefallenSeparate\"</i><span style=\"color: navy\">;</span>#xD;\n    <span style=\"color: navy\">}</span> <i>\"MapSentinelLKBefallenSep\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"EntrySentinelLKBefallen\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
