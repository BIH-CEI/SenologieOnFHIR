  fhir:group ( [
     fhir:name [ fhir:v "MapPrimaerfall" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups use `target tgt : BackboneElement` because FML\r\nhas no syntax to declare the Logical Model sub-path for BackboneElement\r\nslices passed from parent groups. The IG Publisher may produce SM_TARGET_PATH\r\nerrors. The element names are correct per the OncoBox Brust Logical Model.\r\n============================================================================\r\nPrimaerfall: Condition (Brust-Diagnose) + Patient + Encounter -> Primaerfall\r\nPro Primaerfall (Condition mit ICD-10 aus dem Mamma-Spektrum) werden\r\nPatientendaten, Fall-Daten, Diagnose-Block und Therapie-Subblocks befuellt.\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Condition" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "SetFallId" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "id" ] ;
         fhir:variable [ fhir:v "cid" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "fallId" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "cid"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapPrimaerfallart" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "code" ] ;
         fhir:variable [ fhir:v "code" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapPrimaerfallartICD" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "code" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'http://fhir.de/CodeSystem/bfarm/icd-10-gm'" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetPfArtInvasiv" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this.startsWith('C50')" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "primaerfallart" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "1"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetPfArtDCIS" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this.startsWith('D05')" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "primaerfallart" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "2"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetPfArtRisiko" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this.startsWith('Z40')" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "primaerfallart" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "7"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetPfArtRekon" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this.startsWith('Z42')" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "primaerfallart" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "8"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetPfArtBenigne" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ] ;
             fhir:condition [ fhir:v "$this.startsWith('D24')" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "primaerfallart" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:String ;
                 fhir:v "9"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryPatient" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Patient)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapPatient" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "patient" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "patient" ] ;
           fhir:variable [ fhir:v "pat" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapPatient" ] ;
           fhir:variable ( [ fhir:v "patient" ] [ fhir:v "pat" ] [ fhir:v "bundle" ] )
         ] )
       ] [
         fhir:name [ fhir:v "PseudCtx" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "patient" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetPatientPseudonym" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "patient" ] ;
             fhir:element [ fhir:v "id" ] ;
             fhir:variable [ fhir:v "pid" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "patientPseudonym" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "pid"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryEncounter" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Encounter)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapFall" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "encounter" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "fall" ] ;
           fhir:variable [ fhir:v "fall" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapFall" ] ;
           fhir:variable ( [ fhir:v "encounter" ] [ fhir:v "fall" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapDiagnose" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "diagnose" ] ;
         fhir:variable [ fhir:v "diag" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapDiagnose" ] ;
         fhir:variable ( [ fhir:v "src" ] [ fhir:v "diag" ] [ fhir:v "bundle" ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryOperation" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-brustop') or $this.contains('senologie-operation'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapOperation" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "operation" ] ;
           fhir:variable [ fhir:v "op" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapOperation" ] ;
           fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "op" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntrySystemtherapie" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-systemtherapie-procedure'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapSystemtherapie" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "systemtherapie" ] ;
           fhir:variable [ fhir:v "syst" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapSystemtherapie" ] ;
           fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "syst" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryEndoTherapie" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-systemtherapie-procedure'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CheckHO" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ] ;
           fhir:condition [ fhir:v "code.coding.exists((system = 'https://www.medizininformatik-initiative.de/fhir/ext/modul-onko/CodeSystem/mii-cs-onko-therapie-typ') and (code = 'HO'))" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "CallMapEndoTherapie" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "procedure" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "tgt" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "endokrineTherapie" ] ;
             fhir:variable [ fhir:v "endo" ]
           ] ) ;
           fhir:dependent ( [
             fhir:name [ fhir:v "MapEndokrineTherapie" ] ;
             fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "endo" ] [ fhir:v "bundle" ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryRT" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-strahlentherapie'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapStrahlentherapie" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "strahlentherapie" ] ;
           fhir:variable [ fhir:v "rt" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapStrahlentherapie" ] ;
           fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "rt" ] [ fhir:v "bundle" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryTK" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(CarePlan) and resource.meta.profile.exists($this.contains('senologie-tumorboard'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapTK" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "cp" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "tumorkonferenz" ] ;
           fhir:variable [ fhir:v "tk" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapTumorkonferenz" ] ;
           fhir:variable ( [ fhir:v "cp" ] [ fhir:v "tk" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryPsychoonko" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-psychoonkologie'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapPsych" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "proc" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "psychoonkologie" ] ;
           fhir:variable [ fhir:v "psych" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapPsychoonkologie" ] ;
           fhir:variable ( [ fhir:v "proc" ] [ fhir:v "psych" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryResearchSubject" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "bundle" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(ResearchSubject)" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapStud" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "rs" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
