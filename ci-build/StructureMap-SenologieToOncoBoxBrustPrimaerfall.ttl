           fhir:variable ( [ fhir:v "rs" ] [ fhir:v "stud" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "CallMapVerlauf" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapVerlaufFromBundle" ] ;
         fhir:variable ( [ fhir:v "bundle" ] [ fhir:v "tgt" ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapPatient" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nPatient -> Patient-Block (Geburtsdatum, Geschlecht, PLZ, Menopausenstatus)\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Patient" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] [
       fhir:name [ fhir:v "bundle" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "SetPatGebdat" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "birthDate" ] ;
         fhir:variable [ fhir:v "bd" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geburtsdatum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "bd"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetPatGeschlW" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "gender" ] ;
         fhir:variable [ fhir:v "g" ] ;
         fhir:condition [ fhir:v "$this = 'female'" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geschlecht" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "W"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetPatGeschlM" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "gender" ] ;
         fhir:variable [ fhir:v "g" ] ;
         fhir:condition [ fhir:v "$this = 'male'" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geschlecht" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "M"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetPatGeschlD" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "gender" ] ;
         fhir:variable [ fhir:v "g" ] ;
         fhir:condition [ fhir:v "$this = 'other'" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geschlecht" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "D"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetPatGeschlU" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "gender" ] ;
         fhir:variable [ fhir:v "g" ] ;
         fhir:condition [ fhir:v "$this = 'unknown'" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "geschlecht" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:String ;
             fhir:v "U"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapPatPLZ" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "address" ] ;
         fhir:variable [ fhir:v "addr" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetPatPLZ" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "addr" ] ;
           fhir:element [ fhir:v "postalCode" ] ;
           fhir:variable [ fhir:v "plz" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "postleitzahl" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "plz"
