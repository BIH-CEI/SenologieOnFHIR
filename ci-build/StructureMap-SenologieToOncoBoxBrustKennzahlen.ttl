         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "kz" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "bezeichnung" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:String ;
               fhir:v "Praetherapeutische Fallbesprechung"
             ]
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "SetKB2Z" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "src" ]
         ] ) ;
