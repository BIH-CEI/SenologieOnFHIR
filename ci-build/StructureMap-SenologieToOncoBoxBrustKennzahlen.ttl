         fhir:element [ fhir:v "kennzahl" ] ;
         fhir:variable [ fhir:v "kz" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetKB2Id" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "src" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "kz" ] ;
