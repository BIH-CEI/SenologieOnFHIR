<span style=\"color: blue\">0</span> <i>\"SetKB17Z\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.nenner = <span style=\"color: blue\">0</span> <i>\"SetKB17N\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"InitKB17\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">KB-18 Drahtmarkierung</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.kennzahl<b> as </b><span style=\"color: maroon\">kz</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.id = <span style=\"color: blue\">'KB-18'</span> <i>\"SetKB18Id\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.bezeichnung = <span style=\"color: blue\">'Drahtmarkierung'</span> <i>\"SetKB18Name\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.zaehler = <span style=\"color: blue\">0</span> <i>\"SetKB18Z\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.nenner = <span style=\"color: blue\">0</span> <i>\"SetKB18N\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"InitKB18\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">KB-19 Revisionsoperationen</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.kennzahl<b> as </b><span style=\"color: maroon\">kz</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.id = <span style=\"color: blue\">'KB-19'</span> <i>\"SetKB19Id\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.bezeichnung = <span style=\"color: blue\">'Revisionsoperationen'</span> <i>\"SetKB19Name\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.zaehler = <span style=\"color: blue\">0</span> <i>\"SetKB19Z\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.nenner = <span style=\"color: blue\">0</span> <i>\"SetKB19N\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"InitKB19\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">KB-20 Checkliste</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.kennzahl<b> as </b><span style=\"color: maroon\">kz</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.id = <span style=\"color: blue\">'KB-20'</span> <i>\"SetKB20Id\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.bezeichnung = <span style=\"color: blue\">'Checkliste'</span> <i>\"SetKB20Name\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.zaehler = <span style=\"color: blue\">0</span> <i>\"SetKB20Z\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.nenner = <span style=\"color: blue\">0</span> <i>\"SetKB20N\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"InitKB20\"</i><span style=\"color: navy\">;</span>#xD;\n<span style=\"color: navy\">}#xD;\n#xD;\n</span></pre></div>"^^rdf:XMLLiteral ]
