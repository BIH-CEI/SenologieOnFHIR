         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "kz" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "zaehler" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Integer ;
               fhir:v 0
             ]
           ] )
         ] )
       ] [
         fhir:name [ fhir:v "SetKB1N" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "src" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "kz" ] ;
