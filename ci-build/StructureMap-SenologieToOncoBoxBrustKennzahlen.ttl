  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: StructureMap SenologieToOncoBoxBrustKennzahlen</b></p><a name=\"SenologieToOncoBoxBrustKennzahlen\"> </a><a name=\"hcSenologieToOncoBoxBrustKennzahlen\"> </a><pre class=\"fml\">#xD;\n<b>map</b><span style=\"color: navy\"> \"</span>https://www.senologie.org/fhir/StructureMap/SenologieToOncoBoxBrustKennzahlen<span style=\"color: navy\">\" = \"</span>SenologieToOncoBoxBrustKennzahlen<span style=\"color: navy\">\"#xD;\n#xD;\n</span><span style=\"color: navy\">// </span><span style=\"color: green\">title: Senologie Bundle to OncoBox Brust DKG-Kennzahlen (KB-1 bis KB-20)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">status: draft</span>#xD;\n#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"http://hl7.org/fhir/R4/bundle.html\" title=\"Bundle\">http://hl7.org/fhir/StructureDefinition/Bundle</a><span style=\"color: navy\">\" </span><b>alias </b>Bundle <b>as </b><b>source</b>#xD;\n<b>uses</b><span style=\"color: navy\"> \"</span><a href=\"StructureDefinition-oncobox-brust-meldung.html\" title=\"OncoBox Brust N1.1.1 Meldung (Logical Model)\">https://www.senologie.org/fhir/StructureDefinition/oncobox-brust-meldung</a><span style=\"color: navy\">\" </span><b>alias </b>OncoBoxBrust <b>as </b><b>target</b>#xD;\n#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Kennzahlen KB-1 bis KB-20 (DKG-Brustzentrum-Qualitaetsindikatoren)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Die OncoBox erwartet pro Kennzahl einen Zaehler/Nenner-Block. Die</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Aggregation erfolgt typischerweise ueber alle Primaerfaelle des</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Berichtszeitraums. In dieser Transformation werden pro Bundle alle</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">20 Kennzahlen als \"Shell\"-Eintraege angelegt (Zaehler=0, Nenner=0),</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">die dann von einer nachgelagerten Auswerteschicht (CQL) mit den</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">tatsaechlichen Aggregatwerten befuellt werden.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Die tatsaechliche Berechnung der Kennzahlen aus FHIR-Daten ist ein</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Aggregationsschritt, der nicht als 1:1-Mapping umsetzbar ist, sondern</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">eine CQL-basierte Auswertung erfordert.</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">Kurzreferenz (aus DKG-Erhebungsbogen / OncoBox Brust N1.1.1):</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-1  Postop. Fallbesprechung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-2  Praetherapeutische Fallbesprechung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-3  Fallbesprechung Rezidiv/Metastasen</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-4  Adjuvante Chemotherapie (invasiv)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-5  Adjuvante Chemotherapie (DCIS)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-6  Endokrine Therapie</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-7  Trastuzumab bei HER2+</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-8  First-Line-Therapie bei Metastasierung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-9  Psychoonkologische Mitbetreuung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-10 Sozialdienst-Mitbetreuung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-11 Studienteilnahme</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-12 Praeoperative histologische Sicherung</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-13 Primaerfaelle / Rezidive / Metastasen (Fallzahl)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-14 Anzahl Eingriffe bis R0</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-15 BET-Rate bei pT1</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-16 Mastektomien</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-17 Lymphknoten-Entfernung (Mind. 10 LK bei invasivem CA)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-18 Drahtmarkierung bei nicht-tastbaren Befunden</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-19 Revisionsoperationen</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">KB-20 Checkliste (organisatorisch)</span>#xD;\n<span style=\"color: navy\">// </span><span style=\"color: green\">============================================================================</span>#xD;\n<b>group </b>MapKennzahlen<span style=\"color: navy\">(</span><b>source</b> <span style=\"color: maroon\">src</span><span style=\"color: navy\"> : </span>Bundle, <b>target</b> <span style=\"color: maroon\">tgt</span><span style=\"color: navy\"> : </span>OncoBoxBrust<span style=\"color: navy\">)</span><span style=\"color: navy\"> {#xD;\n</span>  <span style=\"color: navy\">// </span><span style=\"color: green\">KB-1 Postop. Fallbesprechung</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.kennzahl<b> as </b><span style=\"color: maroon\">kz</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.id = <span style=\"color: blue\">'KB-1'</span> <i>\"SetKB1Id\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.bezeichnung = <span style=\"color: blue\">'Postop. Fallbesprechung'</span> <i>\"SetKB1Name\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.zaehler = <span style=\"color: blue\">0</span> <i>\"SetKB1Z\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.nenner = <span style=\"color: blue\">0</span> <i>\"SetKB1N\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">}</span> <i>\"InitKB1\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: navy\">// </span><span style=\"color: green\">KB-2 Praetherapeutische Fallbesprechung</span>#xD;\n  src<span style=\"color: navy\"><b> -&gt; </b></span>tgt.kennzahl<b> as </b><span style=\"color: maroon\">kz</span><b> then</b><span style=\"color: navy\"> {#xD;\n</span>    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.id = <span style=\"color: blue\">'KB-2'</span> <i>\"SetKB2Id\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.bezeichnung = <span style=\"color: blue\">'Praetherapeutische Fallbesprechung'</span> <i>\"SetKB2Name\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.zaehler = <span style=\"color: blue\">0</span> <i>\"SetKB2Z\"</i><span style=\"color: navy\">;</span>#xD;\n    src<span style=\"color: navy\"><b> -&gt; </b></span>kz.nenner = <span style=\"color: blue\">0</span> <i>\"SetKB2N\"</i><span style=\"color: navy\">;</span>#xD;\n  <span style=\"color: 