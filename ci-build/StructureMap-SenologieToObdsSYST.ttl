  fhir:name [ fhir:v "SenologieToObdsSYST"] ; # 
  fhir:status [ fhir:v "draft"] ; # 
  fhir:date [ fhir:v "2026-05-04T08:11:13+00:00"^^xsd:dateTime] ; # 
  fhir:publisher [ fhir:v "Berlin Institute of Health at Charité (BIH)"] ; # 
  fhir:contact ( [
     fhir:name [ fhir:v "Berlin Institute of Health at Charité (BIH)" ] ;
     fhir:telecom ( [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://www.bihealth.org" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "title: Senologie FHIR to oBDS Systemische Therapie (SYST)\r\nstatus: draft"] ; # 
  fhir:structure ( [
     fhir:url [
       fhir:v "http://hl7.org/fhir/StructureDefinition/Bundle"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/StructureDefinition/Bundle>
     ] ;
     fhir:mode [ fhir:v "source" ] ;
     fhir:alias [ fhir:v "Bundle" ]
  ] [
     fhir:url [
       fhir:v "https://www.senologie.org/fhir/StructureDefinition/obds-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/obds-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OBDSMeldung" ]
  ] ) ; # 
  fhir:import ( [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsTumorzuordnung>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToObdsNebenwirkung"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToObdsNebenwirkung>
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "SenologieToObdsSYST" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups (MapSYST, MapSubstanz) use\r\n`target tgt : BackboneElement` because FML has no syntax to declare the\r\nLogical Model sub-path for BackboneElement slices passed from parent groups.\r\nThe IG Publisher produces SM_TARGET_PATH errors (~16). The element names are\r\ncorrect per the oBDS Logical Model.\r\n============================================================================\r\nHauptgruppe: Bundle → oBDS SYST\r\nEin Bundle enthaelt eine Systemtherapie-Procedure (uebergeordnet)\r\nund zugehoerige MedicationStatements (einzelne Substanzgaben).\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "OBDSMeldung" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntrySYST" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-systemtherapie-procedure'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapSYST" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "proc" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "syst" ] ;
           fhir:variable [ fhir:v "syst" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapSYST" ] ;
           fhir:variable ( [ fhir:v "proc" ] [ fhir:v "syst" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapSYST" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nMapSYST: Procedure → oBDS SYST Basisdaten\r\nMapped Intention, Stellung zur OP, Therapieart, Protokoll, Zeitraum\r\n============================================================================" ] ;
