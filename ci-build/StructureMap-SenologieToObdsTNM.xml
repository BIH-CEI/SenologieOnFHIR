<b>map</b><span style="color: navy"> &quot;</span>https://www.senologie.org/fhir/StructureMap/SenologieToObdsTNM<span style="color: navy">&quot; = &quot;</span>SenologieToObdsTNM<span style="color: navy">&quot;

</span><span style="color: navy">// </span><span style="color: green">title: Senologie TNM Observations to oBDS TNM BackboneElement</span>
<span style="color: navy">// </span><span style="color: green">status: draft</span>

