</span>        c.code<b> as </b><span style="color: maroon">cd</span><span style="color: navy"><b> -&gt; </b></span>tgt.rSymbol = <span style="color: maroon">cd</span> <i>&quot;SetRSymbol&quot;</i><span style="color: navy">;</span>
