</span>    comp.value<b> as </b><span style="color: maroon">val</span><b> then</b><span style="color: navy"> {
</span>      val.coding<b> as </b><span style="color: maroon">c</span><b> then</b><span style="color: navy"> {
</span>        c.code<b> as </b><span style="color: maroon">cd</span><span style="color: navy"><b> -&gt; </b></span>tgt.ySymbol = <span style="color: maroon">cd</span> <i>&quot;SetYSymbol&quot;</i><span style="color: navy">;</span>
      <span style="color: navy">}</span> <i>&quot;ExtractYCode&quot;</i><span style="color: navy">;</span>
