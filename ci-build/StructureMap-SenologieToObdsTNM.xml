</span>    method.coding<b> as </b><span style="color: maroon">c</span><b> then</b><span style="color: navy"> {
</span>      c.code<b> as </b><span style="color: maroon">cd</span><span style="color: navy"><b> -&gt; </b></span>tgt.version = <span style="color: maroon">cd</span> <i>&quot;SetTNMVersion&quot;</i><span style="color: navy">;</span>
    <span style="color: navy">}</span> <i>&quot;ExtractTNMVersionCode&quot;</i><span style="color: navy">;</span>
  <span style="color: navy">}</span> <i>&quot;MapTNMVersion&quot;</i><span style="color: navy">;</span>
