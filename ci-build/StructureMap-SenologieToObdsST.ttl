  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "SenologieToObdsST" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: Sub-groups (MapST, MapBestrahlung) use\r\n`target tgt : BackboneElement` because FML has no syntax to declare the\r\nLogical Model sub-path for BackboneElement slices passed from parent groups.\r\nThe IG Publisher produces SM_TARGET_PATH errors (~19). The element names are\r\ncorrect per the oBDS Logical Model.\r\n============================================================================\r\nHauptgruppe: Bundle → oBDS ST (Strahlentherapie)\r\nEin Bundle enthaelt Strahlentherapie-Procedures (einzelne Bestrahlungsserien)\r\nund ggf. Observations fuer Nebenwirkungen (CTCAE).\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "OBDSMeldung" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "EntryST" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-strahlentherapie'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapST" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "proc" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "st" ] ;
           fhir:variable [ fhir:v "st" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapST" ] ;
           fhir:variable ( [ fhir:v "proc" ] [ fhir:v "st" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] )
  ] [
     fhir:name [ fhir:v "MapST" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
