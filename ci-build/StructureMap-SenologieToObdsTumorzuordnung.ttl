       fhir:v "https://www.senologie.org/fhir/StructureDefinition/obds-meldung"^^xsd:anyURI ;
       fhir:l <https://www.senologie.org/fhir/StructureDefinition/obds-meldung>
     ] ;
     fhir:mode [ fhir:v "target" ] ;
     fhir:alias [ fhir:v "OBDSMeldung" ]
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "MapTumorzuordnung" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "Known limitation: MapTumorzuordnung uses `target tgt : BackboneElement`\r\nbecause FML has no syntax to declare the Logical Model sub-path for\r\nBackboneElement slices. The IG Publisher produces SM_TARGET_PATH errors (~5).\r\nElement names are correct per the oBDS Logical Model.\r\n============================================================================\r\nTumorzuordnung: Condition (Diagnose) -> OBDSMeldung.tumorzuordnung\r\nWird von allen Meldungstypen importiert, da die Tumorzuordnung in jeder\r\noBDS-Meldung enthalten sein muss.\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Condition" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "BackboneElement" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "MapTumorID" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "identifier" ] ;
         fhir:variable [ fhir:v "id" ] ;
         fhir:condition [ fhir:v "system = 'https://www.senologie.org/fhir/sid/tumor-id'" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "SetTumorID" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "id" ] ;
           fhir:element [ fhir:v "value" ] ;
           fhir:variable [ fhir:v "v" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "tumorID" ] ;
           fhir:transform [ fhir:v "copy" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "v"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapPrimaertumorICD" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "code" ] ;
         fhir:variable [ fhir:v "code" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapICD10Coding" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "code" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'http://fhir.de/CodeSystem/bfarm/icd-10-gm'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "primaertumorICD" ] ;
           fhir:variable [ fhir:v "icd" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetICDCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "icd" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "cd"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetICDVersion" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "version" ] ;
             fhir:variable [ fhir:v "v" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "icd" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "version" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "v"
               ]
             ] )
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "SetDiagnosedatum" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "onset" ] ;
         fhir:variable [ fhir:v "onset" ] ;
         fhir:condition [ fhir:v "$this.is(dateTime)" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "diagnosedatum" ] ;
         fhir:transform [ fhir:v "copy" ] ;
         fhir:parameter ( [
           fhir:value [
             a fhir:Id ;
             fhir:v "onset"
           ]
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapSeitenlokalisation" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "bodySite" ] ;
         fhir:variable [ fhir:v "bs" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "TranslateSeitenlokalisation" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "bs" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'http://snomed.info/sct'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "seitenlokalisation" ] ;
           fhir:transform [ fhir:v "translate" ] ;
           fhir:parameter ( [
             fhir:value [
               a fhir:Id ;
               fhir:v "c"
             ]
           ] [
             fhir:value [
               a fhir:String ;
               fhir:v "https://www.senologie.org/fhir/ConceptMap/cm-sct-to-obds-seitenlokalisation"
             ]
           ] [
             fhir:value [
               a fhir:String ;
               fhir:v "code"
             ]
           ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "MapMorphologieICDO" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "code" ] ;
         fhir:variable [ fhir:v "code" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "MapMorphCoding" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "code" ] ;
           fhir:element [ fhir:v "coding" ] ;
           fhir:variable [ fhir:v "c" ] ;
           fhir:condition [ fhir:v "system = 'urn:oid:2.16.840.1.113883.6.43.1'" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "morphologieICDO" ] ;
           fhir:variable [ fhir:v "morph" ]
         ] ) ;
         fhir:rule ( [
           fhir:name [ fhir:v "SetMorphCode" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:variable [ fhir:v "cd" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "morph" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "code" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "cd"
               ]
             ] )
           ] )
         ] [
           fhir:name [ fhir:v "SetMorphVersion" ] ;
           fhir:source ( [
             fhir:context [ fhir:v "c" ] ;
             fhir:element [ fhir:v "version" ] ;
             fhir:variable [ fhir:v "v" ]
           ] ) ;
           fhir:target ( [
             fhir:context [ fhir:v "morph" ] ;
             fhir:contextType [ fhir:v "variable" ] ;
             fhir:element [ fhir:v "version" ] ;
             fhir:transform [ fhir:v "copy" ] ;
             fhir:parameter ( [
               fhir:value [
                 a fhir:Id ;
                 fhir:v "v"
               ]
             ] )
           ] )
         ] )
       ] )
     ] )
  ] ) . # 

