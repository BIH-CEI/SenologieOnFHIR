  ] ) ; # 
  fhir:import ( [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToIqtigBasis"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToIqtigBasis>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToIqtigBrust"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToIqtigBrust>
  ] [
     fhir:v "https://www.senologie.org/fhir/StructureMap/SenologieToIqtigOperation"^^xsd:anyURI ;
     fhir:l <https://www.senologie.org/fhir/StructureMap/SenologieToIqtigOperation>
  ] ) ; # 
  fhir:group ( [
     fhir:name [ fhir:v "SenologieToIqtigMammachirurgie181" ] ;
     fhir:typeMode [ fhir:v "none" ] ;
     fhir:documentation [ fhir:v "============================================================================\r\nMaster Orchestrator: Bundle -> IQTIG QS 18.1 Mammachirurgie\r\nEmpfaengt ein FHIR Bundle mit Senologie-Ressourcen (Patient, Encounter,\r\nCondition, Procedure, Specimen, Observations) und erzeugt eine vollstaendige\r\nIQTIG-QS-Meldung mit den drei Teildatensaetzen:\r\n- Teildatensatz Basis (B): Patient + Encounter\r\n- Teildatensatz Brust (BRUST): Condition + Pathologie (ein Eintrag je Seite)\r\n- Teildatensatz Operation (O): Procedure + Specimen (ein Eintrag je OP)\r\nAnalog zur IRegG-Meldung wird eine einzelne QS-Meldung pro Behandlungsfall\r\nerzeugt. Die Zuordnung der Teildatensaetze Brust und Operation erfolgt ueber\r\ndie laufenden Nummern (LNRBRUST, LNROP).\r\n============================================================================" ] ;
     fhir:input ( [
       fhir:name [ fhir:v "src" ] ;
       fhir:type [ fhir:v "Bundle" ] ;
       fhir:mode [ fhir:v "source" ]
     ] [
       fhir:name [ fhir:v "tgt" ] ;
       fhir:type [ fhir:v "IQTIG181" ] ;
       fhir:mode [ fhir:v "target" ]
     ] ) ;
     fhir:rule ( [
       fhir:name [ fhir:v "CallMapBasis" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "tgt" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "teildatensatzBasis" ] ;
         fhir:variable [ fhir:v "basis" ]
       ] ) ;
       fhir:dependent ( [
         fhir:name [ fhir:v "MapBasis" ] ;
         fhir:variable ( [ fhir:v "src" ] [ fhir:v "basis" ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryBrust" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Condition) and (resource.meta.profile.exists($this.contains('senologie-diagnose')) or resource.code.coding.exists((system = 'http://fhir.de/CodeSystem/bfarm/icd-10-gm') and code.startsWith('C50')))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapBrust" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "condition" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "teildatensatzBrust" ] ;
           fhir:variable [ fhir:v "brust" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapBrust" ] ;
           fhir:variable ( [ fhir:v "condition" ] [ fhir:v "brust" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] [
       fhir:name [ fhir:v "EntryOperation" ] ;
       fhir:source ( [
         fhir:context [ fhir:v "src" ] ;
         fhir:element [ fhir:v "entry" ] ;
         fhir:variable [ fhir:v "entry" ] ;
         fhir:condition [ fhir:v "resource.is(Procedure) and resource.meta.profile.exists($this.contains('senologie-brustop') or $this.contains('senologie-operation'))" ]
       ] ) ;
       fhir:rule ( [
         fhir:name [ fhir:v "CallMapOperation" ] ;
         fhir:source ( [
           fhir:context [ fhir:v "entry" ] ;
           fhir:element [ fhir:v "resource" ] ;
           fhir:variable [ fhir:v "procedure" ]
         ] ) ;
         fhir:target ( [
           fhir:context [ fhir:v "tgt" ] ;
           fhir:contextType [ fhir:v "variable" ] ;
           fhir:element [ fhir:v "teildatensatzOperation" ] ;
           fhir:variable [ fhir:v "op" ]
         ] ) ;
         fhir:dependent ( [
           fhir:name [ fhir:v "MapOperation" ] ;
           fhir:variable ( [ fhir:v "procedure" ] [ fhir:v "op" ] [ fhir:v "src" ] )
         ] )
       ] )
     ] )
  ] ) . # 

